<section class="articles-list">
  <div class="tracking-intro">
    <h1 class="hero-title">Comment bien emballer votre colis ?</h1>
    <p class="hero-subtitle">
      Pour chaque objet, un emballage adapté : découvrez les bonnes pratiques, étape par étape.
    </p>
  </div>
  <!-- Liste déroulante avec style glassmorphique -->
  <div class="text-center mb-4">
    <select id="article-select" class="form-select w-50 mx-auto">
      <option value="" selected disabled>Choisissez un objet...</option>
      {{#each articles}}
      <option value="#{{this.idCard}}">{{this.cardTitle}}</option>
      {{/each}}
    </select>
  </div>
</section>

<section class="catalogue">
  <div class="container first-container">
    <!-- Grille d'articles -->
    <div class="row g-4 mt-4">
      {{#each articles}}
      <div id="{{this.idCard}}" class="col-lg-4 col-md-6 col-sm-12">
        <div class="card h-100">
          <img src="/static/img/cardImg/{{this.cardImg}}" loading="lazy" alt="{{this.cardImgAlt}}" width="768"
            height="768" class="card-img-top">
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">{{this.cardTitle}}</h5>
            <div class="mt-auto">
              <a href="/conseils/{{this.slug}}" class="btn btn-primary w-100">Voir les conseils</a>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<!-- ===== SECTION À DÉCOUVRIR (HBS) ===== -->
<section class="related-links py-5">
  <div class="container first-container">
    <div class="text-center mb-4">
      <h3 class="related-title">Découvrez l'univers du colis</h3>
      <p class="related-subtitle">Découvrez nos autres services pour une expédition parfaite</p>
    </div>

    <div class="row g-4">
      <!-- Comparateur de prix -->
      <div class="col-md-3">
        <a href="/" class="link-card">
          <div class="link-icon">
            <i class="fa-solid fa-balance-scale"></i>
          </div>
          <h4 class="link-title">Comparer les prix</h4>
          <p class="link-description">Trouvez le meilleur tarif pour votre expédition</p>
          <span class="link-action">
            Comparer maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
          </span>
        </a>
      </div>

      <!-- Suivi de colis -->
      <div class="col-md-3">
        <a href="/suivi" class="link-card">
          <div class="link-icon">
            <i class="fa-solid fa-map-marker-alt"></i>
          </div>
          <h4 class="link-title">Suivre mon colis</h4>
          <p class="link-description">Suivez votre expédition en temps réel</p>
          <span class="link-action">
            Suivre maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
          </span>
        </a>
      </div>

      <!-- Matériel d'emballage -->
      <div class="col-md-3">
        <a href="/mon-materiel" class="link-card">
          <div class="link-icon">
            <i class="fa-solid fa-box"></i>
          </div>
          <h4 class="link-title">Matériel d'emballage</h4>
          <p class="link-description">Découvrez le matériel essentiel pour emballer</p>
          <span class="link-action">
            Voir le matériel <i class="fa-solid fa-arrow-right ms-1"></i>
          </span>
        </a>
      </div>

      <!-- Conseils d'expédition -->
      <div class="col-md-3">
        <a href="/conseils" class="link-card">
          <div class="link-icon">
            <i class="fa-solid fa-lightbulb"></i>
          </div>
          <h4 class="link-title">Conseils d'expédition</h4>
          <p class="link-description">Astuces pour une expédition réussie</p>
          <span class="link-action">
            Lire les conseils <i class="fa-solid fa-arrow-right ms-1"></i>
          </span>
        </a>
      </div>

      <!-- Services à venir -->
      <div class="col-md-3">
        <div class="link-card coming-soon">
          <div class="link-icon">
            <i class="fa-solid fa-hourglass-half"></i>
          </div>
          <h4 class="link-title">Services à venir</h4>
          <p class="link-description">De nouveaux services arrivent bientôt</p>
          <span class="link-action">
            Bientôt disponible <i class="fa-solid fa-clock ms-1"></i>
          </span>
        </div>
      </div>
    </div>

    <!-- Call-to-action principal -->
    <div class="text-center mt-5">
      <div class="main-cta">
        <h4 class="cta-title">Prêt à expédier votre colis ?</h4>
        <p class="cta-subtitle">Comparez les prix et trouvez la meilleure offre en quelques clics</p>
        <a href="/" class="btn btn-primary btn-lg">
          <i class="fa-solid fa-rocket me-2"></i>Commencer maintenant
        </a>
      </div>
    </div>


  </div>


</section>