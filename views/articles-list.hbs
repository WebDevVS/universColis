<nav class="breadcrumb">
  <div class="container">
    <a href="/" class="breadcrumb-link">Accueil</a>
    <span class="mx-2">></span>
    <span class="breadcrumb-current">Conseils d'emballage</span>
  </div>
</nav>


<section class="articles-list">

  <div class="tracking-intro">

    <h1 class="hero-title">Comment bien emballer votre colis ?</h1>
    <p class="hero-subtitle">
      Pour chaque objet, un emballage adapté : découvrez les bonnes pratiques, étape par étape.
    </p>
  </div>
  <!-- Liste déroulante avec style glassmorphique -->
  <div class="text-center mb-4 py-3 px-3">
    <select id="article-select" class="form-select w-50 mx-auto">
      <option value="" selected disabled>Choisissez un objet...</option>
      {{#each articles}}
      <option value="#{{this.idCard}}">{{this.cardTitle}}</option>
      {{/each}}
    </select>
  </div>
</section>

<section class="catalogue">
  <div class="container first-container">
    <!-- Grille d'articles -->
    <div class="row g-4">
      {{#each articles}}
      <div id="{{this.idCard}}" class="col-lg-4 col-md-6 col-sm-12">
        <div class="card h-100">
          {{#if @first}}
          <img src="/static/img/cardImg/{{this.cardImg}}" loading="eager" fetchpriority="high" alt="{{this.cardImgAlt}}"
            width="768" height="768" class="card-img-top">
          {{else}}
          <img src="/static/img/cardImg/{{this.cardImg}}" loading="lazy" alt="{{this.cardImgAlt}}" width="768"
            height="768" class="card-img-top">
          {{/if}}
          <div class="card-body d-flex flex-column">
            <h5 class="card-title">{{this.cardTitle}}</h5>
            <div class="card-meta mb-2">
              <span>⏱️ <strong>{{this.readingTime}} min</strong> de lecture</span>
              <span>📋 <strong>{{this.steps.length}} étapes</strong> faciles à suivre</span>
            </div>
            <p class="card-teaser">{{this.cardTeaser}}</p>
            <div class="mt-auto">
              <a href="/conseils/{{this.slug}}" class="btn btn-primary w-100">Consulter le guide →</a>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</section>

<section class="faq-section row d-flex justify-content-center" id="faq">
  <h2 class="text-center mb-4">FAQ</h2>
  <div class="accordion" id="faqAccordion">

    <div class="accordion-item">
      <h4 class="accordion-header" id="faq1">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#answer1">
          <strong>Comment choisir la bonne technique d'emballage pour mon objet ?</strong>
        </button>
      </h4>
      <div id="answer1" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
        <div class="accordion-body">
          <p>
            Chaque type d'objet nécessite une technique spécifique. Nos 12 guides spécialisés couvrent antiquités,
            électronique, bouteilles, plantes, instruments, tableaux et plus. Sélectionnez votre catégorie d'objet pour
            des conseils experts.
          </p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <h4 class="accordion-header" id="faq2">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#answer2">
          <strong>Quels matériaux utiliser pour emballer des objets fragiles ?</strong>
        </button>
      </h4>
      <div id="answer2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
        <div class="accordion-body">
          <p>
            Les matériaux varient selon l'objet : papier bulle
            pour l'électronique, mousse prédécoupée pour les antiquités, sachets hermétiques pour les liquides, papier
            glassine pour les tableaux. Consultez nos guides par catégorie.
          </p>
        </div>
      </div>
    </div>

    <div class="accordion-item">
      <h4 class="accordion-header" id="faq3">
        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#answer3">
          <strong>Comment éviter la casse lors de l'expédition ?</strong>
        </button>
      </h4>
      <div id="answer3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
        <div class="accordion-body">
          <p>
            Utilisez un emballage adapté au type d'objet, du calage efficace, des étiquettes 'Fragile' et choisissez un
            transporteur fiable. Nos guides détaillent les techniques par catégorie d'objet.
          </p>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Section "À découvrir" CONTEXTUELLE  -->
   {{> related-links/_base pageType="guides-catalog"}} 