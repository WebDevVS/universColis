/* ── PART HEADER ── */
.part-header { background:color-mix(in srgb,var(--pc) 5%,white); border-radius:var(--r); padding:1.75rem 2rem; margin-bottom:1.25rem; border-left:5px solid var(--pc); display:flex; align-items:flex-start; gap:1.25rem; box-shadow:0 2px 18px rgba(0,0,0,0.04); }
