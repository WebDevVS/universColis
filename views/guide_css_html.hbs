.diag-card-photo:hover{box-shadow:0 3px 12px rgba(0,0,0,0.07);}
.diag-photo-icon{font-size:1.4rem;margin-bottom:6px;}
.diag-photo-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.diag-photo-risk{font-size:0.75rem;color:var(--muted);margin-bottom:4px;line-height:1.4;}
.diag-photo-before{font-size:0.73rem;font-style:italic;color:var(--pc,var(--violet));line-height:1.4;border-top:1px solid rgba(0,0,0,0.05);padding-top:5px;margin-top:4px;}

/* ── ZONES SENSIBLES BOÎTIER ── */
.zones-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin:1.1rem 0;}
.zone-card{background:white;border-radius:var(--rsm);padding:0.85rem 1rem;border-left:3px solid var(--pc,var(--violet));display:flex;align-items:flex-start;gap:10px;}
.zone-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px;}
.zone-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:2px;}
.zone-risk{font-size:0.75rem;color:var(--muted);line-height:1.4;}
.zone-precaution{font-size:0.73rem;font-style:italic;color:var(--pc,var(--violet));margin-top:3px;line-height:1.3;}

/* ── BATTERIE ARBRE DÉCISIONNEL ── */
.battery-tree{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.bat-row{display:flex;align-items:center;gap:10px;background:white;border-radius:var(--rsm);padding:10px 14px;border-left:4px solid transparent;}
.bat-row.ok{border-left-color:var(--success);}
.bat-row.warn{border-left-color:var(--warn);}
.bat-row.danger{border-left-color:var(--danger);}
.bat-icon{font-size:1.1rem;flex-shrink:0;}
.bat-content{flex:1;}
.bat-situation{font-family:'Sora',sans-serif;font-size:0.83rem;font-weight:700;color:var(--text);margin-bottom:2px;}
.bat-action{font-size:0.79rem;color:var(--muted);line-height:1.4;}
.bat-badge{display:inline-block;font-size:0.68rem;font-weight:700;border-radius:8px;padding:2px 9px;white-space:nowrap;flex-shrink:0;}
.bat-badge.ok{background:var(--success-bg);color:var(--success);}
.bat-badge.warn{background:var(--warn-bg);color:var(--warn);}
.bat-badge.no{background:var(--danger-bg);color:var(--danger);}

/* ── PREUVES GRID ── */
.preuves-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:1.1rem 0;}
.preuve-card{background:white;border-radius:var(--rsm);padding:0.85rem;border:1.5px solid rgba(0,0,0,0.07);text-align:center;}
.preuve-icon{font-size:1.3rem;margin-bottom:5px;}
.preuve-label{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.preuve-desc{font-size:0.72rem;color:var(--muted);line-height:1.4;}

/* ── STEPS ── */
.steps-list{display:flex;flex-direction:column;}
.step-row{display:grid;grid-template-columns:50px 1fr;position:relative;}
.step-row:not(:last-child) .step-spine::after{content:'';position:absolute;top:40px;left:50%;transform:translateX(-50%);width:2px;height:calc(100% - 40px);background:linear-gradient(to bottom,color-mix(in srgb,var(--pc) 30%,transparent) 60%,transparent);}
.step-spine{display:flex;flex-direction:column;align-items:center;position:relative;}
.step-num{width:38px;height:38px;background:var(--pc);border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:800;box-shadow:0 4px 12px color-mix(in srgb,var(--pc) 35%,transparent);z-index:1;flex-shrink:0;}
.step-content{padding:2px 0 2.5rem 18px;}
.step-content h4{font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:0.5rem;line-height:1.3;}
.step-content p{font-size:0.91rem;color:var(--text);line-height:1.72;margin-bottom:0.7rem;}
.step-content p:last-child{margin-bottom:0;}
.step-content strong{font-weight:600;}
.step-content ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;margin:0.6rem 0;}
.step-content ul li{font-size:0.88rem;padding-left:18px;position:relative;line-height:1.55;}
.step-content ul li::before{content:'→';position:absolute;left:0;color:var(--coral);font-weight:700;}

/* ── STEP WITH IMG ── */
.step-with-img{display:grid;grid-template-columns:1fr 200px;gap:16px;align-items:start;margin-bottom:0.75rem;}
.step-img-col{display:flex;flex-direction:column;gap:6px;justify-self:center;max-width:200px;}
.step-img-ph{width:100%;aspect-ratio:4/3;background:var(--light);border-radius:var(--rsm);display:flex;align-items:center;justify-content:center;font-size:0.75rem;color:var(--muted);text-align:center;padding:12px;border:1.5px dashed rgba(0,0,0,0.1);}
.step-caption-txt{font-size:0.75rem;font-style:italic;color:var(--muted);line-height:1.5;}

/* ── MAT INLINE ── */
.mat-inline{background:color-mix(in srgb,var(--pc,var(--violet)) 8%,white);border-radius:var(--rsm);padding:1rem 1.25rem;margin:0.9rem 0;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 22%,transparent);}
.mat-inline-label{font-family:'Sora',sans-serif;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--pc,var(--violet));margin-bottom:0.6rem;}
.mat-links{display:flex;flex-direction:column;gap:6px;}
.mat-link-row{display:flex;align-items:center;gap:10px;background:white;border-radius:8px;padding:9px 12px;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 14%,transparent);transition:border-color .2s;flex-wrap:wrap;}
.mat-link-row:hover{border-color:color-mix(in srgb,var(--pc,var(--violet)) 35%,transparent);}
.mat-link-name{flex:1;font-size:0.86rem;font-weight:600;color:var(--text);min-width:120px;}
.mat-link-desc{font-size:0.78rem;color:var(--muted);width:100%;}
.mat-link-btn{display:inline-flex;align-items:center;gap:6px;background:var(--pc,var(--violet));color:white;text-decoration:none;padding:6px 13px;border-radius:8px;font-size:0.78rem;font-weight:600;white-space:nowrap;flex-shrink:0;transition:opacity .2s;}
.mat-link-btn::before{content:'🛒';font-size:0.82rem;}
.mat-link-btn:hover{opacity:0.82;}

/* ── RISQUE TRANSPORTEUR ── */
.risk-transport-grid{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.risk-transport-row{display:grid;grid-template-columns:90px 1fr 1fr 1fr;gap:10px;background:white;border-radius:var(--rsm);padding:10px 14px;align-items:center;border-left:4px solid transparent;}
.risk-transport-row.low{border-left-color:var(--success);}
.risk-transport-row.med{border-left-color:var(--p2);}
.risk-transport-row.high{border-left-color:var(--warn);}
.risk-transport-row.critical{border-left-color:var(--danger);}
.risk-transport-row.special{border-left-color:var(--violet);}
.rt-level{font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:700;}
.risk-transport-row.low .rt-level{color:var(--success);}
.risk-transport-row.med .rt-level{color:var(--p2);}
.risk-transport-row.high .rt-level{color:var(--warn);}
.risk-transport-row.critical .rt-level{color:var(--danger);}
.risk-transport-row.special .rt-level{color:var(--violet);}
.rt-example{font-size:0.8rem;color:var(--muted);}
.rt-priority{font-size:0.8rem;font-weight:600;color:var(--text);}
.rt-check{font-size:0.78rem;color:var(--muted);font-style:italic;}

/* ── ASSURANCE TABLE ── */
.assurance-grid{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.assurance-row{display:flex;align-items:flex-start;gap:12px;background:white;border-radius:var(--rsm);padding:10px 14px;border-left:3px solid var(--pc,var(--violet));}
.assurance-val{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);min-width:130px;flex-shrink:0;}
.assurance-decision{font-size:0.8rem;color:var(--muted);line-height:1.45;}

/* ── CHECKLIST ── */
.checklist{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.check-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.check-ico{font-size:1.1rem;flex-shrink:0;}

/* ── CHECKLIST FINALE 5 BLOCS ── */
.checklist-finale{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:1.1rem 0;}
.cf-bloc{background:white;border-radius:var(--rsm);padding:0.85rem;border-top:3px solid var(--pc,var(--violet));border:1.5px solid rgba(0,0,0,0.07);border-top:3px solid var(--pc,var(--violet));}
.cf-title{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;color:var(--pc,var(--violet));margin-bottom:6px;display:flex;align-items:center;gap:6px;}
.cf-items{display:flex;flex-direction:column;gap:3px;}
.cf-item{font-size:0.72rem;color:var(--muted);padding-left:12px;position:relative;line-height:1.4;}
.cf-item::before{content:'·';position:absolute;left:0;color:var(--pc,var(--violet));}

/* ── PROCÉDURE (réutilisé) ── */
.procedure{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.proc-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.proc-n{width:24px;height:24px;background:var(--pc,var(--violet));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-family:'Sora',sans-serif;font-size:0.73rem;font-weight:800;flex-shrink:0;}

/* ── TIPS ── */
.tips-wrap{display:flex;flex-direction:column;gap:7px;margin:1.1rem 0;}
.tips-head{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tips-col-lbl{font-family:'Sora',sans-serif;font-size:0.74rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:6px 12px;border-radius:8px;text-align:center;}
.tips-col-lbl.g{background:var(--success-bg);color:var(--success);}
.tips-col-lbl.b{background:var(--danger-bg);color:var(--danger);}
.tips-pair{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tip-c{border-radius:var(--rsm);padding:11px 13px;font-size:0.86rem;line-height:1.5;display:flex;align-items:flex-start;gap:8px;}
.tip-c.g{background:var(--success-bg);border:1.5px solid var(--success-bd);color:var(--success);}
.tip-c.b{background:var(--danger-bg);border:1.5px solid var(--danger-bd);color:var(--danger);}

/* ── DEST SCALE (réutilisé) ── */
.dest-scale{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin:1.1rem 0;}
.dest-col{border-radius:var(--rsm);overflow:hidden;border:1.5px solid rgba(0,0,0,0.07);}
.dest-col-header{padding:0.65rem 0.75rem;text-align:center;}
.dest-col:nth-child(1) .dest-col-header{background:color-mix(in srgb,var(--success) 12%,white);}
.dest-col:nth-child(2) .dest-col-header{background:color-mix(in srgb,var(--p2) 12%,white);}
.dest-col:nth-child(3) .dest-col-header{background:color-mix(in srgb,var(--warn) 12%,white);}
.dest-col:nth-child(4) .dest-col-header{background:color-mix(in srgb,var(--danger) 12%,white);}
.dest-col-name{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;}
.dest-col:nth-child(1) .dest-col-name{color:var(--success);}
.dest-col:nth-child(2) .dest-col-name{color:var(--p2);}
.dest-col:nth-child(3) .dest-col-name{color:var(--warn);}
.dest-col:nth-child(4) .dest-col-name{color:var(--danger);}
.dest-col-body{background:white;padding:0.65rem 0.75rem;}
.dest-col-items{display:flex;flex-direction:column;gap:3px;}
.dest-col-item{font-size:0.72rem;color:var(--muted);padding-left:12px;position:relative;line-height:1.4;}
.dest-col-item::before{content:'·';position:absolute;left:0;}

/* ── FAQ ── */
.faq-list{display:flex;flex-direction:column;gap:7px;}
.faq-item{border:1.5px solid rgba(0,0,0,0.07);border-radius:var(--rsm);overflow:hidden;}
.faq-q{width:100%;background:none;border:none;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;color:var(--text);cursor:pointer;text-align:left;transition:background .2s;}
.faq-q:hover{background:var(--violet-l);}
.faq-q.open{background:var(--violet);color:white;}
.faq-chev{font-size:0.65rem;flex-shrink:0;transition:transform .25s;}
.faq-q.open .faq-chev{transform:rotate(180deg);}
.faq-a{display:none;padding:14px 18px;font-size:0.9rem;color:var(--muted);background:rgba(130,105,164,0.04);border-top:1px solid rgba(130,105,164,0.1);line-height:1.7;}
.faq-a.open{display:block;}

/* ── SOURCES ── */
.sources{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.5rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.7;}
.sources strong{font-family:'Sora',sans-serif;font-size:0.8rem;color:var(--text);display:block;margin-bottom:6px;}
.sources ul{list-style:none;padding:0;}
.sources li{padding-left:14px;position:relative;}
.sources li::before{content:'·';position:absolute;left:0;}
.sources a{color:var(--violet);text-decoration:none;}
.sources a:hover{text-decoration:underline;}
.affil{background:var(--violet-l);border-radius:var(--rsm);padding:11px 16px;margin:1.25rem 0 0;display:flex;align-items:flex-start;gap:9px;font-size:0.79rem;color:var(--muted);line-height:1.5;border-left:3px solid var(--violet);}
.maj{background:var(--light);border-radius:var(--rsm);padding:0.9rem 1.25rem;margin:1.25rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.6;border-left:3px solid rgba(0,0,0,0.1);}
.maj strong{color:var(--text);font-family:'Sora',sans-serif;font-size:0.8rem;}

/* ── RESPONSIVE ── */
@media(max-width:780px){
  .hero{padding:1.75rem 1.5rem 0;}
  .hero-bottom{margin:0 -1.5rem;padding:1.25rem 1.5rem 0;}
  .hero-bottom-grid{grid-template-columns:1fr;}
  .hb-col:not(:last-child){border-bottom:1px solid var(--violet-m);}
  .part-header{padding:1.5rem;flex-direction:column;gap:0.5rem;}
  .part-num{font-size:1.8rem;}
  .prose{padding:1.5rem;}
  .en-bref{padding:1.5rem;}
