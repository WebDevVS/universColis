      <li><a href="https://aide.laposte.fr/contenu/comment-realiser-ma-declaration-en-douane-cn23" target="_blank" rel="noopener">La Poste — déclaration douanière CN23</a></li>
      <li><a href="https://www.chronopost.fr/fr/livraison/nos-services/assurance-colis" target="_blank" rel="noopener">Chronopost — assurance colis et option Ad Valorem</a></li>
      <li><a href="https://www.dhl.com/discover/fr-fr/logistics-advice/import-export-advice/how-to-ship-batteries" target="_blank" rel="noopener">DHL — expédition de batteries lithium</a></li>
      <li><a href="https://www.douane.gouv.fr/demarche/connaitre-la-nomenclature-de-votre-marchandise" target="_blank" rel="noopener">Douane française — nomenclature douanière</a></li>
      <li><a href="https://www.vinted.fr/help/729-le-colis-a-ete-endommage-en-cours-dacheminement" target="_blank" rel="noopener">Vinted — colis endommagé pendant l'acheminement</a></li>
      <li><a href="https://www.leboncoin.fr/dc/vos_droits_et_obligations" target="_blank" rel="noopener">Leboncoin — droits et obligations vendeur</a></li>
    </ul>
  </div>

  <div class="affil">
    <span style="color:var(--violet);font-size:1rem;flex-shrink:0;margin-top:1px;">ℹ</span>
    <span>Certains liens sur cette page sont affiliés. Nous pouvons toucher une commission sans coût supplémentaire pour vous, ce qui nous aide à maintenir nos services gratuits.</span>
  </div>

</div><!-- /page -->

<script>
function toggleFaq(btn){
  const a=btn.nextElementSibling,was=btn.classList.contains('open');
  document.querySelectorAll('.faq-q.open').forEach(b=>{b.classList.remove('open');b.nextElementSibling.classList.remove('open');});
  if(!was){btn.classList.add('open');a.classList.add('open');}
}
const navLinks=document.querySelectorAll('.sn');
const ids=['avant','emballage','apres'];
let ticking=false;
window.addEventListener('scroll',()=>{
  if(ticking)return;ticking=true;
  requestAnimationFrame(()=>{
    let cur=ids[0];
    ids.forEach(id=>{
      const el=document.getElementById(id);
      if(el&&window.scrollY>=el.offsetTop-130)cur=id;
    });
    navLinks.forEach(l=>{
      const isActive=l.getAttribute('href')==='#'+cur;
      l.classList.toggle('active',isActive);
    });
    ticking=false;
  });
},{passive:true});
</script>
</body>
