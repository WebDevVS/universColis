<!DOCTYPE html>
<html lang="fr">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Comment expédier une œuvre d'art fragile – UniversColis</title>
  <link
    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Lora:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@400;500&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    :root {
      --violet: #8269A4;
      --violet-d: #6b54a0;
      --violet-l: rgba(130, 105, 164, 0.10);
      --violet-m: rgba(130, 105, 164, 0.22);
      --coral: #FA7E75;
      --coral-l: rgba(250, 126, 117, 0.09);
      --bg: #E9E6E1;
      --white: #fff;
      --text: #1e1e1e;
      --muted: #666;
      --light: #f7f5f2;
      --success: #1a5f17;
      --success-bg: rgba(31, 162, 22, 0.07);
      --success-bd: rgba(31, 162, 22, 0.22);
      --warn: #7a4f00;
      --warn-bg: rgba(255, 160, 0, 0.09);
      --warn-bd: rgba(255, 160, 0, 0.28);
      --danger: #8a0000;
      --danger-bg: rgba(204, 0, 0, 0.06);
      --danger-bd: rgba(204, 0, 0, 0.18);
      --r: 16px;
      --rsm: 10px;
      /* ── Couleurs par partie (Option A) ── */
      --p1: #5B7FA0;
      --p1-l: rgba(91, 127, 160, 0.10);
      --p1-m: rgba(91, 127, 160, 0.22);
      --p2: #C4843A;
      --p2-l: rgba(196, 132, 58, 0.10);
      --p2-m: rgba(196, 132, 58, 0.22);
      --p3: #6A9E7F;
      --p3-l: rgba(106, 158, 127, 0.10);
      --p3-m: rgba(106, 158, 127, 0.22);
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 16px;
      line-height: 1.7;
    }

    /* ── BREADCRUMB ── */
    .bc {
      padding: 14px 20px;
      font-size: 0.8rem;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 6px;
      max-width: 960px;
      margin: 0 auto;
      flex-wrap: wrap;
    }

    .bc a {
      color: var(--violet);
      text-decoration: none;
      font-weight: 500;
    }

    .bc a:hover {
      text-decoration: underline;
    }

    /* ── HERO ── */
    .hero {
      max-width: 960px;
      margin: 0 auto 0;
      padding: 2.5rem 2.5rem 0;
      position: relative;
    }

    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: rgba(130, 105, 164, 0.10);
      border: 1px solid rgba(130, 105, 164, 0.2);
      border-radius: 20px;
      padding: 4px 14px;
      font-size: 0.73rem;
      font-weight: 700;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: var(--violet);
      margin-bottom: 1.2rem;
    }

    .hero h1 {
      font-family: 'Sora', sans-serif;
      font-size: clamp(1.6rem, 3.8vw, 2.4rem);
      font-weight: 800;
      line-height: 1.15;
      max-width: 700px;
      margin-bottom: 0.75rem;
      color: var(--text);
    }

    /* tricolor line under title */
    .hero-tricolor {
      display: flex;
      gap: 4px;
      margin-bottom: 1.1rem;
    }

    .hero-tricolor span {
      height: 4px;
      border-radius: 2px;
    }

    .hero-tricolor span:nth-child(1) {
      width: 64px;
      background: var(--p1);
    }

    .hero-tricolor span:nth-child(2) {
      width: 44px;
      background: var(--p2);
    }

    .hero-tricolor span:nth-child(3) {
      width: 54px;
      background: var(--p3);
    }

    .hero-lead {
      font-family: 'Lora', serif;
      font-size: 1rem;
      line-height: 1.75;
      color: var(--muted);
      max-width: 600px;
      margin-bottom: 1.5rem;
      font-style: italic;
    }

    .hero-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      padding-bottom: 1.75rem;
    }

    .hero-pill {
      background: white;
      border: 1px solid rgba(0, 0, 0, 0.1);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--muted);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    }

    .hero-bottom {
      background: white;
      border-radius: var(--r) var(--r) 0 0;
      margin: 0 -2.5rem;
      padding: 1.5rem 2.5rem 0;
    }

    .hero-bottom-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: rgba(0, 0, 0, 0.06);
      border-radius: var(--rsm) var(--rsm) 0 0;
      overflow: hidden;
    }

    .hb-col {
      background: var(--light);
      padding: 1rem 1.25rem;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.5;
      border-top: 3px solid transparent;
      text-decoration: none;
      display: block;
      transition: background .2s, opacity .2s;
      cursor: pointer;
    }

    .hb-col:hover {
      background: white;
      opacity: 0.9;
    }

    .hb-col:nth-child(1) {
      border-top-color: var(--p1);
    }

    .hb-col:nth-child(2) {
      border-top-color: var(--p2);
    }

    .hb-col:nth-child(3) {
      border-top-color: var(--p3);
    }

    .hb-col strong {
      display: block;
      font-family: 'Sora', sans-serif;
      font-size: 0.85rem;
      color: var(--text);
      margin-bottom: 3px;
    }

    /* ── STICKY NAV ── */
    .sticky-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255, 255, 255, 0.96);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--violet-m);
      margin-bottom: 2rem;
    }

    .snav-inner {
      max-width: 960px;
      margin: 0 auto;
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
    }

    .snav-inner::-webkit-scrollbar {
      display: none;
    }

    .sn {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 14px 20px;
      font-family: 'Sora', sans-serif;
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--muted);
      text-decoration: none;
      white-space: nowrap;
      border-bottom: 3px solid transparent;
      transition: color .2s, border-color .2s;
    }

    .sn:hover {
      color: var(--violet);
    }

    .sn.active {
      color: var(--violet);
      border-bottom-color: var(--violet);
    }

    .sn.active[data-part="1"] {
      color: var(--p1);
      border-bottom-color: var(--p1);
    }

    .sn.active[data-part="2"] {
      color: var(--p2);
      border-bottom-color: var(--p2);
    }

    .sn.active[data-part="3"] {
      color: var(--p3);
      border-bottom-color: var(--p3);
    }

    .sn-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: rgba(130, 105, 164, 0.2);
      flex-shrink: 0;
      transition: background .2s;
    }

    .sn.active .sn-dot {
      background: var(--violet);
    }

    .sn.active[data-part="1"] .sn-dot {
      background: var(--p1);
    }

    .sn.active[data-part="2"] .sn-dot {
      background: var(--p2);
    }

    .sn.active[data-part="3"] .sn-dot {
      background: var(--p3);
    }

    /* ── PAGE WRAPPER ── */
    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 0 0 3rem;
    }

    /* ── EN BREF ── */
    .en-bref {
      background: white;
      border-radius: var(--r);
      padding: 1.75rem 2rem;
      margin: 0 auto 2rem;
      box-shadow: 0 2px 18px rgba(0, 0, 0, 0.04);
      border-top: 4px solid var(--violet);
    }

    .en-bref-label {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: 'Sora', sans-serif;
      font-size: 0.71rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--violet);
      margin-bottom: 1rem;
    }

    .en-bref-text {
      font-family: 'Lora', serif;
      font-size: 1rem;
      line-height: 1.75;
      color: var(--text);
      font-style: italic;
      margin-bottom: 1.25rem;
    }

    .en-bref-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .eb-pill {
      background: var(--violet-l);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 0.83rem;
      color: var(--violet);
      font-weight: 500;
      border: 1px solid var(--violet-m);
    }

    /* ── SECTION PART HEADER ── */
    .part-header {
      background: color-mix(in srgb, var(--pc) 5%, white);
      border-radius: var(--r);
      padding: 1.75rem 2rem;
      margin-bottom: 1.25rem;
      border-left: 5px solid var(--pc);
      display: flex;
      align-items: flex-start;
      gap: 1.25rem;
      box-shadow: 0 2px 18px rgba(0, 0, 0, 0.04);
    }

    .part-num {
      font-family: 'Sora', sans-serif;
      font-size: 2.5rem;
      font-weight: 800;
      color: var(--pc);
      opacity: 0.25;
      line-height: 1;
      flex-shrink: 0;
      margin-top: -4px;
    }

    .part-tag {
      display: inline-block;
      background: color-mix(in srgb, var(--pc) 12%, transparent);
      color: var(--pc);
      border-radius: 20px;
      padding: 3px 12px;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      margin-bottom: 6px;
    }

    .part-header h2 {
      font-family: 'Sora', sans-serif;
      font-size: 1.3rem;
      font-weight: 800;
      color: var(--text);
      margin-bottom: 0.4rem;
    }

    .part-header p {
      font-size: 0.9rem;
      color: var(--muted);
      line-height: 1.6;
      margin: 0;
    }

    /* couleur par partie */
    .p1 {
      --pc: var(--p1);
    }

    .p2 {
      --pc: var(--p2);
    }

    .p3 {
      --pc: var(--p3);
    }

    /* ── PROSE ── */
    .prose {
      background: white;
      border-radius: var(--r);
      padding: 2rem;
      margin-bottom: 1.25rem;
      box-shadow: 0 2px 18px rgba(0, 0, 0, 0.04);
    }

    /* Subtle part color thread on prose blocks */
    .p1 .prose {
      border-left: 3px solid color-mix(in srgb, var(--p1) 35%, transparent);
      border-radius: 0 var(--r) var(--r) 0;
    }

    .p2 .prose {
      border-left: 3px solid color-mix(in srgb, var(--p2) 35%, transparent);
      border-radius: 0 var(--r) var(--r) 0;
    }

    .p3 .prose {
      border-left: 3px solid color-mix(in srgb, var(--p3) 35%, transparent);
      border-radius: 0 var(--r) var(--r) 0;
    }

    .prose h3 {
      font-family: 'Sora', sans-serif;
      font-size: 1.03rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.75rem;
      margin-top: 1.5rem;
    }

    .prose h3:first-child {
      margin-top: 0;
    }

    .prose p {
      font-size: 0.93rem;
      color: var(--text);
      line-height: 1.75;
      margin-bottom: 0.9rem;
    }

    .prose p:last-child {
      margin-bottom: 0;
    }

    .prose strong {
      font-weight: 600;
    }

    .prose ul {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 5px;
      margin: 0.75rem 0;
    }

    .prose ul li {
      font-size: 0.91rem;
      color: var(--text);
      padding-left: 20px;
      position: relative;
      line-height: 1.6;
    }

    .prose ul li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: var(--pc, var(--violet));
      font-weight: 700;
    }

    /* ── CALLOUT ── */
    .callout {
      border-radius: var(--rsm);
      padding: 1rem 1.25rem;
      margin: 1.1rem 0;
      font-size: 0.88rem;
      line-height: 1.65;
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .callout-ico {
      font-size: 1.1rem;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .callout-body {
      flex: 1;
    }

    .callout-body strong {
      display: block;
      font-family: 'Sora', sans-serif;
      font-size: 0.78rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 4px;
    }

    /* callouts sémantiques (indépendants des parties) */
    .callout.warn {
      background: var(--warn-bg);
      border-left: 3px solid #ffa000;
      color: var(--warn);
    }

    .callout.warn strong {
      color: #b37700;
    }

    /* callout coloré selon la partie courante */
    .callout.info,
    .callout.tip {
      background: color-mix(in srgb, var(--pc) 9%, white);
      border-left: 3px solid var(--pc);
    }

    .callout.info strong,
    .callout.tip strong {
      color: var(--pc);
    }

    /* ── DIAGNOSTIC GRID ── */
    .diag-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 1.1rem 0;
    }

    .diag-card {
      background: var(--light);
      border-radius: var(--rsm);
      border: 1.5px solid rgba(0, 0, 0, 0.06);
      transition: border-color .2s;
      overflow: hidden;
      padding: 0;
    }

    .diag-card:hover {
      border-color: color-mix(in srgb, var(--pc, var(--violet)) 30%, transparent);
    }

    .diag-card-img {
      width: 100%;
      height: 90px;
      object-fit: cover;
      display: block;
    }

    .diag-card-body {
      padding: 0.85rem 1rem;
    }

    .diag-icon {
      font-size: 1.3rem;
      margin-bottom: 5px;
    }

    .diag-label {
      font-family: 'Sora', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--text);
    }

    .diag-sub {
      font-size: 0.77rem;
      color: var(--muted);
      margin-top: 3px;
      line-height: 1.45;
    }

    /* ── FORMULE ── */
    .formula-box {
      background: var(--light);
      border-radius: var(--rsm);
      padding: 1.25rem 1.5rem;
      margin: 1.1rem 0;
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 10px;
    }

    .formula-item {
      text-align: center;
    }

    .formula-val {
      font-family: 'Sora', sans-serif;
      font-size: 1.5rem;
      font-weight: 800;
      line-height: 1;
    }

    .formula-lbl {
      font-size: 0.72rem;
      color: var(--muted);
      margin-top: 3px;
    }

    .formula-op {
      font-family: 'Sora', sans-serif;
      font-size: 1.2rem;
      color: var(--muted);
      align-self: center;
    }

    .formula-vs {
      font-family: 'Sora', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      background: var(--danger-bg);
      color: var(--danger);
      border: 1px solid var(--danger-bd);
      border-radius: 8px;
      padding: 6px 14px;
      white-space: nowrap;
      align-self: center;
    }

    .f-violet {
      color: var(--violet);
    }

    .f-danger {
      color: var(--danger);
    }

    /* ── LAYERS DIAGRAM ── */
    .layers-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
      margin: 1.1rem 0;
      align-items: stretch;
    }

    .layers-img {
      border-radius: var(--rsm);
      overflow: hidden;
    }

    .layers-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      display: block;
    }

    .layers-diagram {
      display: flex;
      flex-direction: column;
      gap: 3px;
    }

    .layer {
      display: flex;
      align-items: center;
      gap: 10px;
      border-radius: 8px;
      padding: 7px 10px;
      font-size: 0.84rem;
      font-weight: 500;
      flex: 1;
    }

    .layer-arrow {
      text-align: center;
      color: var(--muted);
      font-size: 0.75rem;
      padding: 1px 0;
    }

    .layer-sub {
      font-size: 0.72rem;
      font-weight: 400;
      opacity: 0.75;
      margin-left: 4px;
    }

    .l1 {
      background: #2a3a4a;
      color: white;
    }

    .l2 {
      background: #3a4a5a;
      color: white;
    }

    .l3 {
      background: #4a5a6a;
      color: white;
    }

    .l4 {
      background: #5a6a7a;
      color: white;
    }

    .l5 {
      background: #6a7a8a;
      color: white;
    }

    .l6 {
      background: var(--p2);
      color: white;
    }

    .layer-n {
      font-family: 'Sora', sans-serif;
      font-size: 0.7rem;
      font-weight: 800;
      opacity: 0.6;
      flex-shrink: 0;
      width: 16px;
      text-align: center;
    }

    @media(max-width:640px) {
      .layers-wrap {
        grid-template-columns: 1fr;
      }

      .layers-img {
        min-height: 200px;
      }
    }

    /* ── CARTON CHOICE ── */
    .carton-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 1.1rem 0;
    }

    .carton-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 1.1rem 0;
    }

    .carton-card {
      background: var(--light);
      border-radius: var(--rsm);
      border: 2px solid transparent;
      transition: border-color .2s, box-shadow .2s;
      overflow: hidden;
      padding: 0;
    }

    .carton-card:hover {
      border-color: var(--violet-m);
    }

    .carton-card-img {
      width: 100%;
      height: 130px;
      /* ← monte de 90 à 110px pour plus de contexte */
      object-fit: cover;
      object-position: center;
      display: block;
      transform: none;
    }

    .carton-card-body {
      padding: 0.75rem 0.85rem;
      text-align: center;
    }

    .carton-icon {
      display: none;
    }

    .carton-type {
      font-family: 'Sora', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--text);
    }

    .carton-when {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 3px;
      line-height: 1.4;
    }

    .carton-card.rec {
      border-color: color-mix(in srgb, var(--pc) 30%, transparent);
      background: color-mix(in srgb, var(--pc) 9%, white);
    }

    .carton-card.rec .carton-type {
      color: var(--pc);
    }

    .carton-card:hover {
      border-color: var(--violet-m);
    }

    .carton-icon {
      font-size: 1.5rem;
      margin-bottom: 5px;
    }

    .carton-type {
      font-family: 'Sora', sans-serif;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--text);
    }

    .carton-when {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 3px;
      line-height: 1.4;
    }

    .carton-card.rec {
      border-color: color-mix(in srgb, var(--pc) 30%, transparent);
      background: color-mix(in srgb, var(--pc) 9%, white);
    }

    .carton-card.rec .carton-type {
      color: var(--pc);
    }

    /* ── ÉTAPES ── */
    .steps-list {
      display: flex;
      flex-direction: column;
    }

    .step-row {
      display: grid;
      grid-template-columns: 50px 1fr;
      position: relative;
    }

    .step-row:not(:last-child) .step-spine::after {
      content: '';
      position: absolute;
      top: 40px;
      left: 50%;
      transform: translateX(-50%);
      width: 2px;
      height: calc(100% - 40px);
      background: linear-gradient(to bottom, color-mix(in srgb, var(--pc) 30%, transparent) 60%, transparent);
    }

    .step-spine {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }

    .step-num {
      width: 38px;
      height: 38px;
      background: var(--pc);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: 'Sora', sans-serif;
      font-size: 0.9rem;
      font-weight: 800;
      box-shadow: 0 4px 12px color-mix(in srgb, var(--pc) 35%, transparent);
      z-index: 1;
      flex-shrink: 0;
    }

    .step-content {
      padding: 2px 0 2.5rem 18px;
    }

    .step-with-img {
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 16px;
      align-items: center;
      margin-bottom: 0.75rem;
    }

    .step-img-col {
      display: flex;
      flex-direction: column;
      gap: 6px;
      max-width: 220px;
      /* ← limite la largeur */
      justify-self: center;
      /* ← pousse vers le centre */
    }

    .step-img-real {
      width: 100%;
      height: auto;
      /* ← s'adapte au ratio naturel de l'image */
      object-fit: cover;
      border-radius: var(--rsm);
      display: block;
    }

    .step-caption-txt {
      font-size: 0.75rem;
      font-style: italic;
      color: var(--muted);
      line-height: 1.5;
    }

    .step-content h4 {
      font-family: 'Sora', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
      line-height: 1.3;
    }

    .step-content p {
      font-size: 0.91rem;
      color: var(--text);
      line-height: 1.72;
      margin-bottom: 0.7rem;
    }

    .step-content p:last-child {
      margin-bottom: 0;
    }

    .step-content strong {
      font-weight: 600;
    }

    .step-content ul {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
      margin: 0.6rem 0;
    }

    .step-content ul li {
      font-size: 0.88rem;
      padding-left: 18px;
      position: relative;
      line-height: 1.55;
    }

    .step-content ul li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--coral);
      font-weight: 700;
    }

    /* ── MATÉRIAUX INLINE ── */
    .mat-inline {
      background: color-mix(in srgb, var(--pc) 8%, white);
      border-radius: var(--rsm);
      padding: 1rem 1.25rem;
      margin: 0.9rem 0;
      border: 1px solid color-mix(in srgb, var(--pc) 22%, transparent);
    }

    .mat-inline-label {
      font-family: 'Sora', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--pc);
      margin-bottom: 0.6rem;
    }

    .mat-links {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .mat-link-row {
      display: flex;
      align-items: center;
      gap: 10px;
      background: white;
      border-radius: 8px;
      padding: 9px 12px;
      border: 1px solid color-mix(in srgb, var(--pc) 14%, transparent);
      transition: border-color .2s;
    }

    .mat-link-row:hover {
      border-color: color-mix(in srgb, var(--pc) 35%, transparent);
    }

    .mat-link-name {
      flex: 1;
      font-size: 0.86rem;
      font-weight: 600;
      color: var(--text);
    }

    .mat-link-desc {
      font-size: 0.78rem;
      color: var(--muted);
    }

    .mat-link-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--pc);
      color: white;
      text-decoration: none;
      padding: 6px 13px;
      border-radius: 8px;
      font-size: 0.78rem;
      font-weight: 600;
      white-space: nowrap;
      flex-shrink: 0;
      transition: opacity .2s;
    }

    .mat-link-btn::before {
      content: '🛒';
      font-size: 0.82rem;
    }

    .mat-link-btn:hover {
      opacity: 0.82;
    }

    .mat-option-row {
      display: flex;
      align-items: center;
      gap: 10px;
      background: white;
      border-radius: 8px;
      padding: 9px 12px;
      border: 1px solid color-mix(in srgb, var(--pc) 14%, transparent);
      transition: border-color .2s;
    }

    .mat-option-row:hover {
      border-color: color-mix(in srgb, var(--pc) 35%, transparent);
    }

    .mat-option-info {
      flex: 1;
    }

    .mat-option-lbl {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text);
    }

    .mat-option-dim {
      font-size: 0.75rem;
      color: var(--muted);
      font-style: italic;
    }

    /* ── STEP IMAGE ── */

    .step-img-col {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .step-img-real {
      width: 100%;
      height: auto;
      object-fit: cover;
      border-radius: var(--rsm);
      display: block;
    }

    .step-caption-txt {
      font-size: 0.75rem;
      font-style: italic;
      color: var(--muted);
      line-height: 1.5;
    }

    /* responsive */
    @media(max-width: 600px) {
      .step-with-img {
        grid-template-columns: 1fr;
      }

      .step-img-real {
        height: auto;
      }
    }

    /* ── SPECIAL CASE ── */
    .special-case {
      background: var(--light);
      border-radius: var(--rsm);
      padding: 1rem 1.25rem;
      margin: 0.9rem 0;
      border: 1.5px dashed color-mix(in srgb, var(--pc) 30%, transparent);
      font-size: 0.87rem;
      line-height: 1.65;
    }

    .special-case strong {
      font-family: 'Sora', sans-serif;
      font-size: 0.8rem;
      color: var(--pc);
      display: block;
      margin-bottom: 4px;
    }

    /* ── MAT TABLE ── */
    .mat-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 5px;
    }

    .mat-table th {
      font-family: 'Sora', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--muted);
      padding: 5px 12px;
      text-align: left;
    }

    .mat-table td {
      padding: 10px 12px;
      font-size: 0.86rem;
      background: white;
    }

    .mat-table tr td:first-child {
      border-radius: var(--rsm) 0 0 var(--rsm);
    }

    .mat-table tr td:last-child {
      border-radius: 0 var(--rsm) var(--rsm) 0;
    }

    .mat-tag {
      font-size: 0.71rem;
      font-weight: 600;
      border-radius: 8px;
      padding: 2px 9px;
      white-space: nowrap;
    }

    .mat-tag.a {
      background: var(--success-bg);
      color: var(--success);
    }

    .mat-tag.b {
      background: var(--warn-bg);
      color: var(--warn);
    }

    /* ── TIPS ── */
    .tips-wrap {
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin: 1.1rem 0;
    }

    .tips-head {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7px;
    }

    .tips-col-lbl {
      font-family: 'Sora', sans-serif;
      font-size: 0.74rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 6px 12px;
      border-radius: 8px;
      text-align: center;
    }

    .tips-col-lbl.g {
      background: var(--success-bg);
      color: var(--success);
    }

    .tips-col-lbl.b {
      background: var(--danger-bg);
      color: var(--danger);
    }

    .tips-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 7px;
    }

    .tip-c {
      border-radius: var(--rsm);
      padding: 11px 13px;
      font-size: 0.86rem;
      line-height: 1.5;
      display: flex;
      align-items: flex-start;
      gap: 8px;
    }

    .tip-c.g {
      background: var(--success-bg);
      border: 1.5px solid var(--success-bd);
      color: var(--success);
    }

    .tip-c.b {
      background: var(--danger-bg);
      border: 1.5px solid var(--danger-bd);
      color: var(--danger);
    }

    /* ── DECISION FLOW ── */
    .decision-flow {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 6px;
      padding: 1.1rem;
      background: var(--light);
      border-radius: var(--rsm);
      margin: 1.1rem 0;
    }

    .df-step {
      background: white;
      border-radius: 8px;
      padding: 8px 14px;
      text-align: center;
      border: 1.5px solid var(--violet-m);
      font-size: 0.79rem;
      line-height: 1.35;
      flex: 1;
      min-width: 120px;
    }

    .df-step strong {
      display: block;
      font-family: 'Sora', sans-serif;
      font-size: 0.77rem;
      color: var(--violet);
      margin-bottom: 2px;
    }

    .df-arrow {
      color: var(--muted);
      font-size: 0.85rem;
      flex-shrink: 0;
    }

    /* ── COVERAGE TABLE ── */
    .coverage-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0 5px;
    }

    .coverage-table th {
      font-family: 'Sora', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      padding: 5px 14px;
      text-align: left;
    }

    .coverage-table td {
      padding: 11px 14px;
      font-size: 0.87rem;
      background: white;
    }

    .coverage-table tr td:first-child {
      border-radius: var(--rsm) 0 0 var(--rsm);
    }

    .coverage-table tr td:last-child {
      border-radius: 0 var(--rsm) var(--rsm) 0;
    }

    .cov-green td:first-child {
      border-left: 4px solid #2ecc71;
    }

    .cov-orange td:first-child {
      border-left: 4px solid #f39c12;
    }

    .cov-red td:first-child {
      border-left: 4px solid var(--coral);
    }

    .cov-dark td:first-child {
      border-left: 4px solid var(--violet);
    }

    .cov-badge {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      border-radius: 12px;
      padding: 2px 10px;
      white-space: nowrap;
    }

    .cov-badge.g {
      background: rgba(46, 204, 113, 0.12);
      color: #1a7a43;
    }

    .cov-badge.o {
      background: rgba(243, 156, 18, 0.12);
      color: #a06800;
    }

    .cov-badge.r {
      background: var(--coral-l);
      color: #c0392b;
    }

    .cov-badge.p {
      background: var(--violet-l);
      color: var(--violet);
    }

    /* ── TIMELINE SINISTRE ── */
    .sinistre-steps {
      display: flex;
      flex-direction: column;
      gap: 8px;
      margin: 1.1rem 0;
    }

    .sinistre-step {
      display: grid;
      grid-template-columns: 48px 1fr;
      gap: 0;
      background: white;
      border-radius: var(--rsm);
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      overflow: hidden;
      transition: border-color .2s, box-shadow .2s;
    }

    .sinistre-step:hover {
      border-color: color-mix(in srgb, var(--p3) 30%, transparent);
      box-shadow: 0 3px 12px rgba(0, 0, 0, 0.06);
    }

    .sinistre-step-num {
      background: color-mix(in srgb, var(--p3) 12%, white);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 1rem 0;
      border-right: 1px solid color-mix(in srgb, var(--p3) 18%, transparent);
      gap: 6px;
    }

    .sinistre-step-icon {
      font-size: 1.1rem;
      line-height: 1;
    }

    .sinistre-step-n {
      font-family: 'Sora', sans-serif;
      font-size: 0.65rem;
      font-weight: 800;
      color: var(--p3);
      letter-spacing: 0.03em;
    }

    .sinistre-step-body {
      padding: 0.9rem 1.1rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .sinistre-step-when {
      font-family: 'Sora', sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: var(--p3);
      margin-bottom: 3px;
    }

    .sinistre-step-action {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 3px;
      line-height: 1.3;
    }

    .sinistre-step-why {
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.5;
    }

    /* connector between steps */
    .sinistre-connector {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      padding-left: 23px;
      height: 10px;
    }

    .sinistre-connector::after {
      content: '';
      width: 2px;
      height: 10px;
      background: color-mix(in srgb, var(--p3) 25%, transparent);
      border-radius: 1px;
    }

    /* ── TIMELINE (old, kept for other uses if any) ── */
    .timeline {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .tl-item {
      display: grid;
      grid-template-columns: 42px 1fr;
      position: relative;
    }

    .tl-item:not(:last-child) .tl-spine::after {
      content: '';
      position: absolute;
      top: 34px;
      left: 50%;
      transform: translateX(-50%);
      width: 2px;
      height: calc(100% - 34px);
      background: linear-gradient(to bottom, var(--violet-m), transparent);
    }

    .tl-spine {
      display: flex;
      flex-direction: column;
      align-items: center;
      position: relative;
    }

    .tl-dot {
      width: 30px;
      height: 30px;
      background: var(--violet);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-size: 0.78rem;
      z-index: 1;
      flex-shrink: 0;
    }

    .tl-body {
      padding: 2px 0 1.75rem 14px;
    }

    .tl-when {
      font-family: 'Sora', sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--violet);
      margin-bottom: 2px;
    }

    .tl-action {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 2px;
    }

    .tl-why {
      font-size: 0.81rem;
      color: var(--muted);
      line-height: 1.55;
    }

    /* ── PROCEDURE ── */
    .procedure {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin: 1.1rem 0;
    }

    .proc-item {
      display: flex;
      align-items: center;
      gap: 12px;
      background: white;
      border-radius: var(--rsm);
      padding: 11px 16px;
      border-left: 3px solid rgb(106, 158, 127);
      font-size: 0.88rem;
    }

    .proc-n {
      width: 24px;
      height: 24px;
      background: rgb(106, 158, 127);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-family: 'Sora', sans-serif;
      font-size: 0.73rem;
      font-weight: 800;
      flex-shrink: 0;
    }

    /* ── COST GRID ── */
    .cost-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin: 1.1rem 0;
    }

    .cost-card {
      background: white;
      border-radius: var(--rsm);
      padding: 1rem;
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      text-align: center;
    }

    .cost-icon {
      font-size: 1.4rem;
      margin-bottom: 5px;
    }

    .cost-lbl {
      font-family: 'Sora', sans-serif;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--text);
    }

    .cost-val {
      font-size: 0.78rem;
      color: var(--muted);
      margin-top: 4px;
      line-height: 1.4;
    }

    /* ── FAQ ── */
    .faq-list {
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .faq-item {
      border: 1.5px solid rgba(0, 0, 0, 0.07);
      border-radius: var(--rsm);
      overflow: hidden;
    }

    .faq-q {
      width: 100%;
      background: none;
      border: none;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px 18px;
      font-family: 'Sora', sans-serif;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
      cursor: pointer;
      text-align: left;
      transition: background .2s;
    }

    .faq-q:hover {
      background: var(--violet-l);
    }

    .faq-q.open {
      background: var(--violet);
      color: white;
    }

    .faq-chev {
      font-size: 0.65rem;
      flex-shrink: 0;
      transition: transform .25s;
    }

    .faq-q.open .faq-chev {
      transform: rotate(180deg);
    }

    .faq-a {
      display: none;
      padding: 14px 18px;
      font-size: 0.9rem;
      color: var(--muted);
      background: rgba(130, 105, 164, 0.04);
      border-top: 1px solid rgba(130, 105, 164, 0.1);
      line-height: 1.7;
    }

    .faq-a.open {
      display: block;
    }

    /* ── SOURCES ── */
    .sources {
      background: var(--light);
      border-radius: var(--rsm);
      padding: 1.25rem 1.5rem;
      margin: 1.5rem 0 0;
      font-size: 0.8rem;
      color: var(--muted);
      line-height: 1.7;
    }

    .sources strong {
      font-family: 'Sora', sans-serif;
      font-size: 0.8rem;
      color: var(--text);
      display: block;
      margin-bottom: 6px;
    }

    .sources ul {
      list-style: none;
      padding: 0;
    }

    .sources li {
      padding-left: 14px;
      position: relative;
    }

    .sources li::before {
      content: '·';
      position: absolute;
      left: 0;
    }

    /* ── AFFILIATION ── */
    .affil {
      background: var(--violet-l);
      border-radius: var(--rsm);
      padding: 11px 16px;
      margin: 1.25rem 0 0;
      display: flex;
      align-items: flex-start;
      gap: 9px;
      font-size: 0.79rem;
      color: var(--muted);
      line-height: 1.5;
      border-left: 3px solid var(--violet);
    }

    /* ── TRANSITION PART ── */
    .part-transition {
      text-align: center;
      padding: 0.5rem 0 1.75rem;
      font-family: 'Lora', serif;
      font-size: 0.92rem;
      font-style: italic;
      color: var(--muted);
    }

    .section-gap {
      margin-bottom: 2.25rem;
    }

    /* ════════════════════════════════════
   RESPONSIVE
════════════════════════════════════ */

    /* Tablette */
    @media(max-width:780px) {
      .hero {
        padding: 1.75rem 1.5rem 0;
      }

      .hero-bottom {
        margin: 0 -1.5rem;
        padding: 1.25rem 1.5rem 0;
      }

      .hero-bottom-grid {
        grid-template-columns: 1fr;
      }

      .hb-col:not(:last-child) {
        border-bottom: 1px solid var(--violet-m);
      }

      .part-header {
        padding: 1.5rem;
        flex-direction: column;
        gap: 0.5rem;
      }

      .part-num {
        font-size: 1.8rem;
      }

      .prose {
        padding: 1.5rem;
      }

      .en-bref {
        padding: 1.5rem;
      }

      .carton-grid {
        grid-template-columns: 1fr 1fr;
      }

      .diag-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .cost-grid {
        grid-template-columns: 1fr;
      }

      .decision-flow {
        flex-direction: column;
        align-items: stretch;
      }

      .df-arrow {
        text-align: center;
      }

      .tips-pair {
        grid-template-columns: 1fr;
      }

      .tips-head {
        grid-template-columns: 1fr;
      }

      .tips-col-lbl.b {
        display: none;
      }

      .formula-box {
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
      }

      .formula-vs {
        align-self: flex-start;
      }

      .mat-link-row {
        flex-wrap: wrap;
        gap: 8px;
      }

      .mat-link-btn {
        width: 100%;
        justify-content: center;
      }

      .mat-option-row {
        flex-wrap: wrap;
      }

      .mat-option-row .mat-link-btn {
        width: 100%;
        justify-content: center;
        margin-top: 4px;
      }

      /* overflow tables */
      .coverage-table,
      .mat-table {
        display: block;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
      }
    }

    /* Mobile */
    @media(max-width:520px) {
      .page {
        padding: 0 0 2rem;
      }

      .en-bref,
      .part-header,
      .prose {
        margin-left: 8px;
        margin-right: 8px;
      }

      .hero {
        margin-left: 0;
        margin-right: 0;
        border-radius: 0;
      }

      .bc {
        padding: 10px 12px;
      }

      .hero h1 {
        font-size: 1.35rem;
      }

      .hero-lead {
        font-size: 0.92rem;
      }

      .carton-grid {
        grid-template-columns: 1fr;
      }

      .diag-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 6px;
      }

      .step-row {
        grid-template-columns: 40px 1fr;
      }

      .step-num {
        width: 32px;
        height: 32px;
        font-size: 0.82rem;
      }

      .step-content {
        padding: 2px 0 2rem 12px;
      }

      .step-img-ph,
      .step-img-real {
        width: 100%;
        height: auto;
      }

      .layers-diagram {
        max-width: 100%;
      }

      .tl-item {
        grid-template-columns: 36px 1fr;
      }

      .tl-dot {
        width: 26px;
        height: 26px;
        font-size: 0.7rem;
      }

      .sn {
