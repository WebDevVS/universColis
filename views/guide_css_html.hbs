.bottle-format-icon { width:100%; height:58px; margin-bottom:6px; display:flex; align-items:center; justify-content:center; }
.bottle-format-icon img { max-width:100%; max-height:100%; object-fit:contain; border-radius:6px; }
.bottle-format-name { font-family:'Sora',sans-serif; font-size:0.78rem; font-weight:700; color:var(--text); margin-bottom:4px; }
.bottle-format-specs { font-size:0.71rem; color:var(--muted); line-height:1.5; }
.bottle-format-card.special { border-color:var(--p1-m); background:var(--p1-l); }
.bottle-format-card.special .bottle-format-name{color:var(--p1);}

/* ── CHECKLIST (réutilisé) ── */
.checklist{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.check-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.check-ico{font-size:1.1rem;flex-shrink:0;}

/* ── STEPS ── */
.steps-list{display:flex;flex-direction:column;}
.step-row{display:grid;grid-template-columns:50px 1fr;position:relative;}
.step-row:not(:last-child) .step-spine::after { content:''; position:absolute; top:40px; left:50%; transform:translateX(-50%); width:2px; height:calc(100% - 40px); background:linear-gradient(to bottom,color-mix(in srgb,var(--pc) 30%,transparent) 60%,transparent); }
.step-spine{display:flex;flex-direction:column;align-items:center;position:relative;}
.step-num { width:38px; height:38px; background:var(--pc); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:800; box-shadow:0 4px 12px color-mix(in srgb,var(--pc) 35%,transparent); z-index:1; flex-shrink:0; }
.step-content{padding:2px 0 2.5rem 18px;}
.step-content h4{font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:0.5rem;line-height:1.3;}
.step-content p{font-size:0.91rem;color:var(--text);line-height:1.72;margin-bottom:0.7rem;}
.step-content p:last-child{margin-bottom:0;}
.step-content strong{font-weight:600;}
.step-content ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;margin:0.6rem 0;}
.step-content ul li{font-size:0.88rem;padding-left:18px;position:relative;line-height:1.55;}
.step-content ul li::before{content:'→';position:absolute;left:0;color:var(--coral);font-weight:700;}

/* ── STEP WITH IMG (réutilisé) ── */
.step-with-img { display:grid; grid-template-columns:1fr 200px; gap:16px; align-items:start; margin-bottom:0.75rem; }
.step-img-col{display:flex;flex-direction:column;gap:6px;justify-self:center;max-width:200px;}
.step-img-ph { width:100%; aspect-ratio:4/3; background:var(--light); border-radius:var(--rsm); display:flex; align-items:center; justify-content:center; font-size:0.75rem; color:var(--muted); text-align:center; padding:12px; border:1.5px dashed rgba(0,0,0,0.1); }
.step-img-real { width:100%; aspect-ratio:4/3; object-fit:cover; object-position:center; display:block; background:var(--light); border-radius:var(--rsm); }
.step-caption-txt{font-size:0.75rem;font-style:italic;color:var(--muted);line-height:1.5;}

/* ── COUPE COLIS BOUTEILLE ── */
.colis-layers { display:flex; flex-direction:column; gap:3px; margin:1.1rem 0; }
.colis-layer { border-radius:8px; padding:9px 14px; font-size:0.82rem; font-weight:500; display:flex; align-items:center; gap:10px; }
.cl1{background:#2a3a4a;color:#c8d8e8;}
.cl2{background:#3a4a5a;color:#c8d8e8;}
.cl3{background:#4a5a6a;color:#dde6ed;}
.cl4{background:#5a6a7a;color:#dde6ed;}
.cl5{background:linear-gradient(90deg,var(--p2),color-mix(in srgb,var(--p2) 70%,white));color:white;}
.cl-arrow{text-align:center;color:var(--muted);font-size:0.75rem;padding:1px 0;}
.cl-sub{font-size:0.72rem;font-weight:400;opacity:0.8;margin-left:4px;}

/* ── COMPARATIF 3 COLONNES ── */
.compare-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin:1.1rem 0; }
.compare-col { background:white; border-radius:var(--rsm); overflow:hidden; border:1.5px solid rgba(0,0,0,0.07); }
.compare-col.bad{border-color:var(--danger-bd);}
.compare-col.mid{border-color:var(--warn-bd);}
.compare-col.good{border-color:var(--success-bd);}
.compare-col-ph { width:100%; height:90px; background:var(--light); display:flex; align-items:center; justify-content:center; font-size:0.72rem; color:var(--muted); text-align:center; padding:10px; }
.compare-col-ph-link { display:block; }
.compare-col-ph-img { width:100%; height:140px; object-fit:cover; object-position:center; display:block; background:var(--light); }
.compare-col-body { padding:0.75rem; }
.compare-col-label { font-family:'Sora',sans-serif; font-size:0.8rem; font-weight:700; margin-bottom:3px; }
.compare-col.bad .compare-col-label{color:var(--danger);}
.compare-col.mid .compare-col-label{color:var(--warn);}
.compare-col.good .compare-col-label{color:var(--success);}
.compare-col-note{font-size:0.72rem;color:var(--muted);line-height:1.4;}

/* ── COMPARATIF 2 COLONNES (avec photo portrait) ── */
.compare-2 { display:grid; grid-template-columns:repeat(2,1fr); gap:8px; margin:1.1rem 0; }
.compare-col-img { width:100%; height:280px; object-fit:contain; object-position:center; display:block; background:var(--light); }

/* ── TIPS (réutilisé) ── */
.tips-wrap{display:flex;flex-direction:column;gap:7px;margin:1.1rem 0;}
.tips-head{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tips-col-lbl{font-family:'Sora',sans-serif;font-size:0.74rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:6px 12px;border-radius:8px;text-align:center;}
.tips-col-lbl.g{background:var(--success-bg);color:var(--success);}
.tips-col-lbl.b{background:var(--danger-bg);color:var(--danger);}
.tips-pair{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tip-c{border-radius:var(--rsm);padding:11px 13px;font-size:0.86rem;line-height:1.5;display:flex;align-items:flex-start;gap:8px;}
.tip-c.g{background:var(--success-bg);border:1.5px solid var(--success-bd);color:var(--success);}
.tip-c.b{background:var(--danger-bg);border:1.5px solid var(--danger-bd);color:var(--danger);}

/* ── MAT INLINE (réutilisé) ── */
.mat-inline{background:color-mix(in srgb,var(--pc,var(--violet)) 8%,white);border-radius:var(--rsm);padding:1rem 1.25rem;margin:0.9rem 0;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 22%,transparent);}
.mat-inline-label{font-family:'Sora',sans-serif;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--pc,var(--violet));margin-bottom:0.6rem;}
.mat-links{display:flex;flex-direction:column;gap:6px;}
.mat-link-row{display:flex;align-items:center;gap:10px;background:white;border-radius:8px;padding:9px 12px;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 14%,transparent);transition:border-color .2s;flex-wrap:wrap;}
.mat-link-row:hover{border-color:color-mix(in srgb,var(--pc,var(--violet)) 35%,transparent);}
.mat-link-name{flex:1;font-size:0.86rem;font-weight:600;color:var(--text);min-width:120px;}
.mat-link-desc{font-size:0.78rem;color:var(--muted);width:100%;}
.mat-link-btn{display:inline-flex;align-items:center;gap:6px;background:var(--pc,var(--violet));color:white;text-decoration:none;padding:6px 13px;border-radius:8px;font-size:0.78rem;font-weight:600;white-space:nowrap;flex-shrink:0;transition:opacity .2s;}
.mat-link-btn::before{content:'🛒';font-size:0.82rem;}
.mat-link-btn:hover{opacity:0.82;}

/* ── TRANSPORTEURS GRID ── */
.transport-grid{display:flex;flex-direction:column;gap:8px;margin:1.1rem 0;}
.transport-card{background:white;border-radius:var(--rsm);padding:1rem 1.25rem;border:1.5px solid rgba(0,0,0,0.07);display:flex;align-items:flex-start;gap:12px;transition:box-shadow .2s;}
.transport-card:hover{box-shadow:0 3px 12px rgba(0,0,0,0.07);}
.transport-name{font-family:'Sora',sans-serif;font-size:0.88rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.transport-usage{font-size:0.82rem;color:var(--muted);margin-bottom:5px;line-height:1.45;}
.transport-check{font-size:0.78rem;color:var(--pc,var(--violet));line-height:1.4;}
.transport-badge{display:inline-block;font-size:0.7rem;font-weight:700;border-radius:8px;padding:2px 9px;white-space:nowrap;margin-bottom:4px;}
.tb-standard{background:var(--p1-l);color:var(--p1);}
.tb-express{background:var(--p2-l);color:var(--p2);}
.tb-pro{background:var(--p3-l);color:var(--p3);}
.tb-intl{background:var(--violet-l);color:var(--violet);}

/* ── DESTINATION SCALE ── */
.dest-scale{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin:1.1rem 0;}
.dest-col{border-radius:var(--rsm);overflow:hidden;border:1.5px solid rgba(0,0,0,0.07);}
.dest-col-header{padding:0.65rem 0.75rem;text-align:center;}
.dest-col:nth-child(1) .dest-col-header{background:color-mix(in srgb,var(--success) 12%,white);}
.dest-col:nth-child(2) .dest-col-header{background:color-mix(in srgb,var(--p2) 12%,white);}
.dest-col:nth-child(3) .dest-col-header{background:color-mix(in srgb,var(--warn) 12%,white);}
.dest-col:nth-child(4) .dest-col-header{background:color-mix(in srgb,var(--danger) 12%,white);}
.dest-col-name{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;}
.dest-col:nth-child(1) .dest-col-name{color:var(--success);}
.dest-col:nth-child(2) .dest-col-name{color:var(--p2);}
.dest-col:nth-child(3) .dest-col-name{color:var(--warn);}
.dest-col:nth-child(4) .dest-col-name{color:var(--danger);}
.dest-col-body{background:white;padding:0.65rem 0.75rem;}
.dest-col-items{display:flex;flex-direction:column;gap:3px;}
.dest-col-item{font-size:0.72rem;color:var(--muted);padding-left:12px;position:relative;line-height:1.4;}
.dest-col-item::before{content:'·';position:absolute;left:0;}

/* ── DESCRIPTION DOUANE ── */
.customs-compare{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:1.1rem 0;}
.customs-col{background:white;border-radius:var(--rsm);overflow:hidden;border:1.5px solid rgba(0,0,0,0.07);}
.customs-col.bad{border-color:var(--danger-bd);}
.customs-col.good{border-color:var(--success-bd);}
.customs-col-header{padding:0.65rem 1rem;font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;}
.customs-col.bad .customs-col-header{background:var(--danger-bg);color:var(--danger);}
.customs-col.good .customs-col-header{background:var(--success-bg);color:var(--success);}
.customs-col-body{padding:0.75rem 1rem;}
.customs-item{font-size:0.82rem;padding:4px 0;border-bottom:1px solid rgba(0,0,0,0.04);color:var(--text);}
.customs-item:last-child{border-bottom:none;}
.customs-col.bad .customs-item{color:var(--danger);}
.customs-col.good .customs-item{color:var(--success);}

/* ── PLATEFORMES ── */
.platform-list{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.platform-row{background:white;border-radius:var(--rsm);padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.07);display:flex;align-items:center;gap:12px;transition:box-shadow .2s;}
.platform-row:hover{box-shadow:0 3px 10px rgba(0,0,0,0.07);}
.platform-name{font-family:'Sora',sans-serif;font-size:0.85rem;font-weight:700;color:var(--text);min-width:130px;flex-shrink:0;}
.platform-interest{flex:1;font-size:0.82rem;color:var(--muted);}
.platform-badge{display:inline-block;font-size:0.7rem;font-weight:700;border-radius:8px;padding:2px 9px;white-space:nowrap;flex-shrink:0;}
.pb-ok{background:var(--success-bg);color:var(--success);}
.pb-warn{background:var(--warn-bg);color:var(--warn);}
.pb-no{background:var(--danger-bg);color:var(--danger);}

/* ── CHAIN SCHEMA ── */
.chain-flow{display:flex;align-items:center;flex-wrap:wrap;gap:6px;padding:1.1rem;background:var(--light);border-radius:var(--rsm);margin:1.1rem 0;}
.chain-step{background:white;border-radius:8px;padding:8px 14px;text-align:center;border:1.5px solid var(--violet-m);font-size:0.79rem;line-height:1.35;flex:1;min-width:110px;}
.chain-step strong{display:block;font-family:'Sora',sans-serif;font-size:0.77rem;color:var(--pc,var(--violet));margin-bottom:2px;}
.chain-arrow{color:var(--muted);font-size:0.85rem;flex-shrink:0;}

/* ── FORMULA BOX (réutilisé) ── */
.formula-box{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.1rem 0;display:flex;align-items:center;flex-wrap:wrap;gap:10px;}
.formula-item{text-align:center;}
.formula-val{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;line-height:1;}
.formula-lbl{font-size:0.72rem;color:var(--muted);margin-top:3px;}
.formula-op{font-family:'Sora',sans-serif;font-size:1.2rem;color:var(--muted);align-self:center;}
.f-violet{color:var(--violet);}
.f-p2{color:var(--p2);}

/* ── PROCEDURE (réutilisé) ── */
.procedure{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.proc-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.proc-n{width:24px;height:24px;background:var(--pc,var(--violet));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-family:'Sora',sans-serif;font-size:0.73rem;font-weight:800;flex-shrink:0;}

/* ── FAQ ── */
.faq-list{display:flex;flex-direction:column;gap:7px;}
.faq-item{border:1.5px solid rgba(0,0,0,0.07);border-radius:var(--rsm);overflow:hidden;}
.faq-q{width:100%;background:none;border:none;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;color:var(--text);cursor:pointer;text-align:left;transition:background .2s;}
.faq-q:hover{background:var(--violet-l);}
.faq-q.open{background:var(--violet);color:white;}
.faq-chev{font-size:0.65rem;flex-shrink:0;transition:transform .25s;}
.faq-q.open .faq-chev{transform:rotate(180deg);}
.faq-a{display:none;padding:14px 18px;font-size:0.9rem;color:var(--muted);background:rgba(130,105,164,0.04);border-top:1px solid rgba(130,105,164,0.1);line-height:1.7;}
.faq-a.open{display:block;}

/* ── SOURCES / AFFIL / MAJ ── */
.sources{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.5rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.7;}
.sources strong{font-family:'Sora',sans-serif;font-size:0.8rem;color:var(--text);display:block;margin-bottom:6px;}
.sources ul{list-style:none;padding:0;}
.sources li{padding-left:14px;position:relative;}
.sources li::before{content:'·';position:absolute;left:0;}
.sources a{color:var(--violet);text-decoration:none;}
.sources a:hover{text-decoration:underline;}
.affil{background:var(--violet-l);border-radius:var(--rsm);padding:11px 16px;margin:1.25rem 0 0;display:flex;align-items:flex-start;gap:9px;font-size:0.79rem;color:var(--muted);line-height:1.5;border-left:3px solid var(--violet);}
.maj{background:var(--light);border-radius:var(--rsm);padding:0.9rem 1.25rem;margin:1.25rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.6;border-left:3px solid rgba(0,0,0,0.1);}
.maj strong{color:var(--text);font-family:'Sora',sans-serif;font-size:0.8rem;}

/* ── SPECIAL CASE ── */
.special-case{background:var(--light);border-radius:var(--rsm);padding:1rem 1.25rem;margin:0.9rem 0;border:1.5px dashed color-mix(in srgb,var(--pc,var(--violet)) 30%,transparent);font-size:0.87rem;line-height:1.65;}
.special-case strong{font-family:'Sora',sans-serif;font-size:0.8rem;color:var(--pc,var(--violet));display:block;margin-bottom:4px;}

/* ── RESPONSIVE ── */
@media(max-width:780px){
  .hero{padding:1.75rem 1.5rem 0;}
  .hero-bottom{margin:0 -1.5rem;padding:1.25rem 1.5rem 0;}
  .hero-bottom-grid{grid-template-columns:1fr;}
  .hb-col:not(:last-child){border-bottom:1px solid var(--violet-m);}
  .part-header{padding:1.5rem;flex-direction:column;gap:0.5rem;}
  .part-num{font-size:1.8rem;}
  .prose{padding:1.5rem;}
  .en-bref{padding:1.5rem;}
  .bottle-formats{grid-template-columns:repeat(3,1fr);}
  .compare-3{grid-template-columns:1fr;}
  .tips-pair,.tips-head{grid-template-columns:1fr;}
  .tips-col-lbl.b{display:none;}
  .step-with-img{grid-template-columns:1fr;}
  .dest-scale{grid-template-columns:repeat(2,1fr);}
  .customs-compare{grid-template-columns:1fr;}
  .chain-flow{flex-direction:column;align-items:stretch;}
  .formula-box{flex-direction:column;align-items:flex-start;gap:8px;}
  .data-table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
  .bottle-zones{grid-template-columns:1fr;}
  .bottle-silhouette{display:none;}
}
@media(max-width:520px){
  .page{padding:0 0 2rem;}
  .en-bref,.part-header,.prose{margin-left:8px;margin-right:8px;}
  .hero{margin-left:0;margin-right:0;}
  .bc{padding:10px 12px;}
  .hero h1{font-size:1.35rem;}
  .step-row{grid-template-columns:40px 1fr;}
  .step-num{width:32px;height:32px;font-size:0.82rem;}
  .step-content{padding:2px 0 2rem 12px;}
  .sn{padding:12px 14px;font-size:0.76rem;}
  .bottle-formats{grid-template-columns:repeat(2,1fr);}
  .dest-scale{grid-template-columns:1fr;}
  .platform-row{flex-wrap:wrap;}
}
@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important;}}
</style>
</head>
<body>

<!-- BREADCRUMB -->
<nav class="bc" aria-label="Fil d'Ariane">
  <a href="/">Accueil</a><span>›</span>
