.temp-col { flex:1; padding:1.25rem; text-align:center; display:flex; flex-direction:column; justify-content:center; }
.temp-col.outside{background:color-mix(in srgb,var(--p1) 10%,white);}
.temp-col.inside{background:color-mix(in srgb,var(--coral) 10%,white);}
.temp-divider { display:flex; align-items:center; padding:0 0.5rem; color:var(--coral); font-size:1.5rem; font-weight:700; }
.temp-val { font-family:'Sora',sans-serif; font-size:2rem; font-weight:800; line-height:1; }
.temp-col.outside .temp-val{color:var(--p1);}
.temp-col.inside .temp-val{color:var(--coral);}
.temp-lbl { font-size:0.78rem; color:var(--muted); margin-top:4px; line-height:1.4; }
.temp-caption { text-align:center; font-size:0.75rem; color:var(--muted); font-style:italic; padding:0.5rem 1rem 0.75rem; background:white; border-top:1px solid rgba(0,0,0,0.05); }

/* ── WAX TABLE ── */
.table-wrap { overflow-x:auto; margin:1.1rem 0; -webkit-overflow-scrolling:touch; border-radius:var(--rsm); }
.data-table { width:100%; border-collapse:separate; border-spacing:0 4px; min-width:420px; }
.data-table th { font-family:'Sora',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--muted); padding:5px 12px; text-align:left; }
.data-table td { padding:10px 12px; font-size:0.86rem; background:white; vertical-align:top; }
.data-table tr td:first-child{border-radius:var(--rsm) 0 0 var(--rsm);font-weight:600;}
.data-table tr td:last-child{border-radius:0 var(--rsm) var(--rsm) 0;color:var(--muted);font-size:0.82rem;}
.wax-badge{display:inline-block;font-size:0.71rem;font-weight:600;border-radius:8px;padding:2px 9px;white-space:nowrap;}
.wax-badge.low{background:var(--danger-bg);color:var(--danger);}
.wax-badge.med{background:var(--warn-bg);color:var(--warn);}
.wax-badge.ok{background:var(--success-bg);color:var(--success);}

/* ── FORMAT RISK GRID ── */
.format-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin:1.1rem 0; justify-items: center;}
.format-card { background:white; border-radius:var(--rsm); border:1.5px solid rgba(0,0,0,0.07); transition:box-shadow .2s; }
.format-card:hover{box-shadow:0 3px 12px rgba(0,0,0,0.07);}
.format-type{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.format-risk{font-size:0.76rem;color:var(--muted);margin-bottom:4px;line-height:1.4;}
.format-question{font-size:0.74rem;font-style:italic;color:var(--pc,var(--violet));line-height:1.4;}
.format-card {
  width: 280px; /* ou 100% pour du responsive */
  border: 1px solid #eee;
  border-radius: 12px;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.format-photo {
  width: 100%;
  height: 180px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.format-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 0; /* ou 8px si tu veux des coins arrondis sur la photo */
}

.format-card-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 100%;
}

/* ── 3 FONCTIONS ── */
.fonctions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:1.1rem 0;}
.fonction-card{border-radius:var(--rsm);padding:1rem;border:1.5px solid rgba(0,0,0,0.07);background:white;}
.fonction-num{font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:var(--pc,var(--violet));opacity:0.25;margin-bottom:4px;}
.fonction-title{font-family:'Sora',sans-serif;font-size:0.85rem;font-weight:700;color:var(--text);margin-bottom:4px;}
.fonction-items{font-size:0.78rem;color:var(--muted);line-height:1.6;}
.fonction-key{font-size:0.74rem;font-style:italic;color:var(--pc,var(--violet));margin-top:6px;border-top:1px solid rgba(0,0,0,0.05);padding-top:6px;}

/* ── MAT GRID ── */
.mat-needs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:1.1rem 0;}
.mat-need-card{background:white;border-radius:var(--rsm);padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.07);display:flex;align-items:flex-start;gap:10px;}
.mat-need-body{flex:1;}
.mat-need-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:2px;}
.mat-need-mat{font-size:0.78rem;color:var(--muted);line-height:1.45;}
.prio{display:inline-block;font-size:0.68rem;font-weight:700;border-radius:8px;padding:2px 9px;margin-bottom:4px;white-space:nowrap;}
.prio.ess{background:color-mix(in srgb,var(--pc,var(--violet)) 12%,transparent);color:var(--pc,var(--violet));}
.prio.opt{background:var(--light);color:var(--muted);}

/* ── STEPS ── */
.steps-list{display:flex;flex-direction:column;}
.step-row{display:grid;grid-template-columns:50px 1fr;position:relative;}
.step-row:not(:last-child) .step-spine::after { content:''; position:absolute; top:40px; left:50%; transform:translateX(-50%); width:2px; height:calc(100% - 40px); background:linear-gradient(to bottom,color-mix(in srgb,var(--pc) 30%,transparent) 60%,transparent); }
.step-spine{display:flex;flex-direction:column;align-items:center;position:relative;}
.step-num { width:38px; height:38px; background:var(--pc); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:800; box-shadow:0 4px 12px color-mix(in srgb,var(--pc) 35%,transparent); z-index:1; flex-shrink:0; }
.step-content{padding:2px 0 2.5rem 18px;}
.step-content h4{font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:0.5rem;line-height:1.3;}
.step-content p{font-size:0.91rem;color:var(--text);line-height:1.72;margin-bottom:0.7rem;}
.step-content p:last-child{margin-bottom:0;}
.step-content strong{font-weight:600;}
.step-content ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;margin:0.6rem 0;}
.step-content ul li{font-size:0.88rem;padding-left:18px;position:relative;line-height:1.55;}
.step-content ul li::before{content:'→';position:absolute;left:0;color:var(--coral);font-weight:700;}

/* ── MAT INLINE ── */
.mat-inline{background:color-mix(in srgb,var(--pc,var(--violet)) 8%,white);border-radius:var(--rsm);padding:1rem 1.25rem;margin:0.9rem 0;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 22%,transparent);}
.mat-inline-label{font-family:'Sora',sans-serif;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--pc,var(--violet));margin-bottom:0.6rem;}
.mat-links{display:flex;flex-direction:column;gap:6px;}
.mat-link-row{display:flex;align-items:center;gap:10px;background:white;border-radius:8px;padding:9px 12px;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 14%,transparent);transition:border-color .2s;flex-wrap:wrap;}
.mat-link-row:hover{border-color:color-mix(in srgb,var(--pc,var(--violet)) 35%,transparent);}
.mat-link-name{flex:1;font-size:0.86rem;font-weight:600;color:var(--text);min-width:120px;}
.mat-link-desc{font-size:0.78rem;color:var(--muted);width:100%;}
.mat-link-btn{display:inline-flex;align-items:center;gap:6px;background:var(--pc,var(--violet));color:white;text-decoration:none;padding:6px 13px;border-radius:8px;font-size:0.78rem;font-weight:600;white-space:nowrap;flex-shrink:0;transition:opacity .2s;}
.mat-link-btn::before{content:'🛒';font-size:0.82rem;}
.mat-link-btn:hover{opacity:0.82;}

/* ── CARTON COMPARE ── */
.carton-compare{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:1.1rem 0;}
.carton-c{border-radius:var(--rsm);overflow:hidden;border:2px solid transparent;text-align:center;background:white;}
.carton-c.bad-small{border-color:var(--danger-bd);}
.carton-c.bad-big{border-color:var(--warn-bd);}
.carton-c.good{border-color:var(--success-bd);}
.carton-c-ph{width:100%;height:90px;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--muted);text-align:center;padding:10px;}
.carton-c-body{padding:0.75rem 0.5rem;}
.carton-c-label{font-family:'Sora',sans-serif;font-size:0.8rem;font-weight:700;}
.carton-c.bad-small .carton-c-label{color:var(--danger);}
.carton-c.bad-big .carton-c-label{color:var(--warn);}
.carton-c.good .carton-c-label{color:var(--success);}
.carton-c-note{font-size:0.72rem;color:var(--muted);margin-top:3px;line-height:1.4;}

/* ── COFFRET COMPARE ── */
.coffret-compare{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:1.1rem 0;}
.coffret-side{border-radius:var(--rsm);overflow:hidden;border:1.5px solid rgba(0,0,0,0.07);background:white;}
.coffret-ph{width:100%;height:100px;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--muted);text-align:center;padding:10px;}
.coffret-body{padding:0.85rem;}
.coffret-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;margin-bottom:4px;}
.coffret-side.bad .coffret-label{color:var(--danger);}
.coffret-side.good .coffret-label{color:var(--success);}
.coffret-note{font-size:0.77rem;color:var(--muted);line-height:1.5;}

/* ── CHALEUR BONS RÉFLEXES ── */
.chaleur-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:1.1rem 0;}
.chaleur-card{border-radius:var(--rsm);padding:0.9rem 1rem;border:1.5px solid transparent;background:white;}
.chaleur-card.bon{border-color:var(--success-bd);}
.chaleur-card.mauvais{border-color:var(--danger-bd);}
.chaleur-card-label{font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;}
.chaleur-card.bon .chaleur-card-label{color:var(--success);}
.chaleur-card.mauvais .chaleur-card-label{color:var(--danger);}
.chaleur-items{display:flex;flex-direction:column;gap:4px;}
.chaleur-item{font-size:0.8rem;color:var(--text);padding-left:16px;position:relative;line-height:1.45;}
.chaleur-item::before{position:absolute;left:0;}
.chaleur-card.bon .chaleur-item::before{content:'✓';color:var(--success);}
.chaleur-card.mauvais .chaleur-item::before{content:'✗';color:var(--danger);}

/* ── PRO SPLIT ── */
.pro-split{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:1.1rem 0;}
.pro-col{background:white;border-radius:var(--rsm);padding:1rem;border:1.5px solid rgba(0,0,0,0.07);}
.pro-col-label{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;}
.pro-col.marche .pro-col-label{color:var(--p1);}
.pro-col.transport .pro-col-label{color:var(--p3);}
.pro-col ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;}
.pro-col ul li{font-size:0.82rem;color:var(--text);padding-left:16px;position:relative;line-height:1.5;}
.pro-col ul li::before{content:'—';position:absolute;left:0;color:var(--pc,var(--muted));font-weight:700;}
.pro-col.marche{--pc:var(--p1);}
.pro-col.transport{--pc:var(--p3);}

/* ── FORMULA BOX ── */
.formula-box{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.1rem 0;display:flex;align-items:center;flex-wrap:wrap;gap:10px;}
.formula-item{text-align:center;}
.formula-val{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;line-height:1;}
.formula-lbl{font-size:0.72rem;color:var(--muted);margin-top:3px;}
.formula-op{font-family:'Sora',sans-serif;font-size:1.2rem;color:var(--muted);align-self:center;}
.formula-vs{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-bd);border-radius:8px;padding:6px 14px;white-space:nowrap;align-self:center;}
.f-violet{color:var(--violet);}
.f-danger{color:var(--danger);}

/* ── PROCEDURE ── */
.procedure{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.proc-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.proc-n{width:24px;height:24px;background:var(--pc,var(--violet));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-family:'Sora',sans-serif;font-size:0.73rem;font-weight:800;flex-shrink:0;}

/* ── CHECKLIST ── */
.checklist{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.check-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.check-ico{font-size:1.1rem;flex-shrink:0;}

/* ── TIPS ── */
.tips-wrap{display:flex;flex-direction:column;gap:7px;margin:1.1rem 0;}
.tips-head{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tips-col-lbl{font-family:'Sora',sans-serif;font-size:0.74rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:6px 12px;border-radius:8px;text-align:center;}
.tips-col-lbl.g{background:var(--success-bg);color:var(--success);}
.tips-col-lbl.b{background:var(--danger-bg);color:var(--danger);}
.tips-pair{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tip-c{border-radius:var(--rsm);padding:11px 13px;font-size:0.86rem;line-height:1.5;display:flex;align-items:flex-start;gap:8px;}
.tip-c.g{background:var(--success-bg);border:1.5px solid var(--success-bd);color:var(--success);}
.tip-c.b{background:var(--danger-bg);border:1.5px solid var(--danger-bd);color:var(--danger);}

/* ── FAQ ── */
.faq-list{display:flex;flex-direction:column;gap:7px;}
.faq-item{border:1.5px solid rgba(0,0,0,0.07);border-radius:var(--rsm);overflow:hidden;}
.faq-q{width:100%;background:none;border:none;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;color:var(--text);cursor:pointer;text-align:left;transition:background .2s;}
.faq-q:hover{background:var(--violet-l);}
.faq-q.open{background:var(--violet);color:white;}
.faq-chev{font-size:0.65rem;flex-shrink:0;transition:transform .25s;}
.faq-q.open .faq-chev{transform:rotate(180deg);}
.faq-a{display:none;padding:14px 18px;font-size:0.9rem;color:var(--muted);background:rgba(130,105,164,0.04);border-top:1px solid rgba(130,105,164,0.1);line-height:1.7;}
.faq-a.open{display:block;}

/* ── SOURCES / AFFIL / MAJ ── */
.sources{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.5rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.7;}
.sources strong{font-family:'Sora',sans-serif;font-size:0.8rem;color:var(--text);display:block;margin-bottom:6px;}
.sources ul{list-style:none;padding:0;}
.sources li{padding-left:14px;position:relative;}
.sources li::before{content:'·';position:absolute;left:0;}
.sources a{color:var(--violet);text-decoration:none;}
.sources a:hover{text-decoration:underline;}
.affil{background:var(--violet-l);border-radius:var(--rsm);padding:11px 16px;margin:1.25rem 0 0;display:flex;align-items:flex-start;gap:9px;font-size:0.79rem;color:var(--muted);line-height:1.5;border-left:3px solid var(--violet);}
.maj{background:var(--light);border-radius:var(--rsm);padding:0.9rem 1.25rem;margin:1.25rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.6;border-left:3px solid rgba(0,0,0,0.1);}
.maj strong{color:var(--text);font-family:'Sora',sans-serif;font-size:0.8rem;}

/* ── RESPONSIVE ── */
@media(max-width:780px){
  .hero{padding:1.75rem 1.5rem 0;}
  .hero-bottom{margin:0 -1.5rem;padding:1.25rem 1.5rem 0;}
  .hero-bottom-grid{grid-template-columns:1fr;}
  .hb-col:not(:last-child){border-bottom:1px solid var(--violet-m);}
  .part-header{padding:1.5rem;flex-direction:column;gap:0.5rem;}
  .part-num{font-size:1.8rem;}
  .prose{padding:1.5rem;}
  .en-bref{padding:1.5rem;}
  .risk-grid,.format-grid,.fonctions-grid,.chaleur-grid,.pro-split,.coffret-compare{grid-template-columns:1fr;}
  .mat-needs-grid{grid-template-columns:1fr;}
  .tips-pair,.tips-head{grid-template-columns:1fr;}
  .tips-col-lbl.b{display:none;}
  .carton-compare{grid-template-columns:1fr;}
  .step-with-img{grid-template-columns:1fr;}
  .formula-box{flex-direction:column;align-items:flex-start;gap:8px;}
  .formula-vs{align-self:flex-start;}
  .data-table,.artisan-table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
}
@media(max-width:520px){
  .page{padding:0 0 2rem;}
  .en-bref,.part-header,.prose{margin-left:8px;margin-right:8px;}
  .hero{margin-left:0;margin-right:0;}
  .bc{padding:10px 12px;}
  .hero h1{font-size:1.35rem;}
  .step-row{grid-template-columns:40px 1fr;}
  .step-num{width:32px;height:32px;font-size:0.82rem;}
  .step-content{padding:2px 0 2rem 12px;}
  .sn{padding:12px 14px;font-size:0.76rem;}
  .en-bref-pills{gap:6px;}
  .eb-pill{font-size:0.78rem;padding:4px 11px;}
}
@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important;}}
</style>
</head>
<body>

<!-- BREADCRUMB -->
<nav class="bc" aria-label="Fil d'Ariane">
