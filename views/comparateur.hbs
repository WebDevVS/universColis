            <!-- Services à venir -->
            <div class="col-md-3">
                <div class="link-card coming-soon">
                    <div class="link-icon">
                        <i class="fa-solid fa-hourglass-half"></i>
                    </div>
                    <h4 class="link-title">Services à venir</h4>
                    <p class="link-description">De nouveaux services arrivent bientôt</p>
                    <span class="link-action">
                        Bientôt disponible <i class="fa-solid fa-clock ms-1"></i>
                    </span>
                </div>
            </div> --}}
        </div>

        <!-- Call-to-action principal -->
        <div class="text-center mt-5">
            <div class="main-cta">
                <h4 class="cta-title">Prêt à expédier votre colis ?</h4>
                <p class="cta-subtitle">Comparez les prix et trouvez la meilleure offre en quelques clics</p>
                <a href="/" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-rocket me-2"></i>Commencer maintenant
                </a>
            </div>
        </div>


    </div>
</section>