{{!-- ════════════════════════════════════════════
BREADCRUMB
════════════════════════════════════════════ --}}
<nav class="bc" aria-label="Fil d'Ariane">
  <a href="/">Accueil</a><span>›</span>
  <a href="/conseils">Conseils d'emballage</a><span>›</span>
  <span>{{article.brTitle}}</span>
</nav>

{{!-- ════════════════════════════════════════════
HERO
════════════════════════════════════════════ --}}
<div class="hero">
  <div class="hero-eyebrow">Guide complet</div>
  <h1>{{article.title}}</h1>
  <div class="hero-tricolor">
    <span></span><span></span><span></span>
  </div>
  <p class="hero-lead">{{article.heroIntro}}</p>
  <div class="hero-meta">
    {{#each article.heroPills}}
    <div class="hero-pill">{{this}}</div>
    {{/each}}
  </div>
  <div class="hero-bottom">
    <div class="hero-bottom-grid">
      {{#each article.parts}}
      <a href="#{{this.id}}" class="hb-col">
        <strong>Partie {{this.partNum}} — {{this.label}}</strong>
        {{this.heroSub}}
      </a>
      {{/each}}
    </div>
  </div>
</div>

{{!-- ════════════════════════════════════════════
STICKY NAV
════════════════════════════════════════════ --}}
<nav class="sticky-nav" aria-label="Navigation">
  <div class="snav-inner">
    {{#each article.parts}}
    <a href="#{{this.id}}" class="sn {{#if @first}}active{{/if}}" data-part="{{this.partNum}}">
      <span class="sn-dot"></span>{{this.label}}
    </a>
    {{/each}}
  </div>
</nav>

<div class="page">

  {{!-- ════════════════════════════════════════════
  EN BREF
  ════════════════════════════════════════════ --}}
  <div class="en-bref">
    <div class="en-bref-label">✦ En bref</div>
    <p class="en-bref-text">{{article.enBref.text}}</p>
    <div class="en-bref-pills">
      {{#each article.enBref.pills}}
      <span class="eb-pill">{{this}}</span>
      {{/each}}
    </div>
  </div>

  {{!-- ════════════════════════════════════════════
  PARTIES
  ════════════════════════════════════════════ --}}
  {{#each article.parts}}
  <div id="{{this.id}}" class="section-gap p{{this.partNum}}">

    {{!-- PART HEADER --}}
    <div class="part-header p{{this.partNum}}">
      <div class="part-num">{{this.partNum}}</div>
      <div>
        <div class="part-tag">{{this.label}}</div>
        <h2>{{this.title}}</h2>
        <p>{{this.intro}}</p>
      </div>
    </div>

    {{!-- SECTIONS --}}
    {{#each this.sections}}
    <div class="prose">

      {{!-- ── DISPATCH DES BLOCS ── --}}
      {{#each this.blocks}}

      {{!-- h3 --}}
      {{#if (eq this.type "h3")}}
      <h3>{{this.text}}</h3>

      {{!-- texte --}}
      {{else if (eq this.type "texte")}}
      <p>{{{this.text}}}</p>

      {{!-- info-box --}}
      {{else if (eq this.type "info-box")}}
      <div class="callout {{this.variant}}">
        <div class="callout-ico">{{this.icon}}</div>
        <div class="callout-body">
          <strong>{{this.title}}</strong>
          {{this.text}}
        </div>
      </div>

      {{!-- texte-image --}}
      {{else if (eq this.type "texte-image")}}
      <div class="step-with-img">
        <div>
          {{#each this.prose}}
          <p>{{{this}}}</p>
          {{/each}}
        </div>
        <div class="step-img-col">
          <a href="/static/img/articleImg/{{this.img}}" class="glightbox" data-gallery="article-gallery"
            data-title="{{this.imgAlt}}">
            <img src="/static/img/articleImg/{{this.img}}" alt="{{this.imgAlt}}" class="step-img-real" loading="lazy">
          </a>
          {{#if this.caption}}
          <div class="step-caption-txt">{{this.caption}}</div>
          {{/if}}
        </div>
      </div>

      {{!-- info-cas-particulier --}}
      {{else if (eq this.type "info-cas-particulier")}}
      <div class="special-case">
        <strong>{{this.title}}</strong>
        {{this.text}}
      </div>

      {{!-- note-texte --}}
      {{else if (eq this.type "note-texte")}}
      <p class="note-texte">{{{this.text}}}</p>

      {{!-- conseils-erreurs --}}
      {{else if (eq this.type "conseils-erreurs")}}
      <div class="tips-wrap">
        <div class="row g-2">
          <!-- Colonne des bonnes pratiques -->
          <div class="col-md-6">
            <div class="tips-col-lbl g mb-2">✓ À faire</div>
            {{#each this.pairs}}
            <div class="tip-c g mb-2"><span>✓</span><span>{{this.good}}</span></div>
            {{/each}}
          </div>
          <!-- Colonne des erreurs -->
          <div class="col-md-6">
            <div class="tips-col-lbl b mb-2">✗ À éviter</div>
            {{#each this.pairs}}
            <div class="tip-c b mb-2"><span>✗</span><span>{{this.bad}}</span></div>
            {{/each}}
          </div>
        </div>
      </div>


      {{!-- etapes → partial (récursif) --}}
      {{else if (eq this.type "etapes")}}
      {{> guide-blocks/etapes block=this}}

      {{!-- formula-box → partial --}}
      {{else if (eq this.type "formula-box")}}
      {{> guide-blocks/formula-box block=this}}

      {{!-- schema-couches → partial --}}
      {{else if (eq this.type "schema-couches")}}
      {{> guide-blocks/schema-couches block=this}}

      {{!-- grid-cartes → partial --}}
      {{else if (eq this.type "grid-cartes")}}
      {{> guide-blocks/grid-cartes block=this}}

      {{!-- tableau → partial --}}
      {{else if (eq this.type "tableau")}}
      {{> guide-blocks/tableau block=this}}

      {{!-- tableau-mat → partial --}}
      {{else if (eq this.type "tableau-mat")}}
      {{> guide-blocks/tableau-mat block=this}}

      {{!-- flow-decision → partial --}}
      {{else if (eq this.type "flow-decision")}}
      {{> guide-blocks/flow-decision block=this}}

      {{!-- timeline-etapes → partial --}}
      {{else if (eq this.type "timeline-etapes")}}
      {{> guide-blocks/timeline-etapes block=this}}

      {{!-- grid-cartons → partial --}}
      {{else if (eq this.type "grid-cartons")}}
      {{> guide-blocks/grid-cartons block=this}}

      {{!-- procedure → partial --}}
      {{else if (eq this.type "procedure")}}
      {{> guide-blocks/procedure block=this}}

      {{!-- procedure-image → partial --}}
      {{else if (eq this.type "procedure-image")}}
      {{> guide-blocks/procedure-image block=this}}

      {{!-- grid-cout → partial --}}
      {{else if (eq this.type "grid-cout")}}
      {{> guide-blocks/grid-cout block=this}}

      {{/if}}
      {{/each}}
      {{!-- ── FIN DISPATCH ── --}}

    </div>
    {{/each}}
    {{!-- FIN SECTIONS --}}

    {{!-- TRANSITION --}}
    {{#if this.transition}}
    <div class="part-transition">{{this.transition}}</div>
    {{/if}}

  </div>
  {{/each}}
  {{!-- FIN PARTIES --}}

  {{!-- ════════════════════════════════════════════
  FAQ
  ════════════════════════════════════════════ --}}
  {{#if article.faq}}
  <div class="prose section-gap" id="article-faq">
    <h3>FAQ</h3>
    <div class="faq-list">
      {{#each article.faq}}
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)">
          {{this.question}}<span class="faq-chev">▼</span>
        </button>
        <div class="faq-a">
          {{#each this.responses}}
          <p>{{this.text}}</p>
          {{/each}}
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
  UPDATE NOTE
  ════════════════════════════════════════════ --}}
  {{#if article.updateNote}}
  <div class="update-note-block">
    <strong class="update-note-title">Dernière mise à jour</strong><br>
    {{article.updateNote}}
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
  SOURCES
  ════════════════════════════════════════════ --}}
  {{#if article.sources}}
  <div class="sources">
    <strong>Sources principales</strong>
    <ul>
      {{#each article.sources}}
      <li>
        {{#if this.url}}
        <a href="{{this.url}}" target="_blank" rel="nofollow noopener">{{this.name}}</a>
        {{else}}
        {{this.name}}
        {{/if}}
        {{#if this.article}} — {{this.article}}{{/if}}
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
  AFFILIATION
  ════════════════════════════════════════════ --}}
  <div class="affil">
    <span class="affil-icon">ℹ</span>
    <span>Certains liens sur cette page sont affiliés. Nous pouvons toucher une commission
      sans coût supplémentaire pour vous, ce qui nous aide à maintenir nos services gratuits.</span>
  </div>

</div>{{!-- /page --}}

<!-- Section "À découvrir" CONTEXTUELLE  -->
{{> related-links/_base pageType="guide-detail"}}

<!-- Bouton partager l'article -->
<button id="share-article" class="share-article-btn" title="Partager l'article">
  <i class="fa-solid fa-share"></i>
</button>