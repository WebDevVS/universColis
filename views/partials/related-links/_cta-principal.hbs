{{!-- =============================================
CTA PRINCIPAL — Format horizontal compact
Contextuel selon pageType.
Peut être surchargé via ctaTitle / ctaSubtitle / ctaLink / ctaButtonText
============================================= --}}

<div class="rl-cta">

  <div class="rl-cta-text">
    {{!-- Titre --}}
    {{#if ctaTitle}}
    <h3 class="rl-cta-title">{{ctaTitle}}</h3>
    {{else}}
    {{#if (eq pageType "suivi")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre prochain colis ?</h3>
    {{else if (eq pageType "guide-detail")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "materiel-catalog")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "materiel-category")}}
    <h3 class="rl-cta-title">Votre colis emballé ? Expédiez au meilleur prix</h3>
    {{else if (eq pageType "question-detail")}}
    <h3 class="rl-cta-title">Question résolue ? Expédiez votre colis</h3>
    {{else if (eq pageType "questions-catalog")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "questions-category")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "actualite-detail")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "actualites")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else if (eq pageType "guides-catalog")}}
    <h3 class="rl-cta-title">Quel est le meilleur prix pour votre envoi ?</h3>
    {{else}}
    <h3 class="rl-cta-title">Prêt à expédier votre colis ?</h3>
    {{/if}}
    {{/if}}

    {{!-- Sous-titre --}}
    {{#if ctaSubtitle}}
    <p class="rl-cta-subtitle">{{ctaSubtitle}}</p>
    {{else}}
    {{#if (eq pageType "suivi")}}
    <p class="rl-cta-subtitle">Comparez les offres et trouvez le meilleur tarif en quelques clics</p>
    {{else if (eq pageType "actualite-detail")}}
    <p class="rl-cta-subtitle">Trouvez l'offre la plus compétitive parmi tous les transporteurs</p>
    {{else if (eq pageType "actualites")}}
    <p class="rl-cta-subtitle">Comparez les offres et expédiez au meilleur tarif.</p>
    {{else if (eq pageType "questions-catalog")}}
    <p class="rl-cta-subtitle">Comparez les offres et expédiez au meilleur tarif.</p>
    {{else if (eq pageType "questions-category")}}
    <p class="rl-cta-subtitle">Comparez les offres et expédiez au meilleur tarif.</p>
    {{else}}
    <p class="rl-cta-subtitle">Comparez les prix et trouvez la meilleure offre en quelques clics</p>
    {{/if}}
    {{/if}}
  </div>



  {{!-- Bouton --}}
  {{#if ctaLink}}
  <a href="{{ctaLink}}" class="rl-cta-btn">
    <i class="fa-solid fa-rocket"></i>
    {{#if ctaButtonText}}{{ctaButtonText}}{{else}}Commencer{{/if}}
  </a>
  {{else}}
  {{#if (eq pageType "guides-catalog")}}
  <a href="/#formulaire-comparateur" class="rl-cta-btn">
    <i class="fa-solid fa-rocket"></i>
    Comparer les prix
  </a>
  {{else}}
  <a href="/#formulaire-comparateur" class="rl-cta-btn">
    <i class="fa-solid fa-rocket"></i>
    Comparer les prix
  </a>
  {{/if}}
  {{/if}}

</div>