{{!-- =============================================
  NAV ÉCOSYSTÈME — Chips
  Affiche tous les liens du site en chips discrets.
  La page courante est grisée via pageType.
============================================= --}}

<div class="nav-ecosystem">
  <div class="nav-ecosystem-label">
    <i class="fa-solid fa-globe" style="font-size:0.65rem;"></i>
    Explorez tout l'écosystème UniversColis
  </div>

  <div class="nav-ecosystem-chips">

    <a href="/" class="nav-chip {{#if (eq pageType 'home')}}current-page{{/if}}">
      <i class="fa-solid fa-calculator"></i>Comparateur
    </a>

    <a href="/suivi" class="nav-chip {{#if (eq pageType 'suivi')}}current-page{{/if}}">
      <i class="fa-solid fa-map-marker-alt"></i>Suivi Colis
    </a>

    <a href="/mon-materiel" class="nav-chip {{#if (eq pageType 'materiel-catalog')}}current-page{{/if}}">
      <i class="fa-solid fa-box"></i>Matériel
    </a>

    <a href="/conseils" class="nav-chip {{#if (or (eq pageType 'guides-catalog') (eq pageType 'guide-detail'))}}current-page{{/if}}">
      <i class="fa-solid fa-book-open"></i>Conseils
    </a>

    <a href="/questions" class="nav-chip {{#if (or (eq pageType 'questions-catalog') (eq pageType 'questions-category') (eq pageType 'question-detail'))}}current-page{{/if}}">
      <i class="fa-solid fa-circle-question"></i>FAQ
    </a>

    <a href="/actualites" class="nav-chip {{#if (or (eq pageType 'actualites') (eq pageType 'actualite-detail'))}}current-page{{/if}}">
      <i class="fa-solid fa-newspaper"></i>Actualités
    </a>

    <a href="/suivi" class="nav-chip {{#if (or (eq pageType "suivi") (eq pageType "statuts-colis"))}}current-page{{/if}}">

  </div>
</div>
