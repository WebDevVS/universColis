    <a href="/suivi" class="link-card featured">
      <div class="link-icon"><i class="fa-solid fa-map-marker-alt"></i></div>
      <div class="link-content">
        <h4 class="link-title">Suivre Mon Colis</h4>
        <p class="link-description">5 widgets de suivi</p>
        <span class="link-action">Suivre <i class="fa-solid fa-arrow-right"></i></span>
      </div>
    </a>
  </div>
  
  {{#each relatedQuestions}}
  <div class="col-md-4">
