{{#if (eq questionCategory "tarifs-et-prix")}}
  <div class="col-md-4">
    <a href="/#formulaire-comparateur" class="link-card featured">
      <div class="link-icon"><i class="fa-solid fa-calculator"></i></div>
      <div class="link-content">
        <h4 class="link-title">Comparer les Tarifs</h4>
        <p class="link-description">Prix réel en 2 minutes</p>
        <span class="link-action">Calculer <i class="fa-solid fa-arrow-right"></i></span>
      </div>
    </a>
  </div>
  
  {{!-- 2 questions similaires (depuis serveur) --}}
  {{#each relatedQuestions}}
  <div class="col-md-4">
    <a href="/questions/{{../questionCategory}}/{{this.slug}}" class="link-card">
      <div class="link-icon"><i class="fa-solid fa-circle-question"></i></div>
      <div class="link-content">
        <h4 class="link-title">{{this.questionTitle}}</h4>
        <span class="link-action">Lire <i class="fa-solid fa-arrow-right"></i></span>
      </div>
    </a>
  </div>
  {{/each}}

{{else if (eq questionCategory "suivi-de-colis")}}
