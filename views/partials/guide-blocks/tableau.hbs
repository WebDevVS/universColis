<table class="coverage-table">
  <thead>
    <tr>
      {{#each block.headers}}
      <th>{{this}}</th>
      {{/each}}
    </tr>
  </thead>
  <tbody>
    {{#each block.rows}}
    <tr class="cov-{{this.color}}">
      <td>{{this.level}}</td>
      <td class="cov-calcul">{{this.calcul}}</td>
      <td><span class="cov-badge {{this.color}}">{{this.when}}</span></td>
    </tr>
    {{/each}}
  </tbody>
</table>