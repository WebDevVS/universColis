{{!-- 
  FORMAT-GRID
  Grille de cartes avec photo + type + risque + question.
  
  Paramètres JSON :
  - cols    : nombre de colonnes (2, 3, 4, 5 — défaut 3)
  - cards[] :
      - img          : chemin image
      - imgAlt       : texte alternatif
      - type         : nom du format
      - risk         : risque principal (optionnel)
      - question     : question clé en italique (optionnel)
      - name         : nom alternatif à "type" (optionnel)
      - specs        : spécifications techniques (optionnel)
      - specialStyle : "special" pour bordure colorée (optionnel)
--}}

<div class="format-grid format-grid--cols-{{#if block.cols}}{{block.cols}}{{else}}3{{/if}}">
  {{#each block.cards}}
  <div class="format-card {{#if this.specialStyle}}{{this.specialStyle}}{{/if}}">
    <div class="format-photo">
      <img src="/static/img/articleImg/{{this.img}}"
           alt="{{this.imgAlt}}"
           loading="lazy">
    </div>
    <div class="format-card-body">
      <div class="format-type">{{#if this.name}}{{this.name}}{{else}}{{this.type}}{{/if}}</div>
      {{#if this.specs}}
      <div class="format-risk">{{this.specs}}</div>
      {{/if}}
      {{#if this.risk}}
      <div class="format-risk">{{this.risk}}</div>
      {{/if}}
      {{#if this.question}}
      <div class="format-question">{{this.question}}</div>
      {{/if}}
    </div>
  </div>
  {{/each}}
</div>