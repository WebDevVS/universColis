{{!-- 
  DATA-TABLE
  Tableau avec badges colorés dans la dernière colonne.
  Différent de tableau.hbs : la dernière colonne affiche un badge coloré, pas du texte simple.
  Utilisé pour : tableau des types de cires, tableau des destinations
  
  Paramètres JSON :
  - headers[]  : en-têtes de colonnes (strings)
  - rows[]     :
      - cells[]   : valeurs des colonnes sauf la dernière
      - badge     : texte du badge dans la dernière colonne
      - badgeStyle: "low" (rouge), "med" (orange), "ok" (vert)
--}}

<div class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        {{#each block.headers}}
        <th>{{this}}</th>
        {{/each}}
      </tr>
    </thead>
    <tbody>
      {{#each block.rows}}
      <tr>
        {{#each this.cells}}
        <td>{{{this}}}</td>
        {{/each}}
        {{#if this.badge}}
        <td><span class="wax-badge {{this.badgeStyle}}">{{this.badge}}</span></td>
        {{/if}}
      </tr>
      {{/each}}
    </tbody>
  </table>
</div>