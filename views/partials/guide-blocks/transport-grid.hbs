{{!-- 
  TRANSPORT-GRID
  Liste verticale de cartes transporteurs.
  Chaque carte : icône + badge + nom + usage + vérification.
  Utilisé pour : présenter les transporteurs et leurs conditions
  
  Paramètres JSON :
  - cards[] :
      - icon   : emoji
      - badge  : texte du badge (ex: "Standard", "Express")
      - badgeStyle : "tb-standard", "tb-express", "tb-pro", "tb-intl"
      - name   : nom du transporteur
      - usage  : description d'usage
      - check  : point de vérification en couleur --pc
--}}

<div class="transport-grid">
  {{#each block.cards}}
  <div class="transport-card">
    <div class="transport-visual">
      {{#if this.logo}}
      <img src="/static/img/logos/{{this.logo}}" alt="Logo {{this.name}}" class="transport-logo" loading="lazy">
      {{else if (eq this.name "Colissimo")}}
      <img src="/static/img/logos/laposte.webp" alt="Logo Colissimo" class="transport-logo" loading="lazy">
      {{else if (eq this.name "Chronopost")}}
      <img src="/static/img/logos/chronopost.webp" alt="Logo Chronopost" class="transport-logo" loading="lazy">
      {{else if (eq this.name "Chrono Viti")}}
      <img src="/static/img/logos/chronopost.webp" alt="Logo Chrono Viti" class="transport-logo" loading="lazy">
      {{else if (eq this.name "Mondial Relay")}}
      <img src="/static/img/logos/mondialrelay.webp" alt="Logo Mondial Relay" class="transport-logo" loading="lazy">
      {{else if (eq this.name "DHL Express")}}
      <img src="/static/img/logos/dhlexpress.webp" alt="Logo DHL Express" class="transport-logo" loading="lazy">
      {{else}}
      <span class="transport-fallback-icon">{{this.icon}}</span>
      {{/if}}
    </div>
    <div class="transport-content">
      <span class="transport-badge {{this.badgeStyle}}">{{this.badge}}</span>
      <div class="transport-name">{{this.name}}</div>
      <div class="transport-usage">{{this.usage}}</div>
      <div class="transport-check">{{{this.check}}}</div>
    </div>
  </div>
  {{/each}}
</div>