<!-- PAGE HEADER -->
<header class="page-header">
  <h1>Une question ? <span>Contactez-nous.</span></h1>
  <p>Notre équipe répond à toutes vos questions sur l'expédition, le suivi de colis ou nos services.</p>
</header>

<!-- LAYOUT -->
<div class="contact-wrapper">

  <!-- INFO PANEL -->
  <aside class="info-panel">

    <div class="response-badge">
      <div class="dot"></div>
      <p>Temps de réponse moyen : <strong>sous 48h</strong> ouvrées</p>
    </div>

    <div class="info-card">
      <div class="icon"><i class="fas fa-box"></i></div>
      <h3>Suivi & expédition</h3>
      <p>Une question sur le suivi de votre colis ou la comparaison de transporteurs ? Nous sommes disponibles pour vous
        aider.</p>
    </div>

    <div class="info-card">
      <div class="icon"><i class="fas fa-handshake"></i></div>
      <h3>Partenariats & pros</h3>
      <p>Vous êtes un e-commerçant ou un transporteur ? Contactez-nous pour discuter d'un partenariat.</p>
    </div>

    <div class="info-card">
      <div class="icon"><i class="fas fa-bug"></i></div>
      <h3>Signaler un problème</h3>
      <p>Vous avez trouvé un bug ou une information incorrecte sur le site ? Merci de nous le signaler.</p>
    </div>

  </aside>

  <!-- FORM CARD -->
  <main class="form-card">
    <h2><i class="fas fa-paper-plane" style="color:var(--accent-color);margin-right:10px;"></i>Envoyer un message</h2>

    <form id="contactForm" novalidate>

      <div class="form-row">
        <div class="form-group">
          <label for="nom">Nom & Prénom <span class="required">*</span></label>
          <input type="text" id="nom" name="nom" placeholder="Votre nom complet" required>
          <span class="error-msg" id="error-nom"></span>
        </div>
        <div class="form-group">
          <label for="email">Email <span class="required">*</span></label>
          <input type="email" id="email" name="email" placeholder="exemple@email.com" required>
          <span class="error-msg" id="error-email"></span>
        </div>
      </div>

      <div class="form-group">
        <label for="sujet">Sujet <span class="required">*</span></label>
        <select id="sujet" name="sujet" required>
          <option value="" disabled selected>Choisissez un sujet…</option>
          <option value="suivi">Suivi de colis</option>
          <option value="comparaison">Comparaison de transporteurs</option>
          <option value="partenariat">Partenariat / B2B</option>
          <option value="bug">Signaler un bug</option>
          <option value="autre">Autre demande</option>
        </select>
        <span class="error-msg" id="error-sujet"></span>
      </div>

      <div class="form-group">
        <label for="message">Message <span class="required">*</span></label>
        <textarea id="message" name="message" placeholder="Décrivez votre demande en quelques lignes…"
          required></textarea>
        <span class="error-msg" id="error-message"></span>
      </div>

      <div class="privacy-check">
        <input type="checkbox" id="privacy" name="privacy" required>
        <label for="privacy">J'accepte que mes données soient utilisées pour traiter ma demande, conformément à la <a
            href="/politique-confidentialite">politique de confidentialité</a> d'UniversColis.fr.</label>
      </div>
      <span class="error-msg" id="error-privacy"></span>

      <button type="submit" class="btn-submit">
        <i class="fas fa-paper-plane"></i>
        Envoyer le message
      </button>

    </form>

    <!-- SUCCESS STATE -->
    <div class="success-msg" id="successMsg">
      <div class="success-icon"><i class="fas fa-check"></i></div>
      <h3>Message envoyé !</h3>
      <p>Merci de nous avoir contactés. Nous reviendrons vers vous dans les 48h ouvrées.</p>
    </div>