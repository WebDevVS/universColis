<section class="home">
  <div class="container min-vh-100">
    <div class="row g-5 align-items-center">

      <!-- COLONNE HERO (gauche) -->
      <div class="col-md-6 hero-content-col">
        <div class="hero-content">
          <h1 class="home-phrase">Trouvez le meilleur prix pour vos colis et expédiez efficacement</h1>
          <p class="hero-subtitle">
            Comparez les tarifs d'envoi de colis chez Colissimo, Chronopost, DHL, UPS, Mondial Relay et plus encore.
            Point relais ou enlèvement à domicile, France, DOM-TOM ou international : trouvez l'option la moins chère et
            la plus rapide.
          </p>
        </div>
      </div>

      <!-- COLONNE FORMULAIRE (droite) -->
      <div class="col-md-6 submit-form-col">
        <div class="submit-form" id="formulaire-comparateur">
          <h1>Comparez les tarifs d'envoi</h1>

          <!-- Navigation à onglets -->
          <nav class="tab-navigation" role="tablist" aria-label="Types de recherche">
            <div class="tabs">
              <button class="tab-btn active" data-target="recherche-rapide" role="tab" aria-selected="true"
                aria-controls="recherche-rapide">
                <i class="fa-solid fa-bolt"></i>
                RECHERCHE RAPIDE
              </button>
              <button class="tab-btn" data-target="recherche-avancee" role="tab" aria-selected="false"
                aria-controls="recherche-avancee">
                <i class="fa-solid fa-sliders"></i>
                RECHERCHE AVANCÉE
              </button>
            </div>
          </nav>

          <!-- Contenu des onglets -->
          <div class="tab-content">

            <!-- FORMULAIRE RECHERCHE RAPIDE -->
            <div id="recherche-rapide" class="tab-pane active" role="tabpanel">
              <form action="/comparateur-des-prix" method="GET">
                <input type="hidden" name="formType" value="rapide">

                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="origine-rapide" class="form-label">Origine</label>
                    <input type="hidden" id="origine-rapide" name="origine" value="FR">
                    <span class="form-control bg-light border-none" readonly>FRANCE</span>
                  </div>

                  <div class="col-md-6">
                    <label for="destination-rapide" class="form-label">Destination</label>
                    <select id="destination-rapide" name="destination" class="form-select" required>
                      <option value="" disabled selected>Sélectionnez un pays</option>
                      {{#each countries}}
                      <option value="{{this.isoCode}}">{{this.label}}</option>
                      {{/each}}
                    </select>
                  </div>
                </div>

                <div class="row g-3 mt-2">
                  <div class="col-md-6">
                    <label for="poids-rapide" class="form-label">Poids précis</label>
                    <div class="position-relative">
                      <input type="number" id="poids-rapide" class="form-control poids-input" step="0.1" min="0.1"
                        max="30" placeholder="Ex: 2.5" name="poids" required>
                      <span class="poids-unit">kg</span>
                    </div>
                  </div>

                  <div class="col-md-6 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">
                      Comparer les prix
                    </button>
                  </div>
                </div>
              </form>
            </div>

            <!-- FORMULAIRE RECHERCHE AVANCÉE -->
            <div id="recherche-avancee" class="tab-pane" role="tabpanel">
              <form action="/comparateur-des-prix" method="GET">
                <input type="hidden" name="formType" value="avance">

                <!-- Origine & Destination -->
                <div class="row g-3">
                  <div class="col-md-6">
                    <label for="origine-avance" class="form-label">Pays d'origine</label>
                    <input type="hidden" id="origine-avance" name="origine" value="FR">
                    <span class="form-control bg-light border-none" readonly>FRANCE</span>

                    <label for="ville-origine" class="form-label mt-3">Ville / Code postal</label>
                    <input type="text" id="ville-origine" name="ville-origine" class="form-control"
                      placeholder="Ex : Paris 75000" autocomplete="off" required>
                    <ul id="results-origine" class="results-list position-absolute bg-white border w-100 z-index-1000">
                    </ul>
                  </div>

                  <div class="col-md-6">
                    <label for="destination-avance" class="form-label">Pays de destination</label>
                    <select id="destination-avance" name="destination" class="form-select" required>
                      <option value="" disabled selected>Sélectionnez un pays</option>
                      {{#each countries}}
                      <option value="{{this.isoCode}}">{{this.label}}</option>
                      {{/each}}
                    </select>

                    <label for="ville-destination" class="form-label mt-3">Ville / Code postal</label>
                    <input type="text" id="ville-destination" name="ville-destination" class="form-control"
                      placeholder="Ex : Lyon 69000" autocomplete="off" required>
                    <ul id="results-destination"
                      class="results-list position-absolute bg-white border w-100 z-index-1000"></ul>
                  </div>
                </div>

                <!-- Poids & Dimensions -->
                <div class="row g-3 mt-2">
                  <div class="col-md-6">
                    <label for="poids-avance" class="form-label">Poids précis</label>
                    <div class="position-relative">
                      <input type="number" id="poids-avance" class="form-control poids-input" step="0.1" min="0.1"
                        max="30" placeholder="Ex: 2.5" name="poids" required>
                      <span class="poids-unit">kg</span>
                    </div>
                  </div>

                  <div class="col-md-6">
                    <label for="dimensions" class="form-label">Dimensions (cm)</label>
                    <div class="row g-2">
                      <div class="col-4">
                        <input type="number" class="form-control" placeholder="L" name="longueur" min="1" required>
                      </div>
                      <div class="col-4">
                        <input type="number" class="form-control" placeholder="l" name="largeur" min="1" required>
                      </div>
                      <div class="col-4">
                        <input type="number" class="form-control" placeholder="H" name="hauteur" min="1" required>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- Type d'envoi & Submit -->
                <div class="row g-3 mt-2">
                  <div class="col-md-6">
                    <label for="type-envoi" class="form-label">Type d'envoi</label>
                    <select id="type-envoi" name="code-contenu" class="form-select" required>
                      <option value="" disabled selected>Sélectionnez</option>
                      {{#each categories}}
                      <option value="{{this.category}}">{{this.category}}</option>
                      {{/each}}
                    </select>
                  </div>

                  <div class="col-md-6 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">
                      Comparer les prix
                    </button>
                  </div>
                </div>
              </form>
            </div>

          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Overlay de chargement (inchangé) -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-card">
      <div class="loading-icon">
        <i class="fa-solid fa-magnifying-glass"></i>
      </div>

      <h3 class="loading-title">Recherche en cours...</h3>
      <p class="loading-message">
        Nous analysons les meilleures offres de transporteurs pour vous
      </p>

      <!-- Étapes de progression -->
      <div class="loading-steps">
        <div class="loading-step">
          <div class="step-circle active" id="step1">
            <i class="fa-solid fa-search"></i>
          </div>
          <div class="step-label active">Recherche</div>
        </div>
        <div class="loading-step">
          <div class="step-circle" id="step2">
            <i class="fa-solid fa-chart-line"></i>
          </div>
          <div class="step-label">Analyse</div>
        </div>
        <div class="loading-step">
          <div class="step-circle" id="step3">
            <i class="fa-solid fa-check"></i>
          </div>
          <div class="step-label">Finalisation</div>
        </div>
      </div>

      <div class="spinner-container">
        <div class="modern-spinner"></div>
        <span class="spinner-text" id="spinnerText">Recherche des offres...</span>
      </div>
    </div>
  </div>
</section>

<!-- Section Présentation UniversColis -->
<section class="about-universcolis-mini">
  <div class="container">
    <p class="about-text">
  <strong>UniversColis</strong> compare les tarifs 2025 des principaux transporteurs 
      et vous accompagne à chaque étape de l'expédition avec conseils et outils pratiques.
    </p>
  </div>
</section>

<section class="company-logos py-4">
  <div class="container">
    <div class="logo-container d-flex justify-content-start">
      {{#each carriers}}
      <div class="carrier">
        <img src="{{this}}" alt="{{@key}}" title="{{@key}}" />
      </div>
      {{/each}}
      {{#each carriers}}
      <div class="carrier">
        <img src="{{this}}" alt="{{@key}}" title="{{@key}}" />
      </div>
      {{/each}}
    </div>
  </div>
</section>

