      <h2 class="news-title">Les actualités</h2>
      <p class="news-subtitle">Tarifs 2025, surtaxes carburant, douane & TVA : restez à jour pour payer le juste prix</p>
    </div>

    <div class="row">
      <div class="col-12">

        {{#each actualites}}
        <article class="news-card-mixed" itemscope itemtype="https://schema.org/NewsArticle">
        <meta itemprop="datePublished" content="{{publishedDate}}">
          <div class="news-meta-mixed">
            <div class="news-date-compact">
              <i class="fa-regular fa-calendar"></i>
              <span itemprop="dateModified" content="{{publishedDate}}">{{publishedDate}}</span>
            </div>
            <div class="news-category-compact">{{keyWord}}</div>
          </div>

          <h3 class="news-title-mixed" itemprop="headline">{{resumeTitle}}</h3>
          <p class="news-excerpt-mixed" itemprop="description">
            {{description}}
          </p>

          <a href="{{canonicalUrl}}" class="news-read-more-mixed" itemprop="url">
            Lire l'article complet
            <i class="fa-solid fa-arrow-right"></i>
          </a>
        </article>
        {{/each}}

      </div>
    </div>

    <!-- Footer avec lien vers toutes les actualités -->
    <div class="news-footer">
      <a href="/actualites" class="news-view-all">
        <i class="fa-solid fa-globe"></i>
        Voir toutes les actualités
        <i class="fa-solid fa-arrow-right"></i>
      </a>
    </div>
  </div>
</section>







/* ========================================= */
/* VARIABLES GLOBALES */
/* ========================================= */


/* ========================================= */
/* SECTION 1 - EXPÉDIEZ EN 3 ÉTAPES */
/* ========================================= */
.benefits-v3 {
  
  background-color: var(--white-transparent);
  border-radius: var(--border-radius);
  padding: 2rem;
  margin: 2rem;
  box-shadow: var(--shadow-standard);
}

.section-header {
  text-align: center;
  margin-bottom: 60px;
}

.section-title-home {
  display: flex;
  font-size: 2.5rem;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 16px;
}

.section-subtitle {
  font-size: 1.2rem;
  color: var(--text-muted);
  max-width: 700px;
  margin: 0 auto;
}

.benefits-numbered {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
}

.benefit-numbered {
  position: relative;
  padding: 30px;
  background: linear-gradient(135deg, rgba(130, 105, 164, 0.03), rgba(250, 126, 117, 0.03));
  border-radius: 16px;
  border: 2px solid rgba(130, 105, 164, 0.1);
  transition: all 0.3s ease;
}

.benefit-numbered:hover {
  border-color: var(--primary-color);
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(130, 105, 164, 0.15);
}

.benefit-number {
  position: absolute;
  top: -15px;
  left: 30px;
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 1.2rem;
  color: white;
}

.benefit-numbered h3 {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12px;
  margin-top: 15px;
}

.benefit-numbered p {
  color: var(--text-muted);
  line-height: 1.6;
  margin: 0;
  font-size: 0.95rem;
}

/* Séparateur */
.separator {
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--primary-color), transparent);
  margin: 80px 0;
}

/* ========================================= */
/* SECTION 2 - LES AVANTAGES UNIVERSCOLIS */
/* ========================================= */
.benefits {
   background-color: var(--white-transparent);
  border-radius: var(--border-radius);
  padding: 2rem;
  margin: 2rem;
  box-shadow: var(--shadow-standard);
}

.benefits-container {
  display: flex;
  flex-direction: column;
  gap: 30px;
  max-width: 1000px;
  margin: 0 auto;
}

.benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 30px;
  padding: 40px;
  background: var(--white);
  border-radius: 20px;
  border: 2px solid rgba(130, 105, 164, 0.1);
  transition: all 0.3s ease;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
}

.benefit-item:hover {
  border-color: rgba(130, 105, 164, 0.3);
  transform: translateX(10px);
  box-shadow: -8px 8px 25px rgba(130, 105, 164, 0.12);
}

.benefit-icon-wrapper {
  width: 80px;
  height: 80px;
  min-width: 80px;
  background: rgba(130, 105, 164, 0.1);
  border: 3px solid var(--primary-color);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  color: var(--primary-color);
  transition: transform 0.3s ease;
}

.benefit-item:hover .benefit-icon-wrapper {
  transform: scale(1.05) rotate(3deg);
}

.benefit-content {
  flex: 1;
}

.benefit-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12px;
  line-height: 1.3;
}

.benefit-description {
  color: var(--text-muted);
  line-height: 1.7;
  margin: 0;
  font-size: 1.05rem;
}

/* ========================================= */
/* SECTION 3 - PLUS QU'UN COMPARATEUR (SERVICES) */
/* ========================================= */
.services-section {
  padding: 80px 0;
  background: var(--gradient-light);
}

.services-section .section-title-home {
  color: var(--primary-color);
  background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 30px;
  margin-bottom: 60px;
}

.service-card {
  background: var(--white);
  border-radius: 20px;
  padding: 40px 30px;
  text-align: center;
  transition: all 0.3s ease;
  border: 2px solid rgba(130, 105, 164, 0.1);
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  text-decoration: none;
  color: inherit;
  display: block;
  height: 100%;
}

.service-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: linear-gradient(90deg, var(--primary-color), var(--accent-color));
  transform: scaleX(0);
  transition: transform 0.3s ease;
}

.service-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 24px rgba(130, 105, 164, 0.15);
  border-color: rgba(130, 105, 164, 0.3);
  text-decoration: none;
  color: inherit;
}

.service-card:hover::before {
  transform: scaleX(1);
}

.service-icon {
  width: 80px;
  height: 80px;
  margin: 0 auto 24px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  background: linear-gradient(135deg, var(--primary-color), var(--accent-color));
  color: white;
  transition: all 0.3s ease;
}

.service-card:hover .service-icon {
  transform: scale(1.1) rotate(5deg);
}

.service-title {
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 12px;
}

.service-description {
  font-size: 1rem;
  color: var(--text-muted);
  line-height: 1.6;
  margin-bottom: 20px;
}

.service-action {
  color: var(--accent-color);
  font-weight: 600;
  font-size: 0.95rem;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  transition: all 0.3s ease;
}

.service-card:hover .service-action {
  gap: 12px;
  color: var(--primary-color);
}



/* ========================================= */
/* RESPONSIVE */
/* ========================================= */
@media (max-width: 768px) {

    /* Ensure benefits sections match article margins on small screens */
  .benefits,
  .benefits-v3 {
    margin-left: auto;
    margin-right: auto;
    max-width: 98vw;
    padding-left: 1rem;
    padding-right: 1rem;
    box-sizing: border-box;
  }

  /* Section 1 - Expédiez en 3 étapes */
  .benefits-v3 {
    padding: 60px 0;
  }

  .benefits-numbered {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  /* Section 2 - Les avantages */
  .benefits {
    padding: 60px 0;
  }

  .section-title-home {
    font-size: 2rem;
  }

  .section-header {
    margin-bottom: 50px;
  }

  .benefits-container {
    gap: 20px;
  }

  .benefit-item {
    flex-direction: column;
    text-align: center;
    padding: 30px 20px;
  }

  .benefit-item:hover {
    transform: translateY(-5px);
  }

  .benefit-icon-wrapper {
    margin: 0 auto;
  }

  /* Section 3 - Services */
  .services-section {
    padding: 60px 0;
  }

  .services-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .service-card {
    padding: 32px 24px;
  }

  .main-cta {
    padding: 40px 24px;
  }

  .cta-title {
    font-size: 1.6rem;
  }
}