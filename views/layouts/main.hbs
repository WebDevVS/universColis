    <!-- Scripts spécifiques cookies -->
    {{#if isProd}}
    <script>
        (function () {
            window.clarityConsentState = { loaded: false, lastStatus: null };
            window.loadClarityWithConsent = function (granted) {
                var status = granted ? 'granted' : 'denied';
                if (window.clarityConsentState.lastStatus === status) return;
                window.clarityConsentState.lastStatus = status;
                if (!window.clarityConsentState.loaded) {
                    (function (c, l, a, r, i, t, y) {
                        c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
                        t = l.createElement(r); t.async = 1; t.src = "https://www.clarity.ms/tag/ublc3yobr9";
                        y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
                    })(window, document, "clarity", "script");
                    window.clarityConsentState.loaded = true;
                }
                function send() {
                    if (typeof window.clarity === 'function') {
                        try {
                            window.clarity('consentv2', {
                                ad_storage: 'denied',
                                analytics_storage: status
                            });
                        } catch (e) { }
                    } else {
                        setTimeout(send, 150);
                    }
                }
                send();
            };
        })();
    </script>
