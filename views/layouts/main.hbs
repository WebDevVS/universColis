    {{/if}}

    {{!-- ⚠️ SUPPRIMÉ : silktide-consent-manager.min.css             --}}
    {{!--    Plus besoin - GateKeeper a son propre style               --}}

    <!-- GLightbox CSS conditionnel -->
    {{#if needsGallery}}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/glightbox@3.3.0/dist/css/glightbox.min.css">
    {{/if}}

    <!-- Preconnect Google Fonts & Font Awesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Preload Font Awesome font -->
    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/webfonts/fa-solid-900.woff2"
        as="font" type="font/woff2" crossorigin>

    {{!-- ============================================================ --}}
    {{!-- GOOGLE CONSENT MODE v2 + CLARITY                            --}}
    {{!-- ============================================================ --}}
    <script>
        // ── Initialisation dataLayer et gtag ──────────────────────────
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }

        // ── Google Consent Mode v2 - Valeurs par défaut (DENIED) ─────
        // Tout est refusé par défaut jusqu'à ce que GateKeeper
        // transmette le choix réel de l'utilisateur via TCF 2.2.
        gtag('consent', 'default', {
            analytics_storage:  'denied',
            ad_storage:         'denied',
            ad_user_data:       'denied',
            ad_personalization: 'denied',
            functionality_storage: 'granted',  // toujours nécessaire
            security_storage:      'granted'   // toujours nécessaire
        });

        // ── Clarity : chargement conditionnel au consentement ─────────
        // On initialise l'état de Clarity
        window.clarityConsentState = { loaded: false, lastStatus: null };

        window.loadClarityWithConsent = function (granted) {
            var status = granted ? 'granted' : 'denied';
            if (window.clarityConsentState.lastStatus === status) return;
            window.clarityConsentState.lastStatus = status;

            if (!window.clarityConsentState.loaded) {
                (function (c, l, a, r, i, t, y) {
                    c[a] = c[a] || function () { (c[a].q = c[a].q || []).push(arguments) };
                    t = l.createElement(r); t.async = 1;
                    t.src = "https://www.clarity.ms/tag/ublc3yobr9";
                    y = l.getElementsByTagName(r)[0]; y.parentNode.insertBefore(t, y);
                })(window, document, "clarity", "script");
                window.clarityConsentState.loaded = true;
            }

            // Envoie le statut de consentement à Clarity
            function sendClarityConsent() {
                if (typeof window.clarity === 'function') {
                    try {
                        window.clarity('consentv2', {
                            ad_storage:       'denied',   // Clarity = analytics uniquement
                            analytics_storage: status
                        });
                    } catch (e) { }
                } else {
                    setTimeout(sendClarityConsent, 150);
                }
            }
            sendClarityConsent();
        };

        // ── Écoute du consentement GateKeeper (TCF 2.2) ──────────────
        // GateKeeper expose window.__tcfapi dès son chargement.
        // On écoute 'useractioncomplete' (choix actif) ET
        // 'tcloaded' (consentement déjà enregistré = visites suivantes).
        function handleTCFConsent(tcData, success) {
            if (!success) return;

            // Purpose 1 = Store and/or access information on a device (analytics)
            var analyticsConsented = !!(
                tcData.purpose &&
                tcData.purpose.consents &&
                tcData.purpose.consents[1]
            );

            // Purpose 3/4 = ciblage pub
            var adConsented = !!(
                tcData.purpose &&
                tcData.purpose.consents &&
                tcData.purpose.consents[3]
            );

            // Mise à jour Google Consent Mode v2
            gtag('consent', 'update', {
                analytics_storage:  analyticsConsented ? 'granted' : 'denied',
                ad_storage:         adConsented ? 'granted' : 'denied',
                ad_user_data:       adConsented ? 'granted' : 'denied',
                ad_personalization: adConsented ? 'granted' : 'denied'
            });

            // Chargement conditionnel de Clarity
            window.loadClarityWithConsent(analyticsConsented);

            // Push dans le dataLayer pour GTM (si besoin de triggers GTM)
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
                event: 'consent_update',
                analytics_granted: analyticsConsented,
                ads_granted:       adConsented
            });
        }

        // Attendre que __tcfapi soit disponible (GateKeeper async)
        function waitForTCF() {
            if (typeof window.__tcfapi === 'function') {
                // Écoute les 2 événements : choix initial + visites suivantes
                window.__tcfapi('addEventListener', 2, handleTCFConsent);
            } else {
                setTimeout(waitForTCF, 100);
            }
        }
        waitForTCF();
    </script>

