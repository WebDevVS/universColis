    {{!-- ============================================================ --}}
    {{!-- EZOIC ADS - Scripts header                                   --}}
    {{!-- ORDRE CRITIQUE : GateKeeper CMP → Ezoic → Google Consent    --}}
    {{!-- ============================================================ --}}

    {{!-- 1. GateKeeper Ezoic (CMP TCF 2.2) - DOIT être en PREMIER    --}}
    {{!--    Remplace Silktide. Gère le banner cookies RGPD et         --}}
    {{!--    transmet le consentement à toutes les régies pub.         --}}
    {{!--    NE PAS mettre en async/defer - doit bloquer le rendu      --}}
    {{!--    pour éviter tout tracking avant consentement.             --}}
    {{#if isProd}}
    <script data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
    <script data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>
    {{/if}}

    {{!-- 2. Script principal Ezoic --}}
    <script async src="//www.ezojs.com/ezoic/sa.min.js"></script>
    <script>
        window.ezstandalone = window.ezstandalone || {};
        ezstandalone.cmd = ezstandalone.cmd || [];
    </script>

      {{!-- 3. Script analytics Ezoic --}}
    {{!-- <script src="//ezoicanalytics.com/analytics.js"></script> --}}

    <link rel="stylesheet" href="/static/css/purged/bootstrap.min.css">
    {{#if isProd}}
    <link rel="stylesheet" href="/static/css/purged/style.min.css">
    {{else}}
