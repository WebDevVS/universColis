<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{seoTitle}}</title>
    <meta name="description" content="{{seoDescription}}" />
    <meta name="keywords" content="{{#each seoKeywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}" />
    <meta name="author" content="{{author}}" />
    <meta name="robots" content="index, follow" />
    <meta name="date" content="{{modifiedDate}}" />
    <link rel="canonical" href="{{canonicalUrl}}" />

    <!-- Open Graph (Facebook, LinkedIn) -->
    <meta property="og:type" content="{{ogType}}" />
    <meta property="og:title" content="{{ogTitle}}" />
    <meta property="og:description" content="{{ogDescription}}" />
    <meta property="og:url" content="{{canonicalUrl}}" />
    <meta property="og:image" content="{{ogImage}}" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="article:published_time" content="{{publishedDate}}" />
    <meta property="article:modified_time" content="{{modifiedDate}}" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{twitterTitle}}">
    <meta name="twitter:description" content="{{twitterDescription}}">
    <meta name="twitter:image" content="{{twitterImage}}">

    <!-- JSON-LD Schema.org -->
    <script type="application/ld+json">
          {{{structuredData}}}
      </script>

    <link rel="icon" type="image/png" href="/static/img/favicon.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
    <link rel="stylesheet" href="https://fonts.googleapis.com/icon?family=Material+Icons">
    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">

    {{#if (isProd)}}
    <link href="/static/css/style.min.css" type="text/css" rel="stylesheet">
    <link rel="stylesheet" href="/static/cookiesBanner/silktide-consent-manager.min.css">
    {{else}}
    <link href="/static/css/style.css" type="text/css" rel="stylesheet">
    <link rel="stylesheet" href="/static/cookiesBanner/silktide-consent-manager.css">
    {{/if}}

    <!-- Google Tag Manager -->
    <script>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-W4VCLVRJ');
    </script>
    <!-- End Google Tag Manager -->
</head>

<body class="{{bodyClass}} d-flex flex-column min-vh-100">
    <!-- Google Tag Manager (noscript) -->
    <noscript>
      <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W4VCLVRJ"
    height="0" width="0" class="gtm-noscript-iframe"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <img src="/static/img/logo.png" alt="Logo">
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto"> <!-- ✅ Ça aligne le menu à droite -->
                    <li class="nav-item">
                        <a class="nav-link" href="/"><i class="fa-solid fa-balance-scale me-1"></i>Comparer</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/suivi"><i class="fa-solid fa-map-marker-alt me-1"></i>Suivi</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/mon-materiel"><i class="fa-solid fa-box me-1"></i>Matériel</a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown"
                            aria-expanded="false"><i class="fa-solid fa-lightbulb me-1"></i>
                            Conseils d'emballage
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/conseils">📦 Voir tous les conseils</a></li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            {{#each menuArticles}}
                            <li>
                                <a class="dropdown-item" href="/conseils/{{this.slug}}">
                                    {{this.menuTitle}}
                                </a>
                            </li>
                            {{/each}}
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="beta-banner" id="betaBanner">
        <div class="container">
            <div class="beta-content">
                <span class="beta-text">
                🚀 UniversColis est en constante évolution pour mieux répondre à vos besoins. Merci de votre confiance.
                </span>
            </div>
        </div>
    </div>

    {{{body}}}

    <footer class="text-white py-4">
        <div class="container">
            <div class="row">
                <!-- Logo et description -->
                <div class="col-md-4 mb-4">
                    <a href="/">
                        <img src="/static/img/logo.png" alt="UniversColis Logo" class="footer-logo mb-3">
                    </a>
                    <p class="footer-description">
                        Le meilleur de l’envoi, au même endroit.
                    </p>
                </div>

                <!-- Liens utiles -->
                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">
                        <i class="fa-solid fa-link me-2"></i>Nos Services
                    </h5>
                    <ul class="footer-links">
                        <li>
                            <a href="/">
                                <i class="fa-solid fa-balance-scale me-2"></i>Comparer les prix
                            </a>
                        </li>
                        <li>
                            <a href="/suivi">
                                <i class="fa-solid fa-map-marker-alt me-2"></i>Suivi de colis
                            </a>
                        </li>
                        <li>
                            <a href="/mon-materiel">
                                <i class="fa-solid fa-box me-2"></i>Matériel d'emballage
                            </a>
                        </li>
                        <li>
                            <a href="/conseils">
                                <i class="fa-solid fa-lightbulb me-2"></i>Conseils d'expédition
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Informations légales -->
                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">
                        <i class="fa-solid fa-info-circle me-2"></i>Informations
                    </h5>
                    <ul class="footer-links">
                        <li>
                            <a href="/comment-ca-marche">
                                <i class="fa-solid fa-question-circle me-2"></i>Comment ça marche
                            </a>
                        </li>
                        <li>
                            <a href="/qui-sommes-nous">
                                <i class="fa-solid fa-users me-2"></i>Qui sommes-nous
                            </a>
                        </li>
                        <li>
                            <a href="/politique-confidentialite">
                                <i class="fa-solid fa-shield-alt me-2"></i>Politique de confidentialité
                            </a>
                        </li>
                        <li>
                            <a href="/mentions-legales">
                                <i class="fa-solid fa-gavel me-2"></i>Mentions légales
                            </a>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Ligne de séparation -->
            <hr class="footer-divider">

            <!-- Copyright et contact -->
            <div class="row">
                <div class="col-md-6">
                    <p class="footer-copyright mb-0">
                        &copy; 2025 <strong>UniversColis</strong>. Tous droits réservés.
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="footer-contact mb-0">
                        <i class="fa-solid fa-envelope me-2"></i>
                        <a href="mailto:contact@universcolis.com">contact@universcolis.com</a>
                    </p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Le bouton de remontée en haut -->
    <button id="back-to-top" class="back-to-top">
        <i class="fa-solid fa-arrow-up"></i>
    </button>

    <!-- Script de remontée en haut -->

    <script src="/bootstrap/js/bootstrap.bundle.min.js"></script>

    {{#if isProd}}
      <script src="/static/js/static.min.js" defer></script>

      {{#if hasAutocomplete}}
        <script type="module" src="/static/js/autocomplete.min.js"></script>
      {{/if}}

      {{#if (eq page 'comparateur')}}
        <script id="offres-data" type="application/json">{{{json offres}}}</script>
        <script src="/static/js/redirect.min.js" defer></script>
        <script src="/static/js/comparateurFilters.min.js" defer></script>
      {{/if}}
      
      {{#if (eq page 'suivi')}}
        <script src="/static/js/suivi.min.js" defer></script>
      {{/if}}

      <!-- Scripts spécifiques cookies -->
      <script src="/static/cookiesBanner/silktide-consent-manager.min.js"></script>
      <script src="/static/js/cookiesConfig.min.js"></script>
      <script src="/static/js/cookiePreferencesButton.min.js"></script>

      <!-- Autres scripts -->
      <script src="/static/js/tabs.min.js" defer></script>
      <script src="/static/js/articleSelector.min.js" defer></script>
      <script src="/static/js/loading.min.js"></script>

    {{else}}
      <script src="/static/js/static.js" defer></script>

      {{#if hasAutocomplete}}
        <script type="module" src="/static/js/autocomplete.js"></script>
      {{/if}}

      {{#if (eq page 'comparateur')}}
        <script id="offres-data" type="application/json">{{{json offres}}}</script>
        <script src="/static/js/redirect.js" defer></script>
        <script src="/static/js/comparateurFilters.js" defer></script>  
      {{/if}}

      {{#if (eq page 'suivi')}}
        <script src="/static/js/suivi.js" defer></script>
      {{/if}}

      <!-- Scripts spécifiques cookies -->
      <script src="/static/cookiesBanner/silktide-consent-manager.js"></script>
      <script src="/static/js/cookiesConfig.js"></script>
      <script src="/static/js/cookiePreferencesButton.js"></script>

      <!-- Autres scripts -->
      <script src="/static/js/tabs.js" defer></script>
      <script src="/static/js/articleSelector.js" defer></script>
      <script src="/static/js/loading.js"></script>
    {{/if}}
</body>

</html>