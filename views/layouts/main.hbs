    <!-- Consent defaults (must be BEFORE GTM) -->
    <script>
        // Initialize dataLayer and gtag helper
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }

        // Optional: suffix Silktide si configuré (ex: '_fr'), sinon laissez vide
        var SILKTIDE_SUFFIX = '';
        function skKey(id) { return 'silktideCookieChoice_' + id + SILKTIDE_SUFFIX; }

        // Google Consent Mode v2 - valeurs par défaut
        (function () {
            try {
                var analyticsGranted = localStorage.getItem(skKey('analytics')) === 'true';
                var marketingGranted = localStorage.getItem(skKey('marketing')) === 'true';

                gtag('consent', 'default', {
                    // Analyse selon le choix Analytics
                    analytics_storage: analyticsGranted ? 'granted' : 'denied',
                    // Marketing selon le choix Marketing
                    ad_storage: marketingGranted ? 'granted' : 'denied',
                    ad_user_data: marketingGranted ? 'granted' : 'denied',
                    ad_personalization: marketingGranted ? 'granted' : 'denied',
                    // Nécessaires: toujours GRANTED (non désactivables)
                    functionality_storage: 'granted',
                    security_storage: 'granted'
                });
            } catch (e) { /* no-op */ }
        })();
    </script>

    {{#if isProd}}
    <!-- Google AdSense Auto Ads loader (prod) -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-5973618771807669"
        crossorigin="anonymous"></script>
    {{/if}}

    {{#if isProd}}
    <!-- Google Tag Manager -->
    <script>
        (function () {
            var gtmLoaded = false;

            function loadGTM() {
                if (gtmLoaded) return;
                gtmLoaded = true;

                (function (w, d, s, l, i) {
                    w[l] = w[l] || [];
                    w[l].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
                    var f = d.getElementsByTagName(s)[0],
                        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : '';
                    j.async = true;
                    j.src = 'https://www.googletagmanager.com/gtm.js?id=' + i + dl;
                    f.parentNode.insertBefore(j, f);
                })(window, document, 'script', 'dataLayer', 'GTM-W4VCLVRJ');
            }

            // Charge dès la première interaction (priorité)
            var events = ['click', 'scroll', 'touchstart', 'keydown', 'mousemove'];
            events.forEach(function (event) {
                document.addEventListener(event, loadGTM, { once: true, passive: true });
            });

            // Fallback : Si aucune interaction après 1 seconde
            if ('requestIdleCallback' in window) {
                requestIdleCallback(function () {
                    setTimeout(loadGTM, 1000);
                }, { timeout: 2000 });
            } else {
                setTimeout(loadGTM, 1000);
            }
        })();
    </script>
    {{/if}}

</head>

