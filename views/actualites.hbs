<!-- Contenu principal -->
<nav class="breadcrumb">
    <div class="container">
        <a href="/" class="breadcrumb-link">Accueil</a>
        <span class="mx-2">></span>
        <a href="/actualites" class="breadcrumb-link">Actualités</a>
        <span class="mx-2">></span>
        <span class="breadcrumb-current">{{title}}</span>
    </div>
</nav>


<div class="article-container mt-3">

    <!-- Header de l'article -->
    <header class="article-header">
        <div class="article-meta">
            <div class="article-date">
                <i class="fa-regular fa-calendar"></i>
                <span>{{formatDate publishedDate}}</span>
            </div>
            <div class="article-category">{{keyWord}}</div>
        </div>
        <h1 class="article-title">{{title}}</h1>
        <p class="article-lead">
        </p>
        {{#if readingTime}}
        <p class="reading-time"><i class="fa-regular fa-clock"></i> {{readingTime}} min de lecture</p>
        {{/if}}
    </header>

    {{!-- EZOIC AD #1 : Under page title --}}
    {{#if showEzoic}}
    <div id="ezoic-pub-ad-placeholder-102"></div>
    {{/if}}

    <!-- Contenu de l'article -->
    <article class="article-content">
        <!-- Image illustrative -->
        <a href="/static/img/actualitesImg/{{actualiteImg}}" class="glightbox article-image-link"
            data-gallery="actualites-gallery" data-title="{{actualiteImgAlt}}">
            <img src="/static/img/actualitesImg/{{actualiteImg}}" alt="{{actualiteImgAlt}}"
                class="article-image article-image-right" width="1200" height="675" fetchpriority="high">
        </a>

        <div class="article-text">
            {{#each paragraphs}}

            {{!-- EZOIC AD : après le 5ème paragraphe (index 4 = 5ème élément) --}}
            {{#if (eq @index 3)}}
            <div id="ezoic-pub-ad-placeholder-109"></div>
            {{/if}}

            {{#if (eq @index 7)}}
            <div id="ezoic-pub-ad-placeholder-110"></div>
            {{/if}}

            {{#if (eq @index 11)}}
            <div id="ezoic-pub-ad-placeholder-111"></div>
            {{/if}}

            {{/each}}

            {{#if this.pTitle}}
            <h3>{{this.pTitle}}</h3>
            {{/if}}

            {{#if this.isTable}}
            <table class="article-table">
                <thead>
                    <tr>
                        {{#each this.table.headers}}
                        <th>{{{this}}}</th>
                        {{/each}}
                    </tr>
                </thead>
                <tbody>
                    {{#each this.table.rows}}
                    <tr>
                        {{#each this}}
                        <td>{{{this}}}</td>
                        {{/each}}
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            {{#if this.hasLinks}}
            <p>{{{parseMarkdownLinks this.text}}}</p>
            {{else}}
            <p>{{{this.text}}}</p>
            {{/if}}
            {{#if this.list}}
            <ul>
                {{#each this.list}}
                <li>
                    {{#if ../hasLinks}}
                    {{{parseMarkdownLinks this}}}
                    {{else}}
                    {{{this}}}
                    {{/if}}
                </li>
                {{/each}}
            </ul>
            {{/if}}
            {{/if}}
            {{/each}}
        </div>

        {{#if faq.length}}
        <section class="faq-section" id="faq">
            <h2 class="text-center mb-4">L'essentiel à retenir</h2>
            <div class="accordion" id="faqAccordion">
                {{#each faq}}
                <div class="accordion-item">
                    <h3 class="accordion-header" id="faq{{@index}}">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#answer{{@index}}">
                            <strong>{{this.question}}</strong>
                        </button>
                    </h3>
                    <div id="answer{{@index}}" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            {{#if this.responses.[1]}}
                            <ul class="faq-list">
                                {{#each this.responses}}
                                <li>{{{parseMarkdownLinks this}}}</li>
                                {{/each}}
                            </ul>
                            {{else}}
                            <p>{{{parseMarkdownLinks this.responses.[0]}}}</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </section>
        {{/if}}

        {{#if sources.length}}
        <div class="article-sources">
            <h3>Sources</h3>
            <ul>
                {{#each sources}}
                <li>
                    {{#if this.hasLinks}}
                    {{{parseMarkdownLinks this.name}}}
                    {{else}}
                    <strong>{{this.name}}</strong>
                    {{/if}}
                    {{#if this.article}}
                    {{this.article}}
                    {{/if}}
                </li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

        <!-- CTA vers le comparateur -->
        <div class="article-cta">
            <h3 class="cta-title">Trouvez des alternatives moins chères</h3>
            <a href="/" class="cta-button">
                <i class="fa-solid fa-search"></i>
                Comparer les tarifs maintenant
            </a>
        </div>
    </article>

    {{!-- EZOIC AD #2 : Fin d'article --}}
    {{#if showEzoic}}
    <div id="ezoic-pub-ad-placeholder-103"></div>
    {{/if}}

    <!-- Navigation entre articles -->
    <nav class="article-navigation">
        {{#if prevSlug}}
        <a href="/actualites/{{prevSlug}}" class="nav-link">
            <i class="fa-solid fa-arrow-left"></i>
            <span>Article précédent</span>
        </a>
        {{/if}}

        <a href="/actualites" class="nav-back-home">
            <i class="fa-solid fa-list"></i>
            Toutes les actualités
        </a>

        {{#if nextSlug}}
        <a href="/actualites/{{nextSlug}}" class="nav-link next">
            <span>Article suivant</span>
            <i class="fa-solid fa-arrow-right"></i>
        </a>
        {{/if}}
    </nav>
</div>

<!-- ===== SECTION À DÉCOUVRIR (HBS) ===== -->
<section class="related-links py-5">
    <div class="decouvrir-container">
        <div class="text-center mb-4">
            <h3 class="related-title">Découvrez l'univers du colis</h3>
            <p class="related-subtitle">Comparaison, conseils, matériel, suivi : tout pour réussir vos envois</p>
        </div>

        <div class="row g-4">
            <!-- Comparateur de prix -->
            <div class="col-md-3">
                <a href="/" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-balance-scale"></i>
                    </div>
                    <h4 class="link-title">Comparer les prix</h4>
                    <p class="link-description">Trouvez le meilleur tarif pour votre expédition</p>
                    <span class="link-action">
                        Comparer maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Suivi de colis -->
            <div class="col-md-3">
                <a href="/suivi" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-map-marker-alt"></i>
                    </div>
                    <h4 class="link-title">Suivre mon colis</h4>
                    <p class="link-description">Suivez votre expédition en temps réel</p>
                    <span class="link-action">
                        Suivre maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Matériel d'emballage -->
            <div class="col-md-3">
                <a href="/mon-materiel" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-box"></i>
                    </div>
                    <h4 class="link-title">Matériel d'emballage</h4>
                    <p class="link-description">Découvrez le matériel essentiel pour emballer</p>
                    <span class="link-action">
                        Voir le matériel <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Conseils d'emballage -->
            <div class="col-md-3">
                <a href="/conseils" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-lightbulb"></i>
                    </div>
                    <h4 class="link-title">Conseils d'emballage</h4>
                    <p class="link-description">Astuces pour un emballage réussi</p>
                    <span class="link-action">
                        Lire les conseils <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- FAQ -->

            <div class="col-md-3">
                <a href="/questions" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-question-circle"></i>
                    </div>
                    <h4 class="link-title">Questions fréquentes</h4>
                    <p class="link-description">Toutes les réponses aux questions que vous vous posez sur l'expédition
                    </p>
                    <span class="link-action">
                        Voir la FAQ <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            {{!--
            <!-- Services à venir -->
            <div class="col-md-3">
                <div class="link-card coming-soon">
                    <div class="link-icon">
                        <i class="fa-solid fa-hourglass-half"></i>
                    </div>
                    <h4 class="link-title">Services à venir</h4>
                    <p class="link-description">De nouveaux services arrivent bientôt</p>
                    <span class="link-action">
                        Bientôt disponible <i class="fa-solid fa-clock ms-1"></i>
                    </span>
                </div>
            </div> --}}
        </div>

        <!-- Call-to-action principal -->
        <div class="text-center mt-5">
            <div class="main-cta">
                <h4 class="cta-title">Prêt à expédier votre colis ?</h4>
                <p class="cta-subtitle">Comparez les prix et trouvez la meilleure offre en quelques clics</p>
                <a href="/" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-rocket me-2"></i>Commencer maintenant
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Bouton partager l'article -->
<button id="share-article" class="share-article-btn" title="Partager l'article">
    <i class="fa-solid fa-share"></i>
</button>



{{!-- EZOIC SCRIPT --}}
{{#if showEzoic}}
<script>
    ezstandalone.cmd.push(function () {
        ezstandalone.showAds(102, 103, 109, 110, 111);
    });
</script>
{{/if}}