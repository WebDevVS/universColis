<!-- Contenu principal -->
<nav class="breadcrumb">
    <div class="container">
        <a href="/" class="breadcrumb-link">Accueil</a>
        <span class="mx-2">></span>
        <a href="/actualites" class="breadcrumb-link">Actualités</a>
        <span class="mx-2">></span>
        <span class="breadcrumb-current">{{title}}</span>
    </div>
</nav>


<div class="article-container mt-3">

    <!-- Header de l'article -->
    <header class="article-header">
        <div class="article-meta">
            <div class="article-date">
                <i class="fa-regular fa-calendar"></i>
                <span>{{formatDate publishedDate}}</span>
            </div>
            <div class="article-category">{{keyWord}}</div>
        </div>
        <h1 class="article-title">{{title}}</h1>
        <p class="article-lead">
        </p>
        {{#if readingTime}}
        <p class="reading-time"><i class="fa-regular fa-clock"></i> {{readingTime}} min de lecture</p>
        {{/if}}
    </header>

    {{!-- EZOIC AD #1 : Under page title --}}
    {{#if showEzoic}}
    <div id="ezoic-pub-ad-placeholder-102"></div>
    {{/if}}

    <!-- Contenu de l'article -->
    <article class="article-content">
        <!-- Image illustrative -->
        <a href="/static/img/actualitesImg/{{actualiteImg}}" class="glightbox article-image-link"
            data-gallery="actualites-gallery" data-title="{{actualiteImgAlt}}">
            <img src="/static/img/actualitesImg/{{actualiteImg}}" alt="{{actualiteImgAlt}}"
                class="article-image article-image-right" width="1200" height="675" fetchpriority="high" loading="eager">
        </a>

        <div class="article-text">
            {{#each paragraphs}}

            {{!-- EZOIC AD : après le 5ème paragraphe (index 4 = 5ème élément) --}}
            {{#if (eq @index 3)}}
                {{#if showEzoic}}
                <div id="ezoic-pub-ad-placeholder-109"></div>
                {{/if}}
            {{/if}}

            {{#if (eq @index 7)}}
                {{#if showEzoic}}
                <div id="ezoic-pub-ad-placeholder-110"></div>
                {{/if}}
            {{/if}}

            {{#if (eq @index 11)}}
                {{#if showEzoic}}
                <div id="ezoic-pub-ad-placeholder-111"></div>
                {{/if}}
            {{/if}}

            {{#if this.pTitle}}
            <h3>{{this.pTitle}}</h3>
            {{/if}}

            {{#if this.isTable}}
            <table class="article-table">
                <thead>
                    <tr>
                        {{#each this.table.headers}}
                        <th>{{{this}}}</th>
                        {{/each}}
                    </tr>
                </thead>
                <tbody>
                    {{#each this.table.rows}}
                    <tr>
                        {{#each this}}
                        <td>{{{this}}}</td>
                        {{/each}}
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            {{#if this.hasLinks}}
            <p>{{{parseMarkdownLinks this.text}}}</p>
            {{else}}
            <p>{{{this.text}}}</p>
            {{/if}}
            {{#if this.list}}
            <ul>
                {{#each this.list}}
                <li>
                    {{#if ../hasLinks}}
                    {{{parseMarkdownLinks this}}}
                    {{else}}
                    {{{this}}}
                    {{/if}}
                </li>
                {{/each}}
            </ul>
            {{/if}}
            {{/if}}
            {{/each}}
        </div>

        {{#if faq.length}}
        <section class="faq-section" id="faq">
            <h2 class="text-center mb-4">L'essentiel à retenir</h2>
            <div class="accordion" id="faqAccordion">
                {{#each faq}}
                <div class="accordion-item">
                    <h3 class="accordion-header" id="faq{{@index}}">
                        <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                            data-bs-target="#answer{{@index}}">
                            <strong>{{this.question}}</strong>
                        </button>
                    </h3>
                    <div id="answer{{@index}}" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body">
                            {{#if this.responses.[1]}}
                            <ul class="faq-list">
                                {{#each this.responses}}
                                <li>{{{parseMarkdownLinks this}}}</li>
                                {{/each}}
                            </ul>
                            {{else}}
                            <p>{{{parseMarkdownLinks this.responses.[0]}}}</p>
                            {{/if}}
                        </div>
                    </div>
                </div>
                {{/each}}
            </div>
        </section>
        {{/if}}

        {{#if sources.length}}
        <div class="article-sources">
            <h3>Sources</h3>
            <ul>
                {{#each sources}}
                <li>
                    {{#if this.hasLinks}}
                    {{{parseMarkdownLinks this.name}}}
                    {{else}}
                    <strong>{{this.name}}</strong>
                    {{/if}}
                    {{#if this.article}}
                    {{this.article}}
                    {{/if}}
                </li>
                {{/each}}
            </ul>
        </div>
        {{/if}}

    </article>

    {{!-- EZOIC AD #2 : Fin d'article --}}
    {{#if showEzoic}}
    <div id="ezoic-pub-ad-placeholder-103"></div>
    {{/if}}

    <!-- Navigation entre articles -->
    <nav class="article-navigation">
        {{#if prevSlug}}
        <a href="/actualites/{{prevSlug}}" class="nav-link">
            <i class="fa-solid fa-arrow-left"></i>
            <span>Article précédent</span>
        </a>
        {{/if}}

        <a href="/actualites" class="nav-back-home">
            <i class="fa-solid fa-list"></i>
            Toutes les actualités
        </a>

        {{#if nextSlug}}
        <a href="/actualites/{{nextSlug}}" class="nav-link next">
            <span>Article suivant</span>
            <i class="fa-solid fa-arrow-right"></i>
        </a>
        {{/if}}
    </nav>
</div>

<!-- Section "À découvrir" CONTEXTUELLE  -->
   {{> related-links/_base pageType="actualite-detail"}} 

<!-- Bouton partager l'article -->
<button id="share-article" class="share-article-btn" title="Partager l'article">
    <i class="fa-solid fa-share"></i>
</button>



{{!-- EZOIC SCRIPT --}}
{{#if showEzoic}}
<script>
    ezstandalone.cmd.push(function () {
        ezstandalone.showAds(102, 103, 109, 110, 111);
    });
</script>
{{/if}}