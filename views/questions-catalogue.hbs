    <div class="container">
        <a href="/" class="breadcrumb-link">Accueil</a>
        <span class="mx-2">></span>
        <span class="breadcrumb-current">Questions</span>
    </div>
</nav>

<!-- Hero compact -->
<section class="questions-hero">
    <h1 class="hero-title">Vos questions sur l'envoi de colis</h1>
    <p class="hero-subtitle">
        Parcourez nos catégories pour trouver toutes les réponses dont vous avez besoin
    </p>
</section>

