<nav class="sticky-nav" aria-label="Navigation">
  <div class="snav-inner">
    {{#each article.parts}}
    <a href="#{{this.id}}" class="sn {{#if @first}}active{{/if}}" data-part="{{this.partNum}}">
      <span class="sn-dot"></span>{{this.label}}
    </a>
    {{/each}}
  </div>
</nav>

<div class="page">

  {{!-- ════════════════════════════════════════════
    EN BREF
  ════════════════════════════════════════════ --}}
  <div class="en-bref">
    <div class="en-bref-label">✦ En bref</div>
    <p class="en-bref-text">{{article.enBref.text}}</p>
    <div class="en-bref-pills">
      {{#each article.enBref.pills}}
      <span class="eb-pill">{{this}}</span>
      {{/each}}
    </div>
  </div>

  {{!-- ════════════════════════════════════════════
    PARTIES
  ════════════════════════════════════════════ --}}
  {{#each article.parts}}
  <div id="{{this.id}}" class="section-gap p{{this.partNum}}">

    {{!-- PART HEADER --}}
    <div class="part-header p{{this.partNum}}">
      <div class="part-num">{{this.partNum}}</div>
      <div>
        <div class="part-tag">{{this.label}}</div>
        <h2>{{this.title}}</h2>
        <p>{{this.intro}}</p>
      </div>
    </div>

    {{!-- SECTIONS --}}
    {{#each this.sections}}
    <div class="prose">

      {{#if this.h3}}
      <h3>{{this.h3}}</h3>
      {{/if}}

      {{!-- ── DISPATCH DES BLOCS ── --}}
      {{#each this.blocks}}

        {{!-- texte --}}
        {{#if (eq this.type "texte")}}
          <p>{{{this.text}}}</p>

        {{!-- info-box --}}
        {{else if (eq this.type "info-box")}}
          <div class="callout {{this.variant}}">
            <div class="callout-ico">{{this.icon}}</div>
            <div class="callout-body">
              <strong>{{this.title}}</strong>
              {{this.text}}
            </div>
          </div>

        {{!-- texte-image --}}
        {{else if (eq this.type "texte-image")}}
          <div class="step-with-img">
            <div>
              {{#each this.prose}}
              <p>{{{this}}}</p>
              {{/each}}
            </div>
            <div class="step-img-col">
              <img src="/static/img/articleImg/{{this.img}}"
                   alt="{{this.imgAlt}}"
                   class="step-img-real"
                   loading="lazy">
              {{#if this.caption}}
              <div class="step-caption-txt">{{this.caption}}</div>
              {{/if}}
            </div>
          </div>

        {{!-- info-cas-particulier --}}
        {{else if (eq this.type "info-cas-particulier")}}
          <div class="special-case">
            <strong>{{this.title}}</strong>
            {{this.text}}
          </div>

        {{!-- conseils-erreurs --}}
        {{else if (eq this.type "conseils-erreurs")}}
          <div class="tips-wrap">
            <div class="tips-head">
              <div class="tips-col-lbl g">✓ À faire</div>
              <div class="tips-col-lbl b">✗ À éviter</div>
            </div>
            {{#each this.pairs}}
            <div class="tips-pair">
              <div class="tip-c g"><span>✓</span><span>{{this.good}}</span></div>
              <div class="tip-c b"><span>✗</span><span>{{this.bad}}</span></div>
            </div>
            {{/each}}
          </div>

        {{!-- etapes → partial (récursif) --}}
        {{else if (eq this.type "etapes")}}
          {{> guide-blocks/etapes block=this}}

        {{!-- formula-box → partial --}}
        {{else if (eq this.type "formula-box")}}
          {{> guide-blocks/formula-box block=this}}

        {{!-- schema-couches → partial --}}
        {{else if (eq this.type "schema-couches")}}
          {{> guide-blocks/schema-couches block=this}}

        {{!-- grid-cartes → partial --}}
        {{else if (eq this.type "grid-cartes")}}
          {{> guide-blocks/grid-cartes block=this}}

        {{!-- tableau → partial --}}
        {{else if (eq this.type "tableau")}}
          {{> guide-blocks/tableau block=this}}

        {{!-- tableau-mat → partial --}}
        {{else if (eq this.type "tableau-mat")}}
          {{> guide-blocks/tableau-mat block=this}}

        {{!-- flow-decision → partial --}}
        {{else if (eq this.type "flow-decision")}}
          {{> guide-blocks/flow-decision block=this}}

        {{!-- timeline-etapes → partial --}}
        {{else if (eq this.type "timeline-etapes")}}
          {{> guide-blocks/timeline-etapes block=this}}

        {{!-- grid-cartons → partial --}}
        {{else if (eq this.type "grid-cartons")}}
          {{> guide-blocks/grid-cartons block=this}}

        {{!-- procedure → partial --}}
        {{else if (eq this.type "procedure")}}
          {{> guide-blocks/procedure block=this}}

        {{!-- grid-cout → partial --}}
        {{else if (eq this.type "grid-cout")}}
          {{> guide-blocks/grid-cout block=this}}

        {{/if}}
      {{/each}}
      {{!-- ── FIN DISPATCH ── --}}

    </div>
    {{/each}}
    {{!-- FIN SECTIONS --}}

    {{!-- TRANSITION --}}
    {{#if this.transition}}
    <div class="part-transition">{{this.transition}}</div>
    {{/if}}

  </div>
  {{/each}}
  {{!-- FIN PARTIES --}}

  {{!-- ════════════════════════════════════════════
    FAQ
  ════════════════════════════════════════════ --}}
  {{#if article.faq}}
  <div class="prose section-gap">
    <h3>FAQ</h3>
    <div class="faq-list">
      {{#each article.faq}}
      <div class="faq-item">
        <button class="faq-q" onclick="toggleFaq(this)">
          {{this.question}}<span class="faq-chev">▼</span>
        </button>
        <div class="faq-a">
          {{#each this.responses}}
          <p>{{this.text}}</p>
          {{/each}}
        </div>
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
    UPDATE NOTE
  ════════════════════════════════════════════ --}}
  {{#if article.updateNote}}
  <div style="max-width:960px;margin:1.25rem auto 0;background:var(--light);border-radius:var(--rsm);padding:0.9rem 1.25rem;font-size:0.8rem;color:var(--muted);line-height:1.6;border-left:3px solid rgba(0,0,0,0.1);">
    <strong style="color:var(--text);font-family:'Sora',sans-serif;font-size:0.8rem;">Dernière mise à jour</strong><br>
    {{article.updateNote}}
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
    SOURCES
  ════════════════════════════════════════════ --}}
  {{#if article.sources}}
  <div class="sources">
    <strong>Sources principales</strong>
    <ul>
      {{#each article.sources}}
      <li>
        {{#if this.url}}
        <a href="{{this.url}}" target="_blank" rel="nofollow noopener">{{this.name}}</a>
        {{else}}
        {{this.name}}
        {{/if}}
        {{#if this.article}} — {{this.article}}{{/if}}
      </li>
      {{/each}}
    </ul>
  </div>
  {{/if}}

  {{!-- ════════════════════════════════════════════
    AFFILIATION
  ════════════════════════════════════════════ --}}
  <div class="affil">
    <span style="color:var(--violet);font-size:1rem;flex-shrink:0;margin-top:1px;">ℹ</span>
    <span>Certains liens sur cette page sont affiliés. Nous pouvons toucher une commission
    sans coût supplémentaire pour vous, ce qui nous aide à maintenir nos services gratuits.</span>
  </div>

</div>{{!-- /page --}}




<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Envoyer des bougies par colis en 2026 : emballage, chaleur, règles et transporteurs – UniversColis</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Lora:ital,wght@0,400;1,400&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --violet: #8269A4; --violet-l: rgba(130,105,164,0.10); --violet-m: rgba(130,105,164,0.22);
  --coral: #FA7E75; --coral-l: rgba(250,126,117,0.09);
  --bg: #E9E6E1; --white: #fff; --text: #1e1e1e; --muted: #666; --light: #f7f5f2;
  --success: #1a5f17; --success-bg: rgba(31,162,22,0.07); --success-bd: rgba(31,162,22,0.22);
  --warn: #7a4f00; --warn-bg: rgba(255,160,0,0.09); --warn-bd: rgba(255,160,0,0.28);
  --danger: #8a0000; --danger-bg: rgba(204,0,0,0.06); --danger-bd: rgba(204,0,0,0.18);
  --r: 16px; --rsm: 10px;
  --p1: #5B7FA0; --p1-l: rgba(91,127,160,0.10); --p1-m: rgba(91,127,160,0.22);
  --p2: #C4843A; --p2-l: rgba(196,132,58,0.10); --p2-m: rgba(196,132,58,0.22);
  --p3: #6A9E7F; --p3-l: rgba(106,158,127,0.10); --p3-m: rgba(106,158,127,0.22);
}
body { font-family:'DM Sans',sans-serif; background:var(--bg); color:var(--text); font-size:16px; line-height:1.7; padding-bottom:3rem; }

/* ── BREADCRUMB ── */
.bc { padding:14px 20px; font-size:0.8rem; color:var(--muted); display:flex; align-items:center; gap:6px; max-width:960px; margin:0 auto; flex-wrap:wrap; }
.bc a { color:var(--violet); text-decoration:none; font-weight:500; }
.bc a:hover { text-decoration:underline; }

/* ── HERO ── */
.hero { max-width:960px; margin:0 auto; padding:2.5rem 2.5rem 0; position:relative; }
.hero-eyebrow { display:inline-flex; align-items:center; gap:7px; background:rgba(130,105,164,0.10); border:1px solid rgba(130,105,164,0.2); border-radius:20px; padding:4px 14px; font-size:0.73rem; font-weight:700; letter-spacing:0.07em; text-transform:uppercase; color:var(--violet); margin-bottom:1.2rem; }
.hero h1 { font-family:'Sora',sans-serif; font-size:clamp(1.6rem,3.8vw,2.4rem); font-weight:800; line-height:1.15; max-width:700px; margin-bottom:0.75rem; color:var(--text); }
.hero-tricolor { display:flex; gap:4px; margin-bottom:1.1rem; }
.hero-tricolor span { height:4px; border-radius:2px; }
.hero-tricolor span:nth-child(1){width:64px;background:var(--p1);}
.hero-tricolor span:nth-child(2){width:44px;background:var(--p2);}
.hero-tricolor span:nth-child(3){width:54px;background:var(--p3);}
.hero-lead { font-family:'Lora',serif; font-size:1rem; line-height:1.75; color:var(--muted); max-width:600px; margin-bottom:1.5rem; font-style:italic; }
.hero-meta { display:flex; flex-wrap:wrap; gap:10px; padding-bottom:1.75rem; }
.hero-pill { background:white; border:1px solid rgba(0,0,0,0.1); border-radius:20px; padding:5px 14px; font-size:0.82rem; font-weight:600; color:var(--muted); box-shadow:0 1px 4px rgba(0,0,0,0.05); }
.hero-bottom { background:white; border-radius:var(--r) var(--r) 0 0; margin:0 -2.5rem; padding:1.5rem 2.5rem 0; }
.hero-bottom-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:rgba(0,0,0,0.06); border-radius:var(--rsm) var(--rsm) 0 0; overflow:hidden; }
.hb-col { background:var(--light); padding:1rem 1.25rem; font-size:0.82rem; color:var(--muted); line-height:1.5; border-top:3px solid transparent; text-decoration:none; display:block; transition:background .2s; }
.hb-col:hover { background:white; }
.hb-col:nth-child(1){border-top-color:var(--p1);}
.hb-col:nth-child(2){border-top-color:var(--p2);}
.hb-col:nth-child(3){border-top-color:var(--p3);}
.hb-col strong { display:block; font-family:'Sora',sans-serif; font-size:0.85rem; color:var(--text); margin-bottom:3px; }

/* ── STICKY NAV ── */
.sticky-nav { position:sticky; top:0; z-index:100; background:rgba(255,255,255,0.96); backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px); border-bottom:1px solid var(--violet-m); margin-bottom:2rem; }
.snav-inner { max-width:960px; margin:0 auto; display:flex; overflow-x:auto; scrollbar-width:none; }
.snav-inner::-webkit-scrollbar{display:none;}
.sn { display:flex; align-items:center; gap:7px; padding:14px 20px; font-family:'Sora',sans-serif; font-size:0.8rem; font-weight:600; color:var(--muted); text-decoration:none; white-space:nowrap; border-bottom:3px solid transparent; transition:color .2s,border-color .2s; }
.sn:hover{color:var(--violet);}
.sn.active{color:var(--violet);border-bottom-color:var(--violet);}
.sn.active[data-part="1"]{color:var(--p1);border-bottom-color:var(--p1);}
.sn.active[data-part="2"]{color:var(--p2);border-bottom-color:var(--p2);}
.sn.active[data-part="3"]{color:var(--p3);border-bottom-color:var(--p3);}
.sn-dot{width:8px;height:8px;border-radius:50%;background:rgba(130,105,164,0.2);flex-shrink:0;transition:background .2s;}
.sn.active .sn-dot{background:var(--violet);}
.sn.active[data-part="1"] .sn-dot{background:var(--p1);}
.sn.active[data-part="2"] .sn-dot{background:var(--p2);}
.sn.active[data-part="3"] .sn-dot{background:var(--p3);}

/* ── PAGE ── */
.page { max-width:960px; margin:0 auto; padding:0 0 3rem; }
.section-gap { margin-bottom:2.25rem; }
.p1{--pc:var(--p1);}
.p2{--pc:var(--p2);}
.p3{--pc:var(--p3);}
.part-transition { text-align:center; padding:0.5rem 0 1.75rem; font-family:'Lora',serif; font-size:0.92rem; font-style:italic; color:var(--muted); }

/* ── EN BREF ── */
.en-bref { background:white; border-radius:var(--r); padding:1.75rem 2rem; margin:0 auto 2rem; box-shadow:0 2px 18px rgba(0,0,0,0.04); border-top:4px solid var(--violet); }
.en-bref-label { display:inline-flex; align-items:center; gap:6px; font-family:'Sora',sans-serif; font-size:0.71rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:var(--violet); margin-bottom:1rem; }
.en-bref-text { font-family:'Lora',serif; font-size:1rem; line-height:1.75; color:var(--text); font-style:italic; margin-bottom:1.25rem; }
.en-bref-pills { display:flex; flex-wrap:wrap; gap:8px; }
.eb-pill { background:var(--violet-l); border-radius:20px; padding:5px 14px; font-size:0.83rem; color:var(--violet); font-weight:500; border:1px solid var(--violet-m); }

/* ── PART HEADER ── */
.part-header { background:color-mix(in srgb,var(--pc) 5%,white); border-radius:var(--r); padding:1.75rem 2rem; margin-bottom:1.25rem; border-left:5px solid var(--pc); display:flex; align-items:flex-start; gap:1.25rem; box-shadow:0 2px 18px rgba(0,0,0,0.04); }
.part-num { font-family:'Sora',sans-serif; font-size:2.5rem; font-weight:800; color:var(--pc); opacity:0.25; line-height:1; flex-shrink:0; margin-top:-4px; }
.part-tag { display:inline-block; background:color-mix(in srgb,var(--pc) 12%,transparent); color:var(--pc); border-radius:20px; padding:3px 12px; font-size:0.7rem; font-weight:700; letter-spacing:0.06em; text-transform:uppercase; margin-bottom:6px; }
.part-header h2 { font-family:'Sora',sans-serif; font-size:1.3rem; font-weight:800; color:var(--text); margin-bottom:0.4rem; }
.part-header p { font-size:0.9rem; color:var(--muted); line-height:1.6; margin:0; }

/* ── PROSE ── */
.prose { background:white; border-radius:var(--r); padding:2rem; margin-bottom:1.25rem; box-shadow:0 2px 18px rgba(0,0,0,0.04); }
.p1 .prose { border-left:3px solid color-mix(in srgb,var(--p1) 35%,transparent); }
.p2 .prose { border-left:3px solid color-mix(in srgb,var(--p2) 35%,transparent); }
.p3 .prose { border-left:3px solid color-mix(in srgb,var(--p3) 35%,transparent); }
.prose h3 { font-family:'Sora',sans-serif; font-size:1.03rem; font-weight:700; color:var(--text); margin-bottom:0.75rem; margin-top:1.5rem; }
.prose h3:first-child{margin-top:0;}
.prose p { font-size:0.93rem; color:var(--text); line-height:1.75; margin-bottom:0.9rem; }
.prose p:last-child{margin-bottom:0;}
.prose strong{font-weight:600;}
.prose ul { list-style:none; padding:0; display:flex; flex-direction:column; gap:5px; margin:0.75rem 0; }
.prose ul li { font-size:0.91rem; color:var(--text); padding-left:20px; position:relative; line-height:1.6; }
.prose ul li::before { content:'—'; position:absolute; left:0; color:var(--pc,var(--violet)); font-weight:700; }
.prose a { color:var(--pc,var(--violet)); font-weight:500; }

/* ── CALLOUT ── */
.callout { border-radius:var(--rsm); padding:1rem 1.25rem; margin:1.1rem 0; font-size:0.88rem; line-height:1.65; display:flex; align-items:flex-start; gap:12px; }
.callout-ico{font-size:1.1rem;flex-shrink:0;margin-top:1px;}
.callout-body{flex:1;}
.callout-body strong { display:block; font-family:'Sora',sans-serif; font-size:0.78rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px; }
.callout.warn{background:var(--warn-bg);border-left:3px solid #ffa000;color:var(--warn);}
.callout.warn strong{color:#b37700;}
.callout.info,.callout.tip { background:color-mix(in srgb,var(--pc,var(--violet)) 9%,white); border-left:3px solid var(--pc,var(--violet)); }
.callout.info strong,.callout.tip strong{color:var(--pc,var(--violet));}
.callout.danger{background:var(--danger-bg);border-left:3px solid var(--danger);color:var(--danger);}
.callout.danger strong{color:var(--danger);}

/* ── DECISION SCHEMA ── */
.decision-schema { display:flex; flex-direction:column; gap:8px; margin:1.1rem 0; }
.ds-branch { display:flex; align-items:flex-start; gap:12px; background:white; border-radius:var(--rsm); padding:12px 16px; border-left:4px solid transparent; }
.ds-branch.solid{border-left-color:var(--success);}
.ds-branch.coffret{border-left-color:var(--p2);}
.ds-branch.mixte{border-left-color:var(--danger);}
.ds-icon{font-size:1.2rem;flex-shrink:0;margin-top:1px;}
.ds-content{flex:1;}
.ds-label{font-family:'Sora',sans-serif;font-size:0.85rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.ds-action{font-size:0.8rem;color:var(--muted);line-height:1.5;}

/* ── RISK CARDS ── */
.risk-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin:1.1rem 0; justify-items:center; }
.risk-card { border-radius:var(--rsm); overflow:hidden; border:1.5px solid rgba(0,0,0,0.07); background:white; transition:box-shadow .2s; }
.risk-card:hover{box-shadow:0 4px 14px rgba(0,0,0,0.08);}
.risk-card-ph { width:100%; height:180px; background:var(--light); overflow: hidden; display:block; align-items:center; justify-content:center; font-size:0.75rem; color:var(--muted); text-align:center; border-bottom:1px solid rgba(0,0,0,0.05); }
.risk-card-body{padding:1rem;}
.risk-badge { display:inline-block; font-size:0.80rem; font-weight:700; border-radius:8px; padding:2px 9px; margin-bottom:6px; }
.risk-badge.casse{background:var(--danger-bg);color:var(--danger);}
.risk-badge.chaleur{background:var(--warn-bg);color:var(--warn);}
.risk-badge.chocs{background:var(--violet-l);color:var(--violet);}
.risk-card-title{font-family:'Sora',sans-serif;font-size:0.88rem;font-weight:700;color:var(--text);margin-bottom:4px;}
.risk-card-when{font-size:0.77rem;color:var(--muted);margin-bottom:5px;line-height:1.45;}
.risk-card-consequence{font-size:0.77rem;color:var(--text);line-height:1.5;}

.risk-card {
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  overflow: hidden;
  width: 280px;
  display: flex;
  flex-direction: column;
}

.risk-card-ph img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.risk-card-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

/* ── STEP WITH IMG ── */
.step-with-img { display:grid; grid-template-columns:1fr 200px; gap:16px; align-items:start; margin-bottom:0.75rem; }
.step-img-col{display:flex;flex-direction:column;gap:6px;justify-self:center;max-width:200px;}
.step-img-ph { width:100%; aspect-ratio:4/3; background:var(--light); border-radius:var(--rsm); display:flex; align-items:center; justify-content:center; font-size:0.75rem; color:var(--muted); text-align:center; border:1.5px dashed rgba(0,0,0,0.1); }
.step-caption-txt{font-size:0.75rem;font-style:italic;color:var(--muted);line-height:1.5;}

/* ── TEMP VISUAL ── */
.temp-visual { display:flex; align-items:stretch; margin:1.1rem 0; background:white; border-radius:var(--rsm); overflow:hidden; border:1.5px solid rgba(0,0,0,0.07); }
.temp-col { flex:1; padding:1.25rem; text-align:center; display:flex; flex-direction:column; justify-content:center; }
.temp-col.outside{background:color-mix(in srgb,var(--p1) 10%,white);}
.temp-col.inside{background:color-mix(in srgb,var(--coral) 10%,white);}
.temp-divider { display:flex; align-items:center; padding:0 0.5rem; color:var(--coral); font-size:1.5rem; font-weight:700; }
.temp-val { font-family:'Sora',sans-serif; font-size:2rem; font-weight:800; line-height:1; }
.temp-col.outside .temp-val{color:var(--p1);}
.temp-col.inside .temp-val{color:var(--coral);}
.temp-lbl { font-size:0.78rem; color:var(--muted); margin-top:4px; line-height:1.4; }
.temp-caption { text-align:center; font-size:0.75rem; color:var(--muted); font-style:italic; padding:0.5rem 1rem 0.75rem; background:white; border-top:1px solid rgba(0,0,0,0.05); }

/* ── WAX TABLE ── */
.table-wrap { overflow-x:auto; margin:1.1rem 0; -webkit-overflow-scrolling:touch; border-radius:var(--rsm); }
.data-table { width:100%; border-collapse:separate; border-spacing:0 4px; min-width:420px; }
.data-table th { font-family:'Sora',sans-serif; font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.05em; color:var(--muted); padding:5px 12px; text-align:left; }
.data-table td { padding:10px 12px; font-size:0.86rem; background:white; vertical-align:top; }
.data-table tr td:first-child{border-radius:var(--rsm) 0 0 var(--rsm);font-weight:600;}
.data-table tr td:last-child{border-radius:0 var(--rsm) var(--rsm) 0;color:var(--muted);font-size:0.82rem;}
.wax-badge{display:inline-block;font-size:0.71rem;font-weight:600;border-radius:8px;padding:2px 9px;white-space:nowrap;}
.wax-badge.low{background:var(--danger-bg);color:var(--danger);}
.wax-badge.med{background:var(--warn-bg);color:var(--warn);}
.wax-badge.ok{background:var(--success-bg);color:var(--success);}

/* ── FORMAT RISK GRID ── */
.format-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin:1.1rem 0; justify-items: center;}
.format-card { background:white; border-radius:var(--rsm); border:1.5px solid rgba(0,0,0,0.07); transition:box-shadow .2s; }
.format-card:hover{box-shadow:0 3px 12px rgba(0,0,0,0.07);}
.format-type{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:3px;}
.format-risk{font-size:0.76rem;color:var(--muted);margin-bottom:4px;line-height:1.4;}
.format-question{font-size:0.74rem;font-style:italic;color:var(--pc,var(--violet));line-height:1.4;}
.format-card {
  width: 280px; /* ou 100% pour du responsive */
  border: 1px solid #eee;
  border-radius: 12px;
  background: #fff;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.format-photo {
  width: 100%;
  height: 180px;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.format-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  border-radius: 0; /* ou 8px si tu veux des coins arrondis sur la photo */
}

.format-card-body {
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  width: 100%;
}

/* ── 3 FONCTIONS ── */
.fonctions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:1.1rem 0;}
.fonction-card{border-radius:var(--rsm);padding:1rem;border:1.5px solid rgba(0,0,0,0.07);background:white;}
.fonction-num{font-family:'Sora',sans-serif;font-size:1.4rem;font-weight:800;color:var(--pc,var(--violet));opacity:0.25;margin-bottom:4px;}
.fonction-title{font-family:'Sora',sans-serif;font-size:0.85rem;font-weight:700;color:var(--text);margin-bottom:4px;}
.fonction-items{font-size:0.78rem;color:var(--muted);line-height:1.6;}
.fonction-key{font-size:0.74rem;font-style:italic;color:var(--pc,var(--violet));margin-top:6px;border-top:1px solid rgba(0,0,0,0.05);padding-top:6px;}

/* ── MAT GRID ── */
.mat-needs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:1.1rem 0;}
.mat-need-card{background:white;border-radius:var(--rsm);padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.07);display:flex;align-items:flex-start;gap:10px;}
.mat-need-body{flex:1;}
.mat-need-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;color:var(--text);margin-bottom:2px;}
.mat-need-mat{font-size:0.78rem;color:var(--muted);line-height:1.45;}
.prio{display:inline-block;font-size:0.68rem;font-weight:700;border-radius:8px;padding:2px 9px;margin-bottom:4px;white-space:nowrap;}
.prio.ess{background:color-mix(in srgb,var(--pc,var(--violet)) 12%,transparent);color:var(--pc,var(--violet));}
.prio.opt{background:var(--light);color:var(--muted);}

/* ── STEPS ── */
.steps-list{display:flex;flex-direction:column;}
.step-row{display:grid;grid-template-columns:50px 1fr;position:relative;}
.step-row:not(:last-child) .step-spine::after { content:''; position:absolute; top:40px; left:50%; transform:translateX(-50%); width:2px; height:calc(100% - 40px); background:linear-gradient(to bottom,color-mix(in srgb,var(--pc) 30%,transparent) 60%,transparent); }
.step-spine{display:flex;flex-direction:column;align-items:center;position:relative;}
.step-num { width:38px; height:38px; background:var(--pc); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-family:'Sora',sans-serif; font-size:0.9rem; font-weight:800; box-shadow:0 4px 12px color-mix(in srgb,var(--pc) 35%,transparent); z-index:1; flex-shrink:0; }
.step-content{padding:2px 0 2.5rem 18px;}
.step-content h4{font-family:'Sora',sans-serif;font-size:1rem;font-weight:700;color:var(--text);margin-bottom:0.5rem;line-height:1.3;}
.step-content p{font-size:0.91rem;color:var(--text);line-height:1.72;margin-bottom:0.7rem;}
.step-content p:last-child{margin-bottom:0;}
.step-content strong{font-weight:600;}
.step-content ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;margin:0.6rem 0;}
.step-content ul li{font-size:0.88rem;padding-left:18px;position:relative;line-height:1.55;}
.step-content ul li::before{content:'→';position:absolute;left:0;color:var(--coral);font-weight:700;}

/* ── MAT INLINE ── */
.mat-inline{background:color-mix(in srgb,var(--pc,var(--violet)) 8%,white);border-radius:var(--rsm);padding:1rem 1.25rem;margin:0.9rem 0;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 22%,transparent);}
.mat-inline-label{font-family:'Sora',sans-serif;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;color:var(--pc,var(--violet));margin-bottom:0.6rem;}
.mat-links{display:flex;flex-direction:column;gap:6px;}
.mat-link-row{display:flex;align-items:center;gap:10px;background:white;border-radius:8px;padding:9px 12px;border:1px solid color-mix(in srgb,var(--pc,var(--violet)) 14%,transparent);transition:border-color .2s;flex-wrap:wrap;}
.mat-link-row:hover{border-color:color-mix(in srgb,var(--pc,var(--violet)) 35%,transparent);}
.mat-link-name{flex:1;font-size:0.86rem;font-weight:600;color:var(--text);min-width:120px;}
.mat-link-desc{font-size:0.78rem;color:var(--muted);width:100%;}
.mat-link-btn{display:inline-flex;align-items:center;gap:6px;background:var(--pc,var(--violet));color:white;text-decoration:none;padding:6px 13px;border-radius:8px;font-size:0.78rem;font-weight:600;white-space:nowrap;flex-shrink:0;transition:opacity .2s;}
.mat-link-btn::before{content:'🛒';font-size:0.82rem;}
.mat-link-btn:hover{opacity:0.82;}

/* ── CARTON COMPARE ── */
.carton-compare{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:1.1rem 0;}
.carton-c{border-radius:var(--rsm);overflow:hidden;border:2px solid transparent;text-align:center;background:white;}
.carton-c.bad-small{border-color:var(--danger-bd);}
.carton-c.bad-big{border-color:var(--warn-bd);}
.carton-c.good{border-color:var(--success-bd);}
.carton-c-ph{width:100%;height:90px;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--muted);text-align:center;padding:10px;}
.carton-c-body{padding:0.75rem 0.5rem;}
.carton-c-label{font-family:'Sora',sans-serif;font-size:0.8rem;font-weight:700;}
.carton-c.bad-small .carton-c-label{color:var(--danger);}
.carton-c.bad-big .carton-c-label{color:var(--warn);}
.carton-c.good .carton-c-label{color:var(--success);}
.carton-c-note{font-size:0.72rem;color:var(--muted);margin-top:3px;line-height:1.4;}

/* ── COFFRET COMPARE ── */
.coffret-compare{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:1.1rem 0;}
.coffret-side{border-radius:var(--rsm);overflow:hidden;border:1.5px solid rgba(0,0,0,0.07);background:white;}
.coffret-ph{width:100%;height:100px;background:var(--light);display:flex;align-items:center;justify-content:center;font-size:0.72rem;color:var(--muted);text-align:center;padding:10px;}
.coffret-body{padding:0.85rem;}
.coffret-label{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;margin-bottom:4px;}
.coffret-side.bad .coffret-label{color:var(--danger);}
.coffret-side.good .coffret-label{color:var(--success);}
.coffret-note{font-size:0.77rem;color:var(--muted);line-height:1.5;}

/* ── CHALEUR BONS RÉFLEXES ── */
.chaleur-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin:1.1rem 0;}
.chaleur-card{border-radius:var(--rsm);padding:0.9rem 1rem;border:1.5px solid transparent;background:white;}
.chaleur-card.bon{border-color:var(--success-bd);}
.chaleur-card.mauvais{border-color:var(--danger-bd);}
.chaleur-card-label{font-family:'Sora',sans-serif;font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:6px;}
.chaleur-card.bon .chaleur-card-label{color:var(--success);}
.chaleur-card.mauvais .chaleur-card-label{color:var(--danger);}
.chaleur-items{display:flex;flex-direction:column;gap:4px;}
.chaleur-item{font-size:0.8rem;color:var(--text);padding-left:16px;position:relative;line-height:1.45;}
.chaleur-item::before{position:absolute;left:0;}
.chaleur-card.bon .chaleur-item::before{content:'✓';color:var(--success);}
.chaleur-card.mauvais .chaleur-item::before{content:'✗';color:var(--danger);}

/* ── PRO SPLIT ── */
.pro-split{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin:1.1rem 0;}
.pro-col{background:white;border-radius:var(--rsm);padding:1rem;border:1.5px solid rgba(0,0,0,0.07);}
.pro-col-label{font-family:'Sora',sans-serif;font-size:0.78rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:8px;}
.pro-col.marche .pro-col-label{color:var(--p1);}
.pro-col.transport .pro-col-label{color:var(--p3);}
.pro-col ul{list-style:none;padding:0;display:flex;flex-direction:column;gap:4px;}
.pro-col ul li{font-size:0.82rem;color:var(--text);padding-left:16px;position:relative;line-height:1.5;}
.pro-col ul li::before{content:'—';position:absolute;left:0;color:var(--pc,var(--muted));font-weight:700;}
.pro-col.marche{--pc:var(--p1);}
.pro-col.transport{--pc:var(--p3);}

/* ── FORMULA BOX ── */
.formula-box{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.1rem 0;display:flex;align-items:center;flex-wrap:wrap;gap:10px;}
.formula-item{text-align:center;}
.formula-val{font-family:'Sora',sans-serif;font-size:1.5rem;font-weight:800;line-height:1;}
.formula-lbl{font-size:0.72rem;color:var(--muted);margin-top:3px;}
.formula-op{font-family:'Sora',sans-serif;font-size:1.2rem;color:var(--muted);align-self:center;}
.formula-vs{font-family:'Sora',sans-serif;font-size:0.82rem;font-weight:700;background:var(--danger-bg);color:var(--danger);border:1px solid var(--danger-bd);border-radius:8px;padding:6px 14px;white-space:nowrap;align-self:center;}
.f-violet{color:var(--violet);}
.f-danger{color:var(--danger);}

/* ── PROCEDURE ── */
.procedure{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.proc-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.proc-n{width:24px;height:24px;background:var(--pc,var(--violet));border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-family:'Sora',sans-serif;font-size:0.73rem;font-weight:800;flex-shrink:0;}

/* ── CHECKLIST ── */
.checklist{display:flex;flex-direction:column;gap:6px;margin:1.1rem 0;}
.check-item{display:flex;align-items:center;gap:12px;background:white;border-radius:var(--rsm);padding:11px 16px;border-left:3px solid var(--pc,var(--violet));font-size:0.88rem;}
.check-ico{font-size:1.1rem;flex-shrink:0;}

/* ── TIPS ── */
.tips-wrap{display:flex;flex-direction:column;gap:7px;margin:1.1rem 0;}
.tips-head{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tips-col-lbl{font-family:'Sora',sans-serif;font-size:0.74rem;font-weight:700;text-transform:uppercase;letter-spacing:0.06em;padding:6px 12px;border-radius:8px;text-align:center;}
.tips-col-lbl.g{background:var(--success-bg);color:var(--success);}
.tips-col-lbl.b{background:var(--danger-bg);color:var(--danger);}
.tips-pair{display:grid;grid-template-columns:1fr 1fr;gap:7px;}
.tip-c{border-radius:var(--rsm);padding:11px 13px;font-size:0.86rem;line-height:1.5;display:flex;align-items:flex-start;gap:8px;}
.tip-c.g{background:var(--success-bg);border:1.5px solid var(--success-bd);color:var(--success);}
.tip-c.b{background:var(--danger-bg);border:1.5px solid var(--danger-bd);color:var(--danger);}

/* ── FAQ ── */
.faq-list{display:flex;flex-direction:column;gap:7px;}
.faq-item{border:1.5px solid rgba(0,0,0,0.07);border-radius:var(--rsm);overflow:hidden;}
.faq-q{width:100%;background:none;border:none;display:flex;align-items:center;justify-content:space-between;gap:12px;padding:14px 18px;font-family:'Sora',sans-serif;font-size:0.9rem;font-weight:600;color:var(--text);cursor:pointer;text-align:left;transition:background .2s;}
.faq-q:hover{background:var(--violet-l);}
.faq-q.open{background:var(--violet);color:white;}
.faq-chev{font-size:0.65rem;flex-shrink:0;transition:transform .25s;}
.faq-q.open .faq-chev{transform:rotate(180deg);}
.faq-a{display:none;padding:14px 18px;font-size:0.9rem;color:var(--muted);background:rgba(130,105,164,0.04);border-top:1px solid rgba(130,105,164,0.1);line-height:1.7;}
.faq-a.open{display:block;}

/* ── SOURCES / AFFIL / MAJ ── */
.sources{background:var(--light);border-radius:var(--rsm);padding:1.25rem 1.5rem;margin:1.5rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.7;}
.sources strong{font-family:'Sora',sans-serif;font-size:0.8rem;color:var(--text);display:block;margin-bottom:6px;}
.sources ul{list-style:none;padding:0;}
.sources li{padding-left:14px;position:relative;}
.sources li::before{content:'·';position:absolute;left:0;}
.sources a{color:var(--violet);text-decoration:none;}
.sources a:hover{text-decoration:underline;}
.affil{background:var(--violet-l);border-radius:var(--rsm);padding:11px 16px;margin:1.25rem 0 0;display:flex;align-items:flex-start;gap:9px;font-size:0.79rem;color:var(--muted);line-height:1.5;border-left:3px solid var(--violet);}
.maj{background:var(--light);border-radius:var(--rsm);padding:0.9rem 1.25rem;margin:1.25rem 0 0;font-size:0.8rem;color:var(--muted);line-height:1.6;border-left:3px solid rgba(0,0,0,0.1);}
.maj strong{color:var(--text);font-family:'Sora',sans-serif;font-size:0.8rem;}

/* ── RESPONSIVE ── */
@media(max-width:780px){
  .hero{padding:1.75rem 1.5rem 0;}
  .hero-bottom{margin:0 -1.5rem;padding:1.25rem 1.5rem 0;}
  .hero-bottom-grid{grid-template-columns:1fr;}
  .hb-col:not(:last-child){border-bottom:1px solid var(--violet-m);}
  .part-header{padding:1.5rem;flex-direction:column;gap:0.5rem;}
  .part-num{font-size:1.8rem;}
  .prose{padding:1.5rem;}
  .en-bref{padding:1.5rem;}
  .risk-grid,.format-grid,.fonctions-grid,.chaleur-grid,.pro-split,.coffret-compare{grid-template-columns:1fr;}
  .mat-needs-grid{grid-template-columns:1fr;}
  .tips-pair,.tips-head{grid-template-columns:1fr;}
  .tips-col-lbl.b{display:none;}
  .carton-compare{grid-template-columns:1fr;}
  .step-with-img{grid-template-columns:1fr;}
  .formula-box{flex-direction:column;align-items:flex-start;gap:8px;}
  .formula-vs{align-self:flex-start;}
  .data-table,.artisan-table{display:block;overflow-x:auto;-webkit-overflow-scrolling:touch;}
}
@media(max-width:520px){
  .page{padding:0 0 2rem;}
  .en-bref,.part-header,.prose{margin-left:8px;margin-right:8px;}
  .hero{margin-left:0;margin-right:0;}
  .bc{padding:10px 12px;}
  .hero h1{font-size:1.35rem;}
  .step-row{grid-template-columns:40px 1fr;}
  .step-num{width:32px;height:32px;font-size:0.82rem;}
  .step-content{padding:2px 0 2rem 12px;}
  .sn{padding:12px 14px;font-size:0.76rem;}
  .en-bref-pills{gap:6px;}
  .eb-pill{font-size:0.78rem;padding:4px 11px;}
}
@media(prefers-reduced-motion:reduce){*{transition:none!important;animation:none!important;}}
</style>
</head>
<body>

<!-- BREADCRUMB -->
<nav class="bc" aria-label="Fil d'Ariane">
  <a href="/">Accueil</a><span>›</span>
  <a href="/conseils">Conseils d'emballage</a><span>›</span>
  <span>Envoyer des bougies par colis</span>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-eyebrow">📦 Guide complet 2026</div>
  <h1>Envoyer des bougies par colis en 2026 : emballage, chaleur, règles et transporteurs</h1>
  <div class="hero-tricolor"><span></span><span></span><span></span></div>
  <p class="hero-lead">Une bougie solide peut être expédiée par colis, à condition d'anticiper la casse, la chaleur et les mouvements internes. Le niveau de précaution dépend du format et du contenu exact du colis.</p>
  <div class="hero-meta">
    <div class="hero-pill">⏱ 10 min de lecture</div>
    <div class="hero-pill">📋 3 parties</div>
    <div class="hero-pill">🕯️ Tous formats de bougies</div>
  </div>
  <div class="hero-bottom">
    <div class="hero-bottom-grid">
      <a href="#risques" class="hb-col"><strong>Partie 1 - Identifier les risques</strong>Contenu, types de cires, formats, chaleur</a>
      <a href="#emballage" class="hb-col"><strong>Partie 2 - Emballer correctement</strong>6 étapes avec matériaux recommandés</a>
      <a href="#apres" class="hb-col"><strong>Partie 3 - Règles et vérifications</strong>Transporteurs, réglementation, preuves</a>
    </div>
  </div>
</div>

<!-- STICKY NAV -->
<nav class="sticky-nav" aria-label="Navigation">
  <div class="snav-inner">
    <a href="#risques"  class="sn active" data-part="1"><span class="sn-dot"></span>Identifier les risques</a>
    <a href="#emballage" class="sn" data-part="2"><span class="sn-dot"></span>Emballage</a>
    <a href="#apres"    class="sn" data-part="3"><span class="sn-dot"></span>Règles et vérifications</a>
  </div>
</nav>

<div class="page">

  <!-- EN BREF -->
  <div class="en-bref">
    <div class="en-bref-label">✦ En bref</div>
    <p class="en-bref-text">Une bougie solide peut généralement être envoyée par colis si elle est bien emballée, bien calée et protégée contre la casse, la chaleur et les mouvements. Le niveau de précaution dépend du format. Attention aux coffrets mixtes : huiles parfumées, sprays et aérosols doivent être vérifiés séparément.</p>
    <div class="en-bref-pills">
      <span class="eb-pill">Possible si bougie solide</span>
      <span class="eb-pill">Risque selon format</span>
      <span class="eb-pill">Coffrets mixtes à vérifier</span>
      <span class="eb-pill">Peser et mesurer avant étiquette</span>
    </div>
  </div>

  <!-- ════════ PARTIE 1 ════════ -->
  <div id="risques" class="section-gap p1">

    <div class="part-header p1">
      <div class="part-num">1</div>
      <div>
        <div class="part-tag">Identifier les risques</div>
        <h2>Avant d'envoyer des bougies : identifier le contenu et les risques réels</h2>
        <p>La première question à se poser n'est pas "comment emballer ?" mais "que contient exactement le colis ?" : une bougie solide et un coffret avec liquides ne relèvent pas des mêmes règles.</p>
      </div>
    </div>

    <div class="prose">
      <h3>Bougie seule, coffret cadeau ou produit parfumé : bien identifier le contenu</h3>
      <p>Une bougie en cire, avec ou sans pot, peut généralement être expédiée si elle est correctement préparée. En revanche, les bougies sont souvent vendues avec d'autres produits : coffrets parfumés, huiles, sprays d'ambiance, recharges liquides ou accessoires combustibles.</p>
      <p>Le transport ne classe pas les produits selon leur usage commercial, mais selon leur nature physique et réglementaire. Une chandelle classique doit surtout être protégée contre trois risques : la casse, la chaleur et les chocs internes. En revanche, parfums liquides, aérosols, gels combustibles et produits inflammables peuvent relever de règles plus strictes. En France, La Poste et Colissimo classent ces produits parmi les <strong>marchandises dangereuses interdites</strong> dans les colis postaux ordinaires.</p>
      <p><strong>Ce guide traite donc de l’expédition des bougies solides : bougies en pot, bougies en verre, chandelles, bougies moulées, bougies sculptées, coffrets de bougies et lots de plusieurs bougies.</strong></p>

