    <!-- Liste des articles -->


    {{#each actualites}}
    <article class="article-card-listing">
        <div class="article-card-content">
            <div class="article-image-container">
                <img src="/static/img/actualitesImg/{{actualiteImg}}" alt="{{actualiteImgAlt}}"
                    class="article-image-listing">
            </div>
            <div class="article-content-listing">
                <div class="article-meta-listing">
                    <div class="article-date-listing">
                        <i class="fa-regular fa-calendar"></i>
                        <span>{{publishedDate}}</span>
                    </div>
                    <div class="article-category-listing">{{keyWord}}</div>
                </div>
                <h2 class="article-title-listing">
                    <a href="/actualites/{{slug}}">
                        {{resumeTitle}}
                    </a>
                </h2>
                <p class="article-excerpt-listing">
                    {{description}}
                </p>
                <a href="/actualites/{{slug}}" class="article-read-more-listing">
                    Lire l'article complet
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </article>
    {{/each}}

    <!-- Pagination -->
    {{#if totalPages}}
    <div class="pagination-container">
        <nav class="pagination-nav">
            {{#if (gt currentPage 1)}}
            <a href="?page={{subtract currentPage 1}}" class="pagination-link">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            {{else}}
            <span class="pagination-link disabled">
                <i class="fa-solid fa-chevron-left"></i>
            </span>
            {{/if}}

            {{#each (range 1 totalPages)}}
            <a href="?page={{this}}" class="pagination-link {{#if (eq ../currentPage this)}}active{{/if}}">
                {{this}}
            </a>
            {{/each}}

            {{#if (lt currentPage totalPages)}}
            <a href="?page={{add currentPage 1}}" class="pagination-link">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
            {{else}}
            <span class="pagination-link disabled">
                <i class="fa-solid fa-chevron-right"></i>
            </span>
            {{/if}}
        </nav>
    </div>
    {{/if}}

    <!-- CTA retour accueil -->
    <div class="back-to-home">
        <a href="/" class="home-cta">
            <i class="fa-solid fa-home"></i>
            Retour à l'accueil
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</div>

<!-- ===== SECTION À DÉCOUVRIR (HBS) ===== -->
<section class="related-links py-5">
    <div class="container first-container">
        <div class="text-center mb-4">
            <h3 class="related-title">Découvrez l'univers du colis</h3>
            <p class="related-subtitle">Tous nos services pour une expédition parfaite</p>
        </div>

        <div class="row g-4">
            <!-- Comparateur de prix -->
            <div class="col-md-3">
                <a href="/" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-balance-scale"></i>
                    </div>
                    <h4 class="link-title">Comparer les prix</h4>
                    <p class="link-description">Trouvez le meilleur tarif pour votre expédition</p>
                    <span class="link-action">
                        Comparer maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Suivi de colis -->
            <div class="col-md-3">
                <a href="/suivi" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-map-marker-alt"></i>
                    </div>
                    <h4 class="link-title">Suivre mon colis</h4>
                    <p class="link-description">Suivez votre expédition en temps réel</p>
                    <span class="link-action">
                        Suivre maintenant <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Matériel d'emballage -->
            <div class="col-md-3">
                <a href="/mon-materiel" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-box"></i>
                    </div>
                    <h4 class="link-title">Matériel d'emballage</h4>
                    <p class="link-description">Découvrez le matériel essentiel pour emballer</p>
                    <span class="link-action">
                        Voir le matériel <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Conseils d'emballage -->
            <div class="col-md-3">
                <a href="/conseils" class="link-card">
                    <div class="link-icon">
                        <i class="fa-solid fa-lightbulb"></i>
                    </div>
                    <h4 class="link-title">Conseils d'emballage</h4>
                    <p class="link-description">Astuces pour un emballage réussi</p>
                    <span class="link-action">
                        Lire les conseils <i class="fa-solid fa-arrow-right ms-1"></i>
                    </span>
                </a>
            </div>

            <!-- Services à venir -->
            <div class="col-md-3">
                <div class="link-card coming-soon">
                    <div class="link-icon">
                        <i class="fa-solid fa-hourglass-half"></i>
                    </div>
                    <h4 class="link-title">Services à venir</h4>
                    <p class="link-description">De nouveaux services arrivent bientôt</p>
                    <span class="link-action">
                        Bientôt disponible <i class="fa-solid fa-clock ms-1"></i>
                    </span>
                </div>
            </div>
        </div>

        <!-- Call-to-action principal -->
        <div class="text-center mt-5">
            <div class="main-cta">
                <h4 class="cta-title">Prêt à expédier votre colis ?</h4>
                <p class="cta-subtitle">Comparez les prix et trouvez la meilleure offre en quelques clics</p>
                <a href="/" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-rocket me-2"></i>Commencer maintenant
                </a>
            </div>
        </div>
    </div>
</section>