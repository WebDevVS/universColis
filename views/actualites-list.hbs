        <a href="/" class="breadcrumb-link">Accueil</a>
        <span class="mx-2">></span>
        <span class="breadcrumb-current">Actualités</span>
    </div>
</nav>

<div class="articles-container mt-3">

    <!-- Header de la page -->
    <header class="page-header">
        <div class="articles-container mt-3">
            <h1 class="page-title">Les actualités</h1>
            <p class="page-subtitle">
                Restez informé des dernières évolutions qui impactent vos envois
            </p>
        </div>
    </header>

