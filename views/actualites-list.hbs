    <!-- Liste des articles -->


    {{#each actualites}}
    <article class="article-card-listing">
        <div class="article-card-content">
            <div class="article-image-container">
                <img src="/static/img/actualitesImg/{{actualiteImg}}" alt="{{actualiteImgAlt}}"
                    class="article-image-listing" width="320" height="180" loading="lazy">
            </div>
            <div class="article-content-listing">
                <div class="article-meta-listing">
                    <div class="article-date-listing">
                        <i class="fa-regular fa-calendar"></i>
                        <span>{{formatDate publishedDate}}</span>
                    </div>
                    <div class="article-category-listing">{{keyWord}}</div>
                </div>
                <h2 class="article-title-listing">
                    <a href="/actualites/{{slug}}">
                        {{resumeTitle}}
                    </a>
                </h2>
                <p class="article-excerpt-listing">
                    {{description}}
                </p>
                <a href="/actualites/{{slug}}" class="article-read-more-listing">
                    Lire l'article complet
                    <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </article>
    {{/each}}

    <!-- Pagination -->
    {{#if totalPages}}
    <div class="pagination-container">
        <nav class="pagination-nav">
            {{#if (gt currentPage 1)}}
            <a href="?page={{subtract currentPage 1}}" class="pagination-link">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            {{else}}
            <span class="pagination-link disabled">
                <i class="fa-solid fa-chevron-left"></i>
            </span>
            {{/if}}

            {{#each (range 1 totalPages)}}
            <a href="?page={{this}}" class="pagination-link {{#if (eq ../currentPage this)}}active{{/if}}">
                {{this}}
            </a>
            {{/each}}

            {{#if (lt currentPage totalPages)}}
            <a href="?page={{add currentPage 1}}" class="pagination-link">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
            {{else}}
            <span class="pagination-link disabled">
                <i class="fa-solid fa-chevron-right"></i>
            </span>
            {{/if}}
        </nav>
    </div>
    {{/if}}

    {{#if showEzoic}}
    <div id="ezoic-pub-ad-placeholder-103"></div>
    {{/if}}

    <!-- CTA retour accueil -->
    <div class="back-to-home">
        <a href="/" class="home-cta">
            <i class="fa-solid fa-home"></i>
            Retour à l'accueil
            <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>

</div>

<!-- Section "À découvrir" CONTEXTUELLE  -->
   {{> related-links/_base pageType="actualites"}} 

{{#if showEzoic}}
<script>
    ezstandalone.cmd.push(function () {
        ezstandalone.showAds(103);
    });
